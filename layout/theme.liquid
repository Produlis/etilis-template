<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    {% # Design tokens (static defaults for spacing, sizing, motion, etc.) %}
    {{ 'tokens.css' | asset_url | stylesheet_tag: preload: true }}

    {% # Dynamic CSS variables — color scheme, typography, radius %}
    {% render 'css-variables' %}

    {% comment %}
      Font preloading:
      Preload the critical Inter font weights (Regular + SemiBold) to
      avoid layout shift. Other weights load on-demand via @font-face.
    {% endcomment %}
    <link rel="preload" href="{{ 'Inter-Regular.woff2' | asset_url }}" as="font" type="font/woff2" crossorigin>
    <link rel="preload" href="{{ 'Inter-SemiBold.woff2' | asset_url }}" as="font" type="font/woff2" crossorigin>

    {% # Load and preload the critical CSS %}
    {{ 'critical.css' | asset_url | stylesheet_tag: preload: true }}

    {% # Global component styles %}
    {{ 'components.css' | asset_url | stylesheet_tag }}

    {% # Style guide layout (conditional) %}
    {% if template.suffix == 'style-guide' %}
      {{ 'style-guide.css' | asset_url | stylesheet_tag }}
    {% endif %}

    {% # Favicon %}
    {% render 'favicon' %}

    {% # Social, title, etc. %}
    {% render 'meta-tags' %}

    {% # Block indexing for internal pages %}
    {% if template.suffix == 'style-guide' %}
      <meta name="robots" content="noindex,nofollow">
    {% endif %}

    {{ content_for_header }}
  </head>

  <body data-scheme="nature">
    {% sections 'header-group' %}

    {{ content_for_layout }}

    {% sections 'footer-group' %}
  </body>
</html>

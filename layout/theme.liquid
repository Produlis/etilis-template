<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    {% # Design tokens (static defaults for spacing, sizing, motion, etc.) %}
    {{ 'tokens.css' | asset_url | stylesheet_tag: preload: true }}

    {% # Dynamic CSS variables — color scheme, typography, radius %}
    {% render 'css-variables' %}

    {% comment %}
      Font preloading:
      1. Preconnect to font CDN for faster connection
      2. Preload the critical font variants for heading and body
      3. Additional variants load on-demand via @font-face
    {% endcomment %}
    {% unless settings.type_heading_font.system? %}
      <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
      {{ settings.type_heading_font | font_url | preload_tag: as: 'font', crossorigin: 'anonymous' }}
    {% endunless %}

    {% unless settings.type_body_font.system? %}
      {% if settings.type_heading_font.system? %}
        <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
      {% endif %}
      {{ settings.type_body_font | font_url | preload_tag: as: 'font', crossorigin: 'anonymous' }}
    {% endunless %}

    {% # Load and preload the critical CSS %}
    {{ 'critical.css' | asset_url | stylesheet_tag: preload: true }}

    {% # Global component styles %}
    {{ 'components.css' | asset_url | stylesheet_tag }}

    {% # Style guide layout (conditional) %}
    {% if template.suffix == 'style-guide' %}
      {{ 'style-guide.css' | asset_url | stylesheet_tag }}
    {% endif %}

    {% # Social, title, etc. %}
    {% render 'meta-tags' %}

    {% # Block indexing for internal pages %}
    {% if template.suffix == 'style-guide' %}
      <meta name="robots" content="noindex,nofollow">
    {% endif %}

    {{ content_for_header }}
  </head>

  <body data-scheme="{{ settings.color_scheme }}">
    {% sections 'header-group' %}

    {{ content_for_layout }}

    {% sections 'footer-group' %}
  </body>
</html>

[
  {
    "name": "theme_info",
    "theme_name": "Skeleton",
    "theme_version": "0.1.0",
    "theme_author": "Shopify",
    "theme_documentation_url": "https://help.shopify.com/manual/online-store/themes",
    "theme_support_url": "https://support.shopify.com/"
  },
  {
    "name": "t:general.typography",
    "settings": [
      {
        "type": "header",
        "content": "t:general.fonts"
      },
      {
        "type": "font_picker",
        "id": "type_heading_font",
        "default": "playfair_display_n7",
        "label": "t:labels.heading_font"
      },
      {
        "type": "font_picker",
        "id": "type_body_font",
        "default": "inter_n4",
        "label": "t:labels.body_font"
      }
    ]
  },
  {
    "name": "t:general.favicon",
    "settings": [
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "t:labels.favicon",
        "info": "t:labels.favicon_info"
      }
    ]
  },
  {
    "name": "t:general.layout",
    "settings": [
      {
        "type": "select",
        "id": "max_page_width",
        "label": "t:labels.page_width",
        "options": [
          {
            "value": "90rem",
            "label": "t:options.page_width.narrow"
          },
          {
            "value": "110rem",
            "label": "t:options.page_width.wide"
          }
        ],
        "default": "90rem"
      },
      {
        "type": "range",
        "id": "min_page_margin",
        "min": 10,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "t:labels.page_margin",
        "default": 20
      }
    ]
  },
  {
    "name": "t:general.color_scheme",
    "settings": [
      {
        "type": "select",
        "id": "color_scheme",
        "label": "t:labels.color_scheme",
        "info": "t:labels.color_scheme_info",
        "options": [
          {
            "value": "minimal",
            "label": "t:options.color_scheme.minimal"
          },
          {
            "value": "nature",
            "label": "t:options.color_scheme.nature"
          },
          {
            "value": "sky",
            "label": "t:options.color_scheme.sky"
          }
        ],
        "default": "minimal"
      },
      {
        "type": "header",
        "content": "t:labels.color_overrides"
      },
      {
        "type": "color",
        "id": "color_override_accent",
        "label": "t:labels.color_accent",
        "info": "t:labels.color_override_info"
      },
      {
        "type": "color",
        "id": "color_override_bg",
        "label": "t:labels.color_bg",
        "info": "t:labels.color_override_info"
      },
      {
        "type": "color",
        "id": "color_override_text",
        "label": "t:labels.color_text_primary",
        "info": "t:labels.color_override_info"
      },
      {
        "type": "color",
        "id": "color_override_surface",
        "label": "t:labels.color_surface",
        "info": "t:labels.color_override_info"
      }
    ]
  }
]

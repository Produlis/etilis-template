{% doc %}
  Injects CSS custom properties for the Nature color scheme, typography, and
  border-radius tokens. All visual tokens are applied site-wide.

  The snippet also applies individual color overrides when the merchant sets
  them, so they can fine-tune colors without touching code.

  Loaded in layout/theme.liquid inside <head>.

  @example
  {% render 'css-variables' %}
{% enddoc %}

<style>
  /*
   * Font face declarations — loaded for heading and body fonts
   * selected by the merchant in Theme Settings > Typography.
   * font-display: swap avoids invisible text during load.
   */
  {{ settings.type_heading_font | font_face: font_display: 'swap' }}
  {{ settings.type_heading_font | font_modify: 'weight', 'bold' | font_face: font_display: 'swap' }}
  {{ settings.type_body_font | font_face: font_display: 'swap' }}
  {{ settings.type_body_font | font_modify: 'weight', 'bold' | font_face: font_display: 'swap' }}
  {{ settings.type_body_font | font_modify: 'style', 'italic' | font_face: font_display: 'swap' }}

  {%- comment -%}
    NATURE color scheme — Organic, sustainable, wellness, trust.
    Deep forest greens with warm cream undertones. Pill-shaped
    buttons and generous radius for a soft, organic feel.
    CTA green (#1C3A13) passes WCAG AA on cream (12.5:1).
  {%- endcomment -%}
  {%- assign scheme_bg = '#FCFCF7' -%}
  {%- assign scheme_bg_subtle = '#F2F3E7' -%}
  {%- assign scheme_surface = '#FFFFFF' -%}
  {%- assign scheme_border = '#D2D4C4' -%}
  {%- assign scheme_text = '#1C3A13' -%}
  {%- assign scheme_text_secondary = '#434141' -%}
  {%- assign scheme_text_disabled = '#A8AFA6' -%}
  {%- assign scheme_accent = '#1C3A13' -%}
  {%- assign scheme_accent_hover = '#37522F' -%}
  {%- assign scheme_accent_text = '#FFFFFF' -%}
  {%- assign scheme_highlight = '#D3FA99' -%}
  {%- assign scheme_success = '#1C3A13' -%}
  {%- assign scheme_error = '#B84040' -%}
  {%- assign scheme_focus = '#1C3A13' -%}
  {%- assign scheme_primary_light = '#37522F' -%}
  {%- assign scheme_text_on_accent = '#1C3A13' -%}
  {%- assign scheme_text_on_dark = '#CDD1CC' -%}
  {%- assign scheme_input_border_dark = '#4F6748' -%}
  {%- assign scheme_neutral_300 = '#D2D4C4' -%}
  {%- assign scheme_neutral_400 = '#A8AFA6' -%}
  {%- assign scheme_neutral_800 = '#0F200A' -%}
  {%- assign scheme_radius_btn = '48px' -%}
  {%- assign scheme_radius_card = '24px' -%}
  {%- assign scheme_radius_input = '56px' -%}
  {%- assign scheme_radius_badge = '28px' -%}
  {%- assign scheme_radius_image = '16px' -%}

  /*
   * Merchant color overrides — applied on top of the active scheme
   * so the merchant can tweak individual values without switching
   * the entire palette.
   */
  {%- if settings.color_override_accent != blank -%}
    {%- assign scheme_accent = settings.color_override_accent -%}
  {%- endif -%}
  {%- if settings.color_override_bg != blank -%}
    {%- assign scheme_bg = settings.color_override_bg -%}
  {%- endif -%}
  {%- if settings.color_override_text != blank -%}
    {%- assign scheme_text = settings.color_override_text -%}
  {%- endif -%}
  {%- if settings.color_override_surface != blank -%}
    {%- assign scheme_surface = settings.color_override_surface -%}
  {%- endif -%}

  :root {
    /* ===== Typography ===== */
    --font-heading: {{ settings.type_heading_font.family }}, {{ settings.type_heading_font.fallback_families }};
    --font-body: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
    --font-sans: var(--font-body);

    /* ===== Layout ===== */
    --container-max: {{ settings.max_page_width }};
    --container-padding: {{ settings.min_page_margin }}px;

    /* ===== Color scheme — semantic tokens ===== */

    /* Backgrounds */
    --color-bg: {{ scheme_bg }};
    --color-bg-subtle: {{ scheme_bg_subtle }};
    --color-surface: {{ scheme_surface }};

    /* Text */
    --color-text: {{ scheme_text }};
    --color-text-muted: {{ scheme_text_secondary }};
    --color-text-disabled: {{ scheme_text_disabled }};
    --color-text-inverse: {{ scheme_accent_text }};

    /* Accent / CTA */
    --color-accent: {{ scheme_accent }};
    --color-accent-hover: {{ scheme_accent_hover }};
    --color-accent-text: {{ scheme_accent_text }};
    --color-highlight: {{ scheme_highlight }};

    /* Borders */
    --color-border: {{ scheme_border }};
    --color-divider: {{ scheme_bg_subtle }};

    /* Status */
    --color-success: {{ scheme_success }};
    --color-error: {{ scheme_error }};
    --color-danger: {{ scheme_error }};
    --color-warning: #CA8A04;
    --color-info: {{ scheme_accent }};

    /* Interactive */
    --color-focus: {{ scheme_focus }};
    --color-link: {{ scheme_accent }};
    --color-link-hover: {{ scheme_accent_hover }};

    /* Legacy aliases — keeps existing components working */
    --color-brand-primary: {{ scheme_accent }};
    --color-brand-secondary: {{ scheme_text_secondary }};
    --color-brand-accent: {{ scheme_highlight }};
    --color-surface-2: {{ scheme_bg_subtle }};
    --color-neutral-0: {{ scheme_surface }};
    --color-neutral-300: {{ scheme_neutral_300 }};
    --color-neutral-400: {{ scheme_neutral_400 }};
    --color-neutral-800: {{ scheme_neutral_800 }};

    /* ===== Overlay & glass effects ===== */
    --color-overlay: rgb(0 0 0 / 0.5);
    --color-hover-subtle: rgb(0 0 0 / 0.05);
    --color-hover-subtle-2: rgb(0 0 0 / 0.04);
    --color-hover-subtle-3: rgb(0 0 0 / 0.02);
    --color-glass-bg: rgb(255 255 255 / 0.12);
    --color-glass-bg-heavy: rgb(255 255 255 / 0.88);
    --color-glass-border: rgb(255 255 255 / 0.12);
    --color-glass-border-heavy: rgb(255 255 255 / 0.8);
    --color-on-primary-subtle: rgb(255 255 255 / 0.2);
    --color-on-primary-muted: rgb(255 255 255 / 0.1);
    --color-on-primary-faint: rgb(255 255 255 / 0.05);
    --color-on-primary-dim: rgb(255 255 255 / 0.08);
    --color-on-primary-hover: rgb(255 255 255 / 0.4);
    --color-dark-glass-bg: color-mix(in srgb, {{ scheme_accent }} 12%, transparent);
    --color-x-mark-bg: rgb(255 255 255 / 0.15);
    --color-x-mark-stroke: rgb(255 255 255 / 0.5);
    --color-on-dark-green: color-mix(in srgb, {{ scheme_accent }} 40%, transparent);
    --color-shadow-inset: rgb(0 0 0 / 0.2);
    --color-shadow-inset-light: rgb(255 255 255 / 0.9);

    /* ===== Theme-specific aliases for sections ===== */
    --theme-primary: {{ scheme_accent }};
    --theme-primary-hover: {{ scheme_accent_hover }};
    --theme-primary-light: {{ scheme_primary_light }};
    --theme-primary-dark: {{ scheme_text }};
    --theme-accent: {{ scheme_highlight }};
    --theme-accent-hover: {{ scheme_accent_hover }};
    --theme-text-on-accent: {{ scheme_text_on_accent }};
    --theme-surface: {{ scheme_bg }};
    --theme-surface-alt: {{ scheme_bg_subtle }};
    --theme-surface-muted: {{ scheme_border }};
    --theme-surface-emphasis: {{ scheme_border }};
    --theme-text: {{ scheme_text }};
    --theme-text-secondary: {{ scheme_text_secondary }};
    --theme-text-on-primary: {{ scheme_accent_text }};
    --theme-text-on-dark: {{ scheme_text_on_dark }};
    --theme-text-muted: {{ scheme_text_disabled }};
    --theme-text-dim: {{ scheme_text_disabled }};
    --theme-border: {{ scheme_border }};
    --theme-input-border: {{ scheme_border }};
    --theme-input-border-dark: {{ scheme_input_border_dark }};
    --theme-star: #FFB800;

    /* ===== Border radius per scheme ===== */
    --radius-btn: {{ scheme_radius_btn }};
    --radius-card: {{ scheme_radius_card }};
    --radius-input: {{ scheme_radius_input }};
    --radius-badge: {{ scheme_radius_badge }};
    --radius-image: {{ scheme_radius_image }};
    --theme-radius-card: {{ scheme_radius_card }};
    --theme-radius-button: {{ scheme_radius_btn }};
    --theme-radius-badge: {{ scheme_radius_badge }};
    --theme-radius-image: {{ scheme_radius_image }};
  }
</style>

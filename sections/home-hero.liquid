<div class="home-hero full-width">
  <div class="home-hero__container">
    <div class="home-hero__left">
      <div class="home-hero__top-content">
        {%- if section.settings.review_text != blank -%}
          <div class="home-hero__review-badge">
            <span class="home-hero__star-icon">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M8 0.5L10.12 5.26L15.5 5.85L11.45 9.54L12.58 14.84L8 12.27L3.42 14.84L4.55 9.54L0.5 5.85L5.88 5.26L8 0.5Z" fill="var(--theme-primary)"/>
              </svg>
            </span>
            <span class="home-hero__review-text">{{ section.settings.review_text }}</span>
          </div>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h1 class="home-hero__heading">{{ section.settings.heading }}</h1>
        {%- endif -%}

        {%- if section.settings.body_text != blank -%}
          <p class="home-hero__body">{{ section.settings.body_text }}</p>
        {%- endif -%}

        {%- if section.settings.button_text != blank -%}
          <a
            class="home-hero__cta"
            {% if section.settings.button_url != blank %}
              href="{{ section.settings.button_url }}"
            {% endif %}
          >
            <span class="home-hero__cta-icon">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M8 2L14 8L8 14" stroke="var(--theme-text-on-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M14 8H2" stroke="var(--theme-text-on-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
            <span class="home-hero__cta-text">{{ section.settings.button_text }}</span>
          </a>
        {%- endif -%}
      </div>

      {%- assign bundle_product = section.settings.bundle_product -%}
      <div class="home-hero__bundle">
        <div class="home-hero__bundle-card">
          <div class="home-hero__bundle-image">
            {%- if bundle_product != blank and bundle_product.featured_image != blank -%}
              {{ bundle_product.featured_image | image_url: width: 310, height: 272 | image_tag: loading: 'lazy' }}
            {%- elsif section.settings.bundle_image != blank -%}
              {{ section.settings.bundle_image | image_url: width: 310, height: 272 | image_tag: loading: 'lazy' }}
            {%- else -%}
              <div class="home-hero__bundle-image-placeholder">
                {{ 'product-2' | placeholder_svg_tag }}
              </div>
            {%- endif -%}
          </div>

          <div class="home-hero__bundle-info">
            <div class="home-hero__bundle-details">
              <div class="home-hero__bundle-header">
                {%- liquid
                  if section.settings.bundle_label != blank
                    assign bundle_label_text = section.settings.bundle_label
                  elsif bundle_product != blank
                    assign bundle_label_text = bundle_product.title
                  else
                    assign bundle_label_text = ''
                  endif

                  assign bundle_badge_text = ''
                  if section.settings.bundle_badge != blank
                    assign bundle_badge_text = section.settings.bundle_badge
                  elsif bundle_product != blank
                    if bundle_product.compare_at_price > bundle_product.price
                      assign savings = bundle_product.compare_at_price | minus: bundle_product.price
                      assign pct = savings | times: 100 | divided_by: bundle_product.compare_at_price
                      assign bundle_badge_text = 'SAVE ' | append: pct | append: '%+'
                    endif
                  endif
                -%}
                {%- if bundle_label_text != blank -%}
                  <span class="home-hero__bundle-label">{{ bundle_label_text }}</span>
                {%- endif -%}
                {%- if bundle_badge_text != blank -%}
                  <span class="home-hero__bundle-badge">{{ bundle_badge_text }}</span>
                {%- endif -%}
              </div>

              {%- if section.settings.bundle_description != blank -%}
                <p class="home-hero__bundle-description">{{ section.settings.bundle_description }}</p>
              {%- endif -%}
            </div>

            <div class="home-hero__bundle-footer">
              <div class="home-hero__bundle-prices">
                {%- if bundle_product != blank -%}
                  <span class="home-hero__bundle-price">{{ bundle_product.price | money }}</span>
                  {%- if bundle_product.compare_at_price > bundle_product.price -%}
                    <span class="home-hero__bundle-compare-price">{{ bundle_product.compare_at_price | money }}</span>
                  {%- endif -%}
                {%- else -%}
                  {%- if section.settings.bundle_price != blank -%}
                    <span class="home-hero__bundle-price">{{ section.settings.bundle_price }}</span>
                  {%- endif -%}
                  {%- if section.settings.bundle_compare_price != blank -%}
                    <span class="home-hero__bundle-compare-price">{{ section.settings.bundle_compare_price }}</span>
                  {%- endif -%}
                {%- endif -%}
              </div>

              {%- if bundle_product != blank -%}
                {%- form 'product', bundle_product -%}
                  <input type="hidden" name="id" value="{{ bundle_product.selected_or_first_available_variant.id }}">
                  <button
                    type="submit"
                    class="home-hero__bundle-button"
                    {% unless bundle_product.available %}disabled{% endunless %}
                  >
                    {%- if bundle_product.available -%}
                      {%- if section.settings.bundle_button_text != blank -%}
                        {{ section.settings.bundle_button_text }}
                      {%- else -%}
                        {{ 'products.hero.add_to_cart' | t }}
                      {%- endif -%}
                    {%- else -%}
                      {{ 'products.sold_out' | t }}
                    {%- endif -%}
                  </button>
                {%- endform -%}
              {%- elsif section.settings.bundle_button_text != blank -%}
                <a
                  class="home-hero__bundle-button"
                  {% if section.settings.bundle_button_url != blank %}
                    href="{{ section.settings.bundle_button_url }}"
                  {% endif %}
                >
                  {{ section.settings.bundle_button_text }}
                </a>
              {%- endif -%}
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="home-hero__right">
      {%- if section.settings.image != blank -%}
        <div class="home-hero__image">
          {{ section.settings.image | image_url: width: 1224 | image_tag: loading: 'eager' }}
        </div>
      {%- else -%}
        <div class="home-hero__image home-hero__image--placeholder">
          {{ 'product-1' | placeholder_svg_tag }}
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

{% stylesheet %}
  .home-hero {
    background-color: var(--theme-surface);
    padding: 52px;
  }

  .home-hero__container {
    display: flex;
    flex-direction: row;
    gap: 40px;
    max-width: var(--container-max);
    margin: 0 auto;
    align-items: stretch;
  }

  .home-hero__left {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 32px;
  }

  .home-hero__top-content {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  /* Review badge */
  .home-hero__review-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background-color: var(--theme-accent);
    color: var(--theme-text-on-accent);
    border-radius: var(--theme-radius-badge);
    padding: 6px 16px;
    width: fit-content;
  }

  .home-hero__star-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .home-hero__review-text {
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-medium);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wider);
    line-height: var(--line-height-none);
  }

  /* Heading */
  .home-hero__heading {
    font-size: var(--font-size-5xl);
    line-height: var(--line-height-tight);
    color: var(--theme-primary);
    letter-spacing: var(--letter-spacing-tighter);
    font-weight: var(--font-weight-bold);
    margin: 0;
  }

  /* Body text */
  .home-hero__body {
    font-size: var(--font-size-base);
    line-height: var(--line-height-normal);
    color: var(--theme-text-secondary);
    max-width: 423px;
    margin: 0;
  }

  /* CTA Button */
  .home-hero__cta {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background-color: var(--theme-primary);
    color: var(--theme-text-on-primary);
    border-radius: var(--theme-radius-button);
    padding: 8px 24px 8px 8px;
    text-decoration: none;
    width: fit-content;
    transition: opacity var(--duration-fast, 150ms) var(--ease-standard, ease);
  }

  .home-hero__cta:hover {
    opacity: 0.85;
  }

  .home-hero__cta:focus-visible {
    outline: 2px solid var(--color-focus, var(--theme-primary));
    outline-offset: 2px;
    border-radius: var(--theme-radius-button);
  }

  .home-hero__cta-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background-color: var(--theme-primary-light);
    border-radius: var(--radius-round);
    flex-shrink: 0;
  }

  .home-hero__cta-text {
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-medium);
    line-height: var(--line-height-none);
  }

  /* Bundle upsell card */
  .home-hero__bundle-card {
    display: flex;
    flex-direction: row;
    gap: 16px;
    background-color: var(--theme-surface-alt);
    border-radius: var(--theme-radius-card);
    padding: 8px 16px 8px 8px;
    align-items: center;
  }

  .home-hero__bundle-image {
    flex-shrink: 0;
    width: 155px;
    height: 136px;
    border-radius: var(--theme-radius-image);
    overflow: hidden;
  }

  .home-hero__bundle-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .home-hero__bundle-image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--theme-surface-alt);
    border-radius: var(--theme-radius-image);
  }

  .home-hero__bundle-image-placeholder svg {
    width: 60%;
    height: auto;
    opacity: 0.4;
  }

  .home-hero__bundle-info {
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex: 1;
    min-width: 0;
  }

  .home-hero__bundle-header {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .home-hero__bundle-label {
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-regular);
    line-height: var(--line-height-normal);
    color: var(--theme-primary);
  }

  .home-hero__bundle-badge {
    display: inline-flex;
    align-items: center;
    background-color: var(--theme-accent);
    color: var(--theme-text-on-accent);
    border-radius: var(--theme-radius-badge);
    padding: 4px 8px;
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-medium);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wider);
    line-height: var(--line-height-normal);
  }

  .home-hero__bundle-description {
    font-size: var(--font-size-sm);
    line-height: var(--line-height-snug);
    color: var(--theme-text-secondary);
    margin: 0;
  }

  .home-hero__bundle-details {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .home-hero__bundle-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
  }

  .home-hero__bundle-prices {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .home-hero__bundle-price {
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-regular);
    line-height: var(--line-height-normal);
    color: var(--theme-primary);
  }

  .home-hero__bundle-compare-price {
    font-size: var(--font-size-xs);
    line-height: var(--line-height-snug);
    color: color-mix(in srgb, var(--theme-primary) 40%, transparent);
    text-decoration: line-through;
  }

  .home-hero__bundle-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: var(--theme-surface-muted);
    color: var(--theme-primary);
    border-radius: var(--theme-radius-button);
    height: 44px;
    padding: 0 20px;
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-medium);
    letter-spacing: var(--letter-spacing-tight);
    line-height: var(--line-height-normal);
    text-decoration: none;
    white-space: nowrap;
    transition: opacity var(--duration-fast, 150ms) var(--ease-standard, ease);
  }

  .home-hero__bundle-button:hover {
    opacity: 0.85;
  }

  .home-hero__bundle-button:focus-visible {
    outline: 2px solid var(--color-focus, var(--theme-primary));
    outline-offset: 2px;
  }

  .home-hero__bundle-button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  button.home-hero__bundle-button {
    border: none;
    cursor: pointer;
    font-family: inherit;
  }

  /* Right column - hero image */
  .home-hero__right {
    flex: 1;
  }

  .home-hero__image {
    min-height: 500px;
    height: 100%;
    border-radius: var(--theme-radius-card);
    overflow: hidden;
  }

  .home-hero__image img,
  .home-hero__image svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .home-hero__image--placeholder {
    background-color: var(--theme-surface-alt);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .home-hero__image--placeholder svg {
    width: 50%;
    height: auto;
    opacity: 0.4;
  }

  /* Mobile styles */
  @media screen and (max-width: 749px) {
    .home-hero {
      padding: 24px 16px;
    }

    .home-hero__container {
      flex-direction: column;
      gap: 24px;
    }

    .home-hero__heading {
      font-size: var(--font-size-3xl);
      line-height: var(--line-height-tight);
      letter-spacing: var(--letter-spacing-tighter);
    }

    .home-hero__body {
      max-width: 100%;
    }

    .home-hero__image {
      min-height: 0;
      height: auto;
      aspect-ratio: 4 / 3;
    }

    .home-hero__bundle-card {
      flex-direction: row;
      gap: 12px;
      padding: 8px 12px 8px 8px;
    }

    .home-hero__bundle-image {
      width: 80px;
      height: 70px;
    }

    .home-hero__bundle-description {
      display: none;
    }

    .home-hero__bundle-button {
      height: 36px;
      padding: 0 12px;
      font-size: var(--font-size-sm);
    }
  }

  /* Tablet adjustments */
  @media screen and (min-width: 750px) and (max-width: 989px) {
    .home-hero {
      padding: 32px;
    }

    .home-hero__container {
      gap: 24px;
    }

    .home-hero__heading {
      font-size: var(--font-size-4xl);
      line-height: var(--line-height-tight);
    }

    .home-hero__image {
      min-height: 0;
      height: auto;
      aspect-ratio: 3 / 4;
    }

    .home-hero__bundle-card {
      flex-direction: column;
      align-items: flex-start;
    }

    .home-hero__bundle-image {
      width: 100%;
      height: 120px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.home_hero.name",
  "settings": [
    {
      "type": "text",
      "id": "review_text",
      "label": "t:labels.review_text",
      "default": "10,078+ FIVE-STAR REVIEWS"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "A health gut can change your life."
    },
    {
      "type": "textarea",
      "id": "body_text",
      "label": "t:labels.body_text",
      "default": "Our capsule-in-capsule technology delivers the right probiotic strains to the right places to ease bloating, gas, and irregularity."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "t:labels.button_text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "t:labels.button_url"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:labels.image"
    },
    {
      "type": "header",
      "content": "t:labels.bundle"
    },
    {
      "type": "product",
      "id": "bundle_product",
      "label": "t:labels.bundle_product"
    },
    {
      "type": "image_picker",
      "id": "bundle_image",
      "label": "t:sections.home_hero.settings.bundle_image_override"
    },
    {
      "type": "text",
      "id": "bundle_label",
      "label": "t:labels.bundle_label",
      "default": "Bundle"
    },
    {
      "type": "text",
      "id": "bundle_badge",
      "label": "t:labels.bundle_badge",
      "default": "Save 50%+"
    },
    {
      "type": "textarea",
      "id": "bundle_description",
      "label": "t:labels.description",
      "default": "Add DM-02™ Daily Multivitamin to your routine and save on your first order."
    },
    {
      "type": "text",
      "id": "bundle_button_text",
      "label": "t:labels.button_text",
      "default": "Add to Cart"
    },
    {
      "type": "text",
      "id": "bundle_price",
      "label": "t:sections.home_hero.settings.bundle_price_fallback",
      "default": "$109.00"
    },
    {
      "type": "text",
      "id": "bundle_compare_price",
      "label": "t:sections.home_hero.settings.bundle_compare_price_fallback",
      "default": "$199.99"
    },
    {
      "type": "url",
      "id": "bundle_button_url",
      "label": "t:sections.home_hero.settings.bundle_button_url_fallback"
    }
  ],
  "presets": [
    {
      "name": "t:sections.home_hero.name"
    }
  ]
}
{% endschema %}

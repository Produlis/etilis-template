<div class="home-hero full-width">
  <div class="home-hero__container">
    <div class="home-hero__left">
      <div class="home-hero__top-content">
        {%- if section.settings.review_text != blank -%}
          <div class="home-hero__review-badge">
            <span class="home-hero__star-icon">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M8 0.5L10.12 5.26L15.5 5.85L11.45 9.54L12.58 14.84L8 12.27L3.42 14.84L4.55 9.54L0.5 5.85L5.88 5.26L8 0.5Z" fill="var(--theme-primary)"/>
              </svg>
            </span>
            <span class="home-hero__review-text">{{ section.settings.review_text }}</span>
          </div>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h1 class="home-hero__heading">{{ section.settings.heading }}</h1>
        {%- endif -%}

        {%- if section.settings.body_text != blank -%}
          <p class="home-hero__body">{{ section.settings.body_text }}</p>
        {%- endif -%}

        {%- if section.settings.button_text != blank -%}
          <a
            class="home-hero__cta"
            {% if section.settings.button_url != blank %}
              href="{{ section.settings.button_url }}"
            {% endif %}
          >
            <span class="home-hero__cta-icon">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M8 2L14 8L8 14" stroke="var(--theme-text-on-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M14 8H2" stroke="var(--theme-text-on-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
            <span class="home-hero__cta-text">{{ section.settings.button_text }}</span>
          </a>
        {%- endif -%}
      </div>

      <div class="home-hero__bundle">
        <div class="home-hero__bundle-card">
          <div class="home-hero__bundle-image">
            {%- if section.settings.bundle_image != blank -%}
              {{ section.settings.bundle_image | image_url: width: 310, height: 272 | image_tag: loading: 'lazy' }}
            {%- else -%}
              <div class="home-hero__bundle-image-placeholder">
                {{ 'product-2' | placeholder_svg_tag }}
              </div>
            {%- endif -%}
          </div>

          <div class="home-hero__bundle-info">
            <div class="home-hero__bundle-header">
              {%- if section.settings.bundle_label != blank -%}
                <span class="home-hero__bundle-label">{{ section.settings.bundle_label }}</span>
              {%- endif -%}
              {%- if section.settings.bundle_badge != blank -%}
                <span class="home-hero__bundle-badge">{{ section.settings.bundle_badge }}</span>
              {%- endif -%}
            </div>

            {%- if section.settings.bundle_description != blank -%}
              <p class="home-hero__bundle-description">{{ section.settings.bundle_description }}</p>
            {%- endif -%}

            <div class="home-hero__bundle-pricing">
              {%- if section.settings.bundle_price != blank -%}
                <span class="home-hero__bundle-price">{{ section.settings.bundle_price }}</span>
              {%- endif -%}
              {%- if section.settings.bundle_compare_price != blank -%}
                <span class="home-hero__bundle-compare-price">{{ section.settings.bundle_compare_price }}</span>
              {%- endif -%}
            </div>

            {%- if section.settings.bundle_button_text != blank -%}
              <a
                class="home-hero__bundle-button"
                {% if section.settings.bundle_button_url != blank %}
                  href="{{ section.settings.bundle_button_url }}"
                {% endif %}
              >
                {{ section.settings.bundle_button_text }}
              </a>
            {%- endif -%}
          </div>
        </div>
      </div>
    </div>

    <div class="home-hero__right">
      {%- if section.settings.image != blank -%}
        <div class="home-hero__image">
          {{ section.settings.image | image_url: width: 1224 | image_tag: loading: 'eager' }}
        </div>
      {%- else -%}
        <div class="home-hero__image home-hero__image--placeholder">
          {{ 'product-1' | placeholder_svg_tag }}
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

{% stylesheet %}
  .home-hero {
    background-color: var(--theme-surface);
    padding: 52px;
  }

  .home-hero__container {
    display: flex;
    flex-direction: row;
    gap: 40px;
    max-width: 1440px;
    margin: 0 auto;
    align-items: stretch;
  }

  .home-hero__left {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 32px;
  }

  .home-hero__top-content {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  /* Review badge */
  .home-hero__review-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background-color: var(--theme-accent);
    color: var(--theme-primary);
    border-radius: var(--theme-radius-badge);
    padding: 6px 16px;
    width: fit-content;
  }

  .home-hero__star-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .home-hero__review-text {
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 1.44px;
    line-height: 1;
  }

  /* Heading */
  .home-hero__heading {
    font-size: 52px;
    line-height: 64px;
    color: var(--theme-primary);
    letter-spacing: -2.08px;
    font-weight: 700;
    margin: 0;
  }

  /* Body text */
  .home-hero__body {
    font-size: 16px;
    line-height: 24px;
    color: var(--theme-text-secondary);
    max-width: 423px;
    margin: 0;
  }

  /* CTA Button */
  .home-hero__cta {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background-color: var(--theme-primary);
    color: var(--theme-text-on-primary);
    border-radius: var(--theme-radius-button);
    padding: 8px 24px 8px 8px;
    text-decoration: none;
    width: fit-content;
    transition: opacity var(--duration-fast, 150ms) var(--ease-standard, ease);
  }

  .home-hero__cta:hover {
    opacity: 0.85;
  }

  .home-hero__cta-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background-color: var(--theme-primary-light);
    border-radius: 50%;
    flex-shrink: 0;
  }

  .home-hero__cta-text {
    font-size: 16px;
    font-weight: 500;
    line-height: 1;
  }

  /* Bundle upsell card */
  .home-hero__bundle-card {
    display: flex;
    flex-direction: row;
    gap: 16px;
    background-color: var(--theme-surface-alt);
    border-radius: var(--theme-radius-card);
    padding: 8px 16px 8px 8px;
    align-items: center;
  }

  .home-hero__bundle-image {
    flex-shrink: 0;
    width: 155px;
    height: 136px;
    border-radius: var(--theme-radius-image);
    overflow: hidden;
  }

  .home-hero__bundle-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .home-hero__bundle-image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--theme-surface-alt);
    border-radius: var(--theme-radius-image);
  }

  .home-hero__bundle-image-placeholder svg {
    width: 60%;
    height: auto;
    opacity: 0.4;
  }

  .home-hero__bundle-info {
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1;
    min-width: 0;
  }

  .home-hero__bundle-header {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .home-hero__bundle-label {
    font-size: 14px;
    font-weight: 600;
    color: var(--theme-primary);
  }

  .home-hero__bundle-badge {
    display: inline-flex;
    align-items: center;
    background-color: var(--theme-accent);
    color: var(--theme-primary);
    border-radius: var(--theme-radius-badge);
    padding: 2px 10px;
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    line-height: 1.4;
  }

  .home-hero__bundle-description {
    font-size: 14px;
    line-height: 20px;
    color: var(--theme-text-secondary);
    margin: 0;
  }

  .home-hero__bundle-pricing {
    display: flex;
    align-items: baseline;
    gap: 8px;
  }

  .home-hero__bundle-price {
    font-size: 16px;
    font-weight: 600;
    color: var(--theme-primary);
  }

  .home-hero__bundle-compare-price {
    font-size: 12px;
    color: color-mix(in srgb, var(--theme-primary) 40%, transparent);
    text-decoration: line-through;
  }

  .home-hero__bundle-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: var(--theme-surface-muted);
    color: var(--theme-primary);
    border-radius: var(--theme-radius-button);
    height: 40px;
    padding: 0 20px;
    font-size: 16px;
    font-weight: 500;
    text-decoration: none;
    width: fit-content;
    transition: opacity var(--duration-fast, 150ms) var(--ease-standard, ease);
  }

  .home-hero__bundle-button:hover {
    opacity: 0.85;
  }

  /* Right column - hero image */
  .home-hero__right {
    flex: 1;
  }

  .home-hero__image {
    height: 612px;
    border-radius: var(--theme-radius-card);
    overflow: hidden;
  }

  .home-hero__image img,
  .home-hero__image svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .home-hero__image--placeholder {
    background-color: var(--theme-surface-alt);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .home-hero__image--placeholder svg {
    width: 50%;
    height: auto;
    opacity: 0.4;
  }

  /* Mobile styles */
  @media screen and (max-width: 749px) {
    .home-hero {
      padding: 24px 20px;
    }

    .home-hero__container {
      flex-direction: column;
      gap: 24px;
    }

    .home-hero__heading {
      font-size: 32px;
      line-height: 40px;
      letter-spacing: -1.28px;
    }

    .home-hero__body {
      max-width: 100%;
    }

    .home-hero__image {
      height: 400px;
    }

    .home-hero__bundle {
      display: none;
    }
  }

  /* Tablet adjustments */
  @media screen and (min-width: 750px) and (max-width: 989px) {
    .home-hero {
      padding: 32px;
    }

    .home-hero__heading {
      font-size: 40px;
      line-height: 50px;
    }

    .home-hero__image {
      height: 480px;
    }

    .home-hero__bundle-card {
      flex-direction: column;
      align-items: flex-start;
    }

    .home-hero__bundle-image {
      width: 100%;
      height: 120px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.home_hero.name",
  "settings": [
    {
      "type": "text",
      "id": "review_text",
      "label": "t:labels.review_text",
      "default": "10,078+ FIVE-STAR REVIEWS"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "A health gut can change your life."
    },
    {
      "type": "textarea",
      "id": "body_text",
      "label": "t:labels.body_text",
      "default": "Our capsule-in-capsule technology delivers the right probiotic strains to the right places to ease bloating, gas, and irregularity."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "t:labels.button_text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "t:labels.button_url"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:labels.image"
    },
    {
      "type": "header",
      "content": "t:labels.bundle"
    },
    {
      "type": "image_picker",
      "id": "bundle_image",
      "label": "t:labels.image"
    },
    {
      "type": "text",
      "id": "bundle_label",
      "label": "t:labels.title",
      "default": "Bundle"
    },
    {
      "type": "text",
      "id": "bundle_badge",
      "label": "t:labels.tag",
      "default": "Save 50%+"
    },
    {
      "type": "textarea",
      "id": "bundle_description",
      "label": "t:labels.description",
      "default": "Add DM-02™ Daily Multivitamin to your routine and save on your first order."
    },
    {
      "type": "text",
      "id": "bundle_price",
      "label": "t:labels.price",
      "default": "$109.00"
    },
    {
      "type": "text",
      "id": "bundle_compare_price",
      "label": "t:labels.compare_price",
      "default": "$199.99"
    },
    {
      "type": "text",
      "id": "bundle_button_text",
      "label": "t:labels.button_text",
      "default": "Add to Cart"
    },
    {
      "type": "url",
      "id": "bundle_button_url",
      "label": "t:labels.button_url"
    }
  ],
  "presets": [
    {
      "name": "t:sections.home_hero.name"
    }
  ]
}
{% endschema %}

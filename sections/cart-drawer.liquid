{%- comment -%}
  Cart Drawer — slide-out panel with line items, upsell products, promo code, and checkout.
  Rendered from header-group.json so it appears on every page.
{%- endcomment -%}

<div class="cart-drawer" data-cart-drawer>
  {%- comment -%} Overlay {%- endcomment -%}
  <div class="cart-drawer__overlay" data-cart-drawer-overlay tabindex="-1"></div>

  {%- comment -%} Drawer panel {%- endcomment -%}
  <div class="cart-drawer__panel" data-cart-drawer-panel role="dialog" aria-label="{{ 'cart.title' | t }}" aria-modal="true">

    {%- comment -%} Scrollable body {%- endcomment -%}
    <div class="cart-drawer__body" data-cart-drawer-body>

      {%- comment -%} Header {%- endcomment -%}
      <div class="cart-drawer__header">
        <h2 class="cart-drawer__title">{{ 'cart.title' | t }}</h2>
        <button class="cart-drawer__close" data-cart-drawer-close aria-label="{{ 'header.close_menu' | t }}">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M6 6L18 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>

      {%- comment -%} Top announcement banner {%- endcomment -%}
      {% if section.settings.show_free_shipping_bar %}
        {%- assign fs_threshold = section.settings.free_shipping_threshold | times: 100 -%}
        {%- assign fs_cart_total = cart.total_price -%}
        <div class="cart-drawer__announcement" data-cart-drawer-announcement>
          <p class="cart-drawer__announcement-text" data-cart-drawer-announcement-text>
            {%- if fs_cart_total >= fs_threshold -%}
              {{ 'cart.free_shipping_success' | t }}
            {%- else -%}
              {%- assign fs_remaining = fs_threshold | minus: fs_cart_total -%}
              {{ 'cart.free_shipping_remaining' | t: amount: fs_remaining | money }}
            {%- endif -%}
          </p>
        </div>
      {% endif %}

      {%- comment -%} Free shipping progress bar {%- endcomment -%}
      {% if section.settings.show_free_shipping_bar %}
        {%- assign free_shipping_threshold = section.settings.free_shipping_threshold | times: 100 -%}
        {%- assign cart_total = cart.total_price -%}
        {%- if cart_total >= free_shipping_threshold -%}
          {%- assign shipping_progress = 100 -%}
        {%- else -%}
          {%- assign shipping_progress = cart_total | times: 100 | divided_by: free_shipping_threshold -%}
        {%- endif -%}
        <div class="cart-drawer__shipping-bar" data-cart-shipping-bar>
          <p class="cart-drawer__shipping-text" data-cart-shipping-text>
            {%- if cart_total >= free_shipping_threshold -%}
              {{ 'cart.free_shipping_success' | t }}
            {%- else -%}
              {%- assign remaining = free_shipping_threshold | minus: cart_total -%}
              {{ 'cart.free_shipping_remaining' | t: amount: remaining | money }}
            {%- endif -%}
          </p>
          <div class="cart-drawer__progress-track">
            <div class="cart-drawer__progress-fill" style="--progress: {{ shipping_progress }}%" data-cart-shipping-fill></div>
            <div class="cart-drawer__progress-icon" style="--progress: {{ shipping_progress }}%" data-cart-shipping-icon>
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <rect width="24" height="24" rx="12" fill="var(--theme-accent)"/>
                <rect x="2" y="2" width="20" height="20" rx="10" stroke="var(--theme-primary)" stroke-width="2"/>
                <path d="M8 9H16V15H8V9Z" stroke="var(--theme-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M10 15V16.5" stroke="var(--theme-primary)" stroke-width="1.5" stroke-linecap="round"/>
                <path d="M14 15V16.5" stroke="var(--theme-primary)" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </div>
          </div>
        </div>
      {% endif %}

      {%- comment -%} Cart items {%- endcomment -%}
      <div class="cart-drawer__items" data-cart-items>
        {% if cart.item_count > 0 %}
          {% for item in cart.items %}
            <div class="cart-drawer__item" data-cart-item data-line-key="{{ item.key }}">
              <a href="{{ item.url }}" class="cart-drawer__item-image">
                {% if item.image %}
                  {{ item.image | image_url: width: 310 | image_tag: class: 'cart-drawer__item-img', loading: 'lazy' }}
                {% else %}
                  {{ 'product-1' | placeholder_svg_tag: 'cart-drawer__item-placeholder' }}
                {% endif %}
              </a>
              <div class="cart-drawer__item-details">
                <div class="cart-drawer__item-left">
                  <div class="cart-drawer__item-info">
                    <a href="{{ item.url }}" class="cart-drawer__item-title">{{ item.product.title }}</a>
                    {% if item.variant.title != 'Default Title' %}
                      <p class="cart-drawer__item-variant">{{ item.variant.title }}</p>
                    {% endif %}
                  </div>
                  <div class="cart-drawer__quantity" data-quantity-selector>
                    <button
                      class="cart-drawer__quantity-btn"
                      data-quantity-minus
                      aria-label="{{ 'cart.decrease_quantity' | t }}"
                    >
                      {{ 'icon-minus.svg' | inline_asset_content }}
                    </button>
                    <span class="cart-drawer__quantity-value" data-quantity-value>{{ item.quantity }}</span>
                    <button
                      class="cart-drawer__quantity-btn"
                      data-quantity-plus
                      aria-label="{{ 'cart.increase_quantity' | t }}"
                    >
                      {{ 'icon-plus.svg' | inline_asset_content }}
                    </button>
                  </div>
                </div>
                <div class="cart-drawer__item-right">
                  <button
                    class="cart-drawer__remove-btn"
                    data-remove-item
                    aria-label="{{ 'cart.remove' | t }}: {{ item.product.title }}"
                  >
                    {{ 'icon-trash.svg' | inline_asset_content }}
                  </button>
                  <div class="cart-drawer__item-prices">
                    {%- assign compare_line = item.variant.compare_at_price | default: 0 | times: item.quantity -%}
                    {%- assign has_compare = false -%}
                    {%- if compare_line > item.final_line_price -%}
                      {%- assign has_compare = true -%}
                      {%- assign display_compare = compare_line -%}
                    {%- elsif item.original_line_price > item.final_line_price -%}
                      {%- assign has_compare = true -%}
                      {%- assign display_compare = item.original_line_price -%}
                    {%- endif -%}
                    <div class="cart-drawer__item-price-row">
                      {% if has_compare %}
                        <span class="cart-drawer__item-compare-price">{{ display_compare | money }}</span>
                      {% endif %}
                      <span class="cart-drawer__item-price">{{ item.final_line_price | money }}</span>
                    </div>
                    {% if has_compare %}
                      {%- assign item_savings = display_compare | minus: item.final_line_price | money -%}
                      <span class="cart-drawer__item-savings">({{ 'cart.save_label' | t: amount: item_savings }})</span>
                    {% endif %}
                    {% for discount in item.discount_allocations %}
                      <span class="cart-drawer__item-discount-badge">
                        {{ 'icon-discount-tag.svg' | inline_asset_content }}
                        <span>{{ discount.discount_application.title }}</span>
                      </span>
                    {% endfor %}
                  </div>
                </div>
              </div>
            </div>
          {% endfor %}
        {% else %}
          {%- comment -%} Fallback placeholder items for visualization {%- endcomment -%}
          {% for i in (1..2) %}
            <div class="cart-drawer__item">
              <div class="cart-drawer__item-image">
                {{ 'product-' | append: i | placeholder_svg_tag: 'cart-drawer__item-placeholder' }}
              </div>
              <div class="cart-drawer__item-details">
                <div class="cart-drawer__item-left">
                  <div class="cart-drawer__item-info">
                    <span class="cart-drawer__item-title">{{ 'cart.fallback_product_title' | t }}</span>
                    <p class="cart-drawer__item-variant">{{ 'cart.fallback_variant' | t }}</p>
                  </div>
                  <div class="cart-drawer__quantity">
                    <button class="cart-drawer__quantity-btn" disabled>
                      {{ 'icon-minus.svg' | inline_asset_content }}
                    </button>
                    <span class="cart-drawer__quantity-value">1</span>
                    <button class="cart-drawer__quantity-btn" disabled>
                      {{ 'icon-plus.svg' | inline_asset_content }}
                    </button>
                  </div>
                </div>
                <div class="cart-drawer__item-right">
                  <button class="cart-drawer__remove-btn" disabled>
                    {{ 'icon-trash.svg' | inline_asset_content }}
                  </button>
                  <div class="cart-drawer__item-prices">
                    <div class="cart-drawer__item-price-row">
                      <span class="cart-drawer__item-compare-price">$59.99</span>
                      <span class="cart-drawer__item-price">$39.99</span>
                    </div>
                    <span class="cart-drawer__item-savings">({{ 'cart.save_label' | t: amount: '$20.00' }})</span>
                    <span class="cart-drawer__item-discount-badge">
                      {{ 'icon-discount-tag.svg' | inline_asset_content }}
                      <span>SAVE20</span>
                    </span>
                  </div>
                </div>
              </div>
            </div>
          {% endfor %}
        {% endif %}
      </div>

      {%- comment -%} Upsell products (Swiper slider) {%- endcomment -%}
      {% render 'swiper-loader' %}
      {% if section.settings.upsell_collection != blank %}
        {%- assign upsell_products = section.settings.upsell_collection.products -%}
      {% endif %}

      {% if upsell_products != blank and upsell_products.size > 0 %}
        <div class="cart-drawer__upsell" data-cart-upsell>
          <div class="cart-drawer__upsell-top">
            <h3 class="cart-drawer__upsell-heading">{{ section.settings.upsell_heading }}</h3>
            <div class="cart-drawer__upsell-nav">
              <button class="cart-drawer__upsell-nav-btn" data-upsell-prev aria-label="{{ 'cart.decrease_quantity' | t }}">
                <svg width="7" height="12" viewBox="0 0 7 12" fill="none" aria-hidden="true"><path d="M6 1L1 6L6 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </button>
              <button class="cart-drawer__upsell-nav-btn" data-upsell-next aria-label="{{ 'cart.increase_quantity' | t }}">
                <svg width="7" height="12" viewBox="0 0 7 12" fill="none" aria-hidden="true"><path d="M1 1L6 6L1 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </button>
            </div>
          </div>
          <div class="swiper cart-drawer__upsell-swiper" data-cart-upsell-swiper>
            <div class="swiper-wrapper">
              {% for product in upsell_products limit: 8 %}
                <div class="swiper-slide">
                  <article class="cart-drawer__upsell-card" data-upsell-card>
                    <div class="cart-drawer__upsell-image">
                      {% if product.featured_image %}
                        {{ product.featured_image | image_url: width: 200, height: 200 | image_tag: class: 'cart-drawer__upsell-img', loading: 'lazy' }}
                      {% else %}
                        <div class="cart-drawer__upsell-placeholder">
                          {{ 'product-1' | placeholder_svg_tag }}
                        </div>
                      {% endif %}
                    </div>
                    <div class="cart-drawer__upsell-info">
                      <h4 class="cart-drawer__upsell-title">
                        <a href="{{ product.url }}">{{ product.title }}</a>
                      </h4>
                      <div class="cart-drawer__upsell-prices">
                        <span class="cart-drawer__upsell-price">{{ product.price | money }}</span>
                        {% if product.compare_at_price > product.price %}
                          <span class="cart-drawer__upsell-compare">{{ product.compare_at_price | money }}</span>
                        {% endif %}
                      </div>
                    </div>
                    <button
                      class="cart-drawer__upsell-atc"
                      data-upsell-atc
                      data-variant-id="{{ product.selected_or_first_available_variant.id }}"
                      {% unless product.available %}disabled{% endunless %}
                      aria-label="{{ 'products.add_to_cart' | t }}"
                    >
                      {% if product.available %}
                        {{ 'products.add_to_cart' | t }}
                      {% else %}
                        {{ 'products.sold_out' | t }}
                      {% endif %}
                    </button>
                  </article>
                </div>
              {% endfor %}
            </div>
          </div>
        </div>
      {% else %}
        {%- comment -%} Fallback placeholder upsell cards for visualization {%- endcomment -%}
        <div class="cart-drawer__upsell" data-cart-upsell>
          <div class="cart-drawer__upsell-top">
            <h3 class="cart-drawer__upsell-heading">{{ section.settings.upsell_heading | default: 'You may also like' }}</h3>
            <div class="cart-drawer__upsell-nav">
              <button class="cart-drawer__upsell-nav-btn" data-upsell-prev aria-label="{{ 'cart.decrease_quantity' | t }}">
                <svg width="7" height="12" viewBox="0 0 7 12" fill="none" aria-hidden="true"><path d="M6 1L1 6L6 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </button>
              <button class="cart-drawer__upsell-nav-btn" data-upsell-next aria-label="{{ 'cart.increase_quantity' | t }}">
                <svg width="7" height="12" viewBox="0 0 7 12" fill="none" aria-hidden="true"><path d="M1 1L6 6L1 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </button>
            </div>
          </div>
          <div class="swiper cart-drawer__upsell-swiper" data-cart-upsell-swiper>
            <div class="swiper-wrapper">
              {% for i in (1..3) %}
                <div class="swiper-slide">
                  <article class="cart-drawer__upsell-card">
                    <div class="cart-drawer__upsell-image">
                      <div class="cart-drawer__upsell-placeholder">
                        {{ 'product-' | append: i | placeholder_svg_tag }}
                      </div>
                    </div>
                    <div class="cart-drawer__upsell-info">
                      <h4 class="cart-drawer__upsell-title">{{ 'cart.fallback_product_title' | t }}</h4>
                      <div class="cart-drawer__upsell-prices">
                        <span class="cart-drawer__upsell-price">$29.99</span>
                        <span class="cart-drawer__upsell-compare">$39.99</span>
                      </div>
                    </div>
                    <button class="cart-drawer__upsell-atc" disabled>
                      {{ 'products.add_to_cart' | t }}
                    </button>
                  </article>
                </div>
              {% endfor %}
            </div>
          </div>
        </div>
      {% endif %}
    </div>

    {%- comment -%} Sticky footer {%- endcomment -%}
      <div class="cart-drawer__footer" data-cart-footer>
        <div class="cart-drawer__footer-inner">
          {%- comment -%} Promo code input {%- endcomment -%}
          <div class="cart-drawer__promo" data-cart-promo>
            <input
              type="text"
              class="cart-drawer__promo-input"
              placeholder="{{ 'cart.promo_code' | t }}"
              data-promo-input
              aria-label="{{ 'cart.promo_code' | t }}"
            >
            <button class="cart-drawer__promo-apply" data-promo-apply>
              {{ 'cart.apply' | t }}
            </button>
          </div>

          {%- comment -%} Checkout+ protection {%- endcomment -%}
          {% if section.settings.show_checkout_protection %}
            <div class="cart-drawer__protection" data-cart-protection>
              <div class="cart-drawer__protection-icon">
                {{ 'icon-box.svg' | inline_asset_content }}
              </div>
              <div class="cart-drawer__protection-info">
                <div class="cart-drawer__protection-title-row">
                  <span class="cart-drawer__protection-title">{{ section.settings.checkout_protection_title }}</span>
                  {{ 'icon-warning.svg' | inline_asset_content }}
                </div>
                <p class="cart-drawer__protection-desc">{{ section.settings.checkout_protection_description }}</p>
              </div>
              <label class="cart-drawer__protection-toggle">
                <input
                  type="checkbox"
                  data-protection-checkbox
                  {% unless cart.attributes.checkout_protection == '' %}checked{% endunless %}
                  aria-label="{{ section.settings.checkout_protection_title }}"
                >
                <span class="cart-drawer__protection-checkbox">
                  {{ 'icon-checkbox.svg' | inline_asset_content }}
                </span>
              </label>
            </div>
          {% endif %}

          {%- comment -%} Subtotal row {%- endcomment -%}
          <div class="cart-drawer__subtotal">
            <span class="cart-drawer__subtotal-label">{{ 'cart.subtotal' | t }}</span>
            <div class="cart-drawer__subtotal-right">
              {% if cart.item_count > 0 %}
                {% if cart.original_total_price > cart.total_price %}
                  {%- assign total_savings = cart.original_total_price | minus: cart.total_price -%}
                  {%- assign savings_pct = total_savings | times: 100 | divided_by: cart.original_total_price -%}
                  <span class="cart-drawer__savings-badge">
                    {{ 'cart.save_percent' | t: percent: savings_pct }}
                  </span>
                {% endif %}
                <span class="cart-drawer__subtotal-price" data-cart-subtotal>{{ cart.total_price | money }}</span>
              {% else %}
                <span class="cart-drawer__savings-badge">
                  {{ 'cart.save_percent' | t: percent: 33 }}
                </span>
                <span class="cart-drawer__subtotal-price" data-cart-subtotal>$79.98</span>
              {% endif %}
            </div>
          </div>

          {%- comment -%} Checkout button {%- endcomment -%}
          <a href="{{ routes.cart_url }}/checkout" class="cart-drawer__checkout-btn">
            {{ 'cart.checkout' | t }}
          </a>

          {%- comment -%} Trust badges {%- endcomment -%}
          <div class="cart-drawer__trust-row">
            <div class="cart-drawer__trust-badge">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <rect x="1" y="1" width="14" height="14" rx="3" stroke="var(--theme-primary)" stroke-width="1.2"/>
                <text x="8" y="11" text-anchor="middle" font-size="7" font-weight="600" fill="var(--theme-primary)">30</text>
              </svg>
              <span>{{ 'cart.money_back_guarantee' | t }}</span>
            </div>
            <div class="cart-drawer__trust-badge">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M8 1L10 5.5L15 6.2L11.5 9.5L12.3 14.5L8 12.2L3.7 14.5L4.5 9.5L1 6.2L6 5.5L8 1Z" fill="var(--theme-star)"/>
              </svg>
              <span>{{ 'cart.happy_customers' | t }}</span>
            </div>
          </div>
        </div>
      </div>
  </div>
</div>

{% stylesheet %}
  /* ===== Cart Drawer ===== */
  .cart-drawer__overlay {
    display: none;
    position: fixed;
    inset: 0;
    background-color: var(--color-overlay);
    z-index: var(--z-modal, 300);
    opacity: 0;
    transition: opacity var(--duration-medium, 300ms) var(--ease-standard, ease);
  }

  .cart-drawer__overlay.is-open {
    display: block;
    opacity: 1;
  }

  .cart-drawer__panel {
    position: fixed;
    inset-block: 0;
    inset-inline-end: 0;
    width: 608px;
    max-width: 100vw;
    background-color: var(--theme-surface);
    z-index: var(--z-modal, 300);
    transform: translateX(100%);
    transition: transform var(--duration-medium, 300ms) var(--ease-emphasized, cubic-bezier(0.2, 0, 0, 1));
    display: flex;
    flex-direction: column;
  }

  .cart-drawer__panel.is-open {
    transform: translateX(0);
  }

  /* --- Body (scrollable) --- */
  .cart-drawer__body {
    flex: 1;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  /* --- Top announcement banner --- */
  .cart-drawer__announcement {
    background-color: var(--theme-primary);
    margin-inline: -24px;
    padding: 12px 24px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .cart-drawer__announcement-text {
    font-size: var(--font-size-xl);
    line-height: var(--line-height-snug);
    color: var(--theme-text-on-primary);
    margin: 0;
    text-align: center;
  }

  /* --- Header --- */
  .cart-drawer__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .cart-drawer__title {
    font-size: var(--font-size-2xl);
    line-height: var(--line-height-snug);
    letter-spacing: var(--letter-spacing-tighter);
    color: var(--theme-text);
    margin: 0;
    font-weight: var(--font-weight-regular);
  }

  .cart-drawer__close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    padding: 0;
    background: none;
    border: none;
    color: var(--theme-text);
    cursor: pointer;
    border-radius: var(--radius-round, 50%);
    transition: background-color var(--duration-fast, 150ms) var(--ease-standard, ease);
  }

  .cart-drawer__close:hover {
    background-color: var(--color-hover-subtle);
  }

  .cart-drawer__close:focus-visible {
    outline: 2px solid var(--color-focus, var(--theme-primary));
    outline-offset: 2px;
  }

  /* --- Free shipping bar --- */
  .cart-drawer__shipping-bar {
    background-color: var(--theme-surface-alt);
    border-radius: var(--radius-xl);
    padding: 16px 16px 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
  }

  .cart-drawer__shipping-text {
    font-size: var(--font-size-xl);
    line-height: var(--line-height-snug);
    color: var(--theme-text);
    margin: 0;
    text-align: center;
  }

  .cart-drawer__progress-track {
    position: relative;
    width: 100%;
    height: 12px;
    background-color: var(--theme-primary);
    border-radius: var(--theme-radius-badge);
    overflow: visible;
  }

  .cart-drawer__progress-fill {
    position: absolute;
    inset-block-start: 0;
    inset-inline-start: 0;
    height: 100%;
    width: var(--progress, 0%);
    max-width: 100%;
    background-color: var(--theme-primary);
    border-radius: var(--theme-radius-badge);
    transition: width var(--duration-medium, 300ms) var(--ease-standard, ease);
  }

  .cart-drawer__progress-icon {
    position: absolute;
    inset-block-start: 50%;
    inset-inline-start: var(--progress, 0%);
    transform: translate(-50%, -50%);
    transition: inset-inline-start var(--duration-medium, 300ms) var(--ease-standard, ease);
  }

  /* --- Cart items --- */
  .cart-drawer__items {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .cart-drawer__item {
    display: flex;
    gap: 16px;
    padding: 8px 16px 8px 8px;
    border-radius: var(--radius-3xl);
  }

  .cart-drawer__item-image {
    width: 155px;
    height: 136px;
    flex-shrink: 0;
    border-radius: var(--radius-xl);
    overflow: hidden;
    background-color: var(--theme-surface-alt);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .cart-drawer__item-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .cart-drawer__item-placeholder {
    width: 60%;
    height: auto;
    opacity: 0.4;
  }

  .cart-drawer__item-details {
    flex: 1;
    min-width: 0;
    display: flex;
    gap: 12px;
  }


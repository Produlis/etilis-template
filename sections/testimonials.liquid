<section class="testimonials full-width" aria-label="{{ 'testimonials.section_label' | t }}">
  <div class="testimonials__container">
    <div class="testimonials__header" data-animate="fade-up">
      <div class="testimonials__header-left">
        <span class="testimonials__tag">{{ section.settings.tag_text }}</span>
        <h2 class="testimonials__heading">{{ section.settings.heading }}</h2>
      </div>

      {%- assign review_rating = product.metafields.reviews.rating -%}
      {%- assign review_count = product.metafields.reviews.rating_count -%}
      {%- if review_rating.value and review_count.value and review_count.value > 0 -%}
      <div class="testimonials__header-right">
        <span class="testimonials__rating-number">{{ review_rating.value.rating }}</span>
        <div class="testimonials__rating-info">
          <div class="testimonials__stars" aria-label="{{ 'testimonials.star_rating' | t: rating: review_rating.value.rating }}">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M10 1.667l2.575 5.218 5.758.838-4.166 4.06.983 5.73L10 14.808l-5.15 2.705.983-5.73-4.166-4.06 5.758-.838L10 1.667z" fill="var(--theme-star)"/>
            </svg>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M10 1.667l2.575 5.218 5.758.838-4.166 4.06.983 5.73L10 14.808l-5.15 2.705.983-5.73-4.166-4.06 5.758-.838L10 1.667z" fill="var(--theme-star)"/>
            </svg>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M10 1.667l2.575 5.218 5.758.838-4.166 4.06.983 5.73L10 14.808l-5.15 2.705.983-5.73-4.166-4.06 5.758-.838L10 1.667z" fill="var(--theme-star)"/>
            </svg>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M10 1.667l2.575 5.218 5.758.838-4.166 4.06.983 5.73L10 14.808l-5.15 2.705.983-5.73-4.166-4.06 5.758-.838L10 1.667z" fill="var(--theme-star)"/>
            </svg>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M10 1.667l2.575 5.218 5.758.838-4.166 4.06.983 5.73L10 14.808l-5.15 2.705.983-5.73-4.166-4.06 5.758-.838L10 1.667z" fill="var(--theme-star)"/>
            </svg>
          </div>
          <span class="testimonials__review-count">{{ review_count.value }} {{ 'products.hero.five_star_reviews' | t }}</span>
        </div>
      </div>
      {%- endif -%}
    </div>
  </div>

  {%- assign meta_testimonials = product.metafields.custom.testimonials.value -%}
  <div class="testimonials__cards" role="list" data-animate="fade-up">
    {%- if meta_testimonials and meta_testimonials.size > 0 -%}
      {%- for testimonial in meta_testimonials -%}
        <article class="testimonials__card" role="listitem">
          <div class="testimonials__card-avatar">
            {%- if testimonial.image -%}
              <img src="{{ testimonial.image }}" loading="lazy" alt="{{ testimonial.author_name | escape }}">
            {%- else -%}
              {% render 'placeholder-image' %}
            {%- endif -%}
          </div>

          <div class="testimonials__card-content">
            <blockquote class="testimonials__card-quote">
              {{ testimonial.quote }}
            </blockquote>
            <div class="testimonials__card-author">
              <span class="testimonials__card-name">{{ testimonial.author_name }}</span>
              {%- if testimonial.author_role != blank -%}
                <span class="testimonials__card-role">{{ testimonial.author_role }}</span>
              {%- endif -%}
            </div>
          </div>
        </article>
      {%- endfor -%}
    {%- else -%}
      {% for block in section.blocks %}
        <article
          class="testimonials__card"
          role="listitem"
          {{ block.shopify_attributes }}
        >
          <div class="testimonials__card-avatar">
            {% if block.settings.author_image %}
              {{ block.settings.author_image | image_url: width: 200, height: 192, crop: 'center' | image_tag: loading: 'lazy' }}
            {% else %}
              {% render 'placeholder-image' %}
            {% endif %}
          </div>

          <div class="testimonials__card-content">
            <blockquote class="testimonials__card-quote">
              {{ block.settings.quote }}
            </blockquote>
            <div class="testimonials__card-author">
              <span class="testimonials__card-name">{{ block.settings.author_name }}</span>
              {% if block.settings.author_role != blank %}
                <span class="testimonials__card-role">{{ block.settings.author_role }}</span>
              {% endif %}
            </div>
          </div>
        </article>
      {% endfor %}
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .testimonials {
    background-color: var(--theme-surface);
    padding: var(--space-13) 0;
    overflow: hidden;
  }

  .testimonials__container {
    max-width: var(--container-max, 80rem);
    margin: 0 auto;
    padding: 0 var(--space-13);
    width: 100%;
    box-sizing: border-box;
  }

  .testimonials__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    flex-wrap: wrap;
    gap: var(--space-6);
  }

  .testimonials__header-left {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    max-width: 696px;
  }

  .testimonials__tag {
    display: inline-flex;
    align-self: flex-start;
    background-color: var(--theme-surface-alt);
    color: var(--theme-primary);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-medium);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wider);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--theme-radius-badge);
    line-height: normal;
  }

  .testimonials__heading {
    font-size: var(--font-size-5xl);
    line-height: normal;
    color: var(--theme-primary);
    letter-spacing: var(--letter-spacing-tighter);
    margin: 0;
    font-weight: var(--font-weight-regular);
  }

  .testimonials__header-right {
    display: flex;
    gap: var(--space-4);
    align-items: center;
  }

  .testimonials__rating-number {
    font-size: var(--font-size-5xl);
    line-height: normal;
    color: var(--theme-primary);
    letter-spacing: var(--letter-spacing-tighter);
    font-weight: var(--font-weight-regular);
  }

  .testimonials__rating-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .testimonials__stars {
    display: flex;
    gap: var(--space-2);
  }

  .testimonials__stars svg {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    fill: var(--theme-star);
  }

  .testimonials__review-count {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    color: var(--theme-text);
    letter-spacing: var(--letter-spacing-wider);
    text-transform: uppercase;
    line-height: normal;
  }

  .testimonials__cards {
    display: flex;
    gap: var(--space-6);
    margin-top: var(--space-13);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding: 0 var(--space-13) var(--space-2);
  }

  .testimonials__cards::-webkit-scrollbar {
    display: none;
  }

  .testimonials__card {
    display: flex;
    align-items: flex-start;
    background-color: var(--theme-surface-alt);
    border-radius: var(--radius-3xl);
    padding: var(--space-2) var(--space-4) var(--space-2) var(--space-2);
    min-width: 576px;
    max-width: 576px;
    scroll-snap-align: start;
    flex-shrink: 0;
  }

  .testimonials__card-avatar {
    width: 100px;
    min-height: 96px;
    flex-shrink: 0;
    border-radius: var(--theme-radius-image);
    overflow: hidden;
  }

  .testimonials__card-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .testimonials__avatar-placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .testimonials__card-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    padding: var(--space-2);
    gap: var(--space-4);
    min-width: 0;
  }

  .testimonials__card-quote {
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-medium);
    color: var(--theme-primary);
    line-height: var(--line-height-snug);
    letter-spacing: var(--letter-spacing-tighter);
    margin: 0;
  }

  .testimonials__card-author {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .testimonials__card-name {
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-medium);
    color: var(--theme-primary);
    line-height: var(--line-height-normal);
  }

  .testimonials__card-role {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    color: var(--theme-text-secondary);
    line-height: var(--line-height-snug);
  }

  @media screen and (max-width: 749px) {
    .testimonials {
      padding: var(--space-6) 0;
    }

    .testimonials__container {
      padding: 0 var(--space-5);
    }

    .testimonials__header {
      flex-direction: column;
      align-items: flex-start;
    }

    .testimonials__header-right {
      align-items: flex-start;
    }

    .testimonials__heading {
      font-size: var(--font-size-3xl);
      line-height: var(--line-height-tight);
      letter-spacing: var(--letter-spacing-tighter);
    }

    .testimonials__rating-number {
      font-size: var(--font-size-3xl);
    }

    .testimonials__cards {
      padding: 0 var(--space-5) var(--space-2);
    }

    .testimonials__card {
      min-width: 300px;
      max-width: 300px;
    }

    .testimonials__card-avatar {
      width: 72px;
      min-height: 72px;
    }

    .testimonials__card-quote {
      font-size: var(--font-size-base);
      line-height: var(--line-height-snug);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.testimonials.name",
  "settings": [
    {
      "type": "text",
      "id": "tag_text",
      "label": "t:sections.testimonials.settings.tag_text",
      "default": "Testimonials"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.testimonials.settings.heading",
      "default": "What our customers say"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "t:sections.testimonials.blocks.testimonial.name",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "t:sections.testimonials.blocks.testimonial.settings.quote",
          "default": "This product changed my daily routine completely. Highly recommended!"
        },
        {
          "type": "text",
          "id": "author_name",
          "label": "t:sections.testimonials.blocks.testimonial.settings.author_name",
          "default": "Jane Doe"
        },
        {
          "type": "text",
          "id": "author_role",
          "label": "t:sections.testimonials.blocks.testimonial.settings.author_role",
          "default": "Verified Buyer"
        },
        {
          "type": "image_picker",
          "id": "author_image",
          "label": "t:sections.testimonials.blocks.testimonial.settings.author_image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.testimonials.name",
      "blocks": [
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}

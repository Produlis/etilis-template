<section class="testimonials full-width" aria-label="{{ 'testimonials.section_label' | t }}">
  <div class="testimonials__container">
    <div class="testimonials__header">
      <div class="testimonials__header-left">
        <span class="testimonials__tag">{{ section.settings.tag_text }}</span>
        <h2 class="testimonials__heading">{{ section.settings.heading }}</h2>
      </div>

      <div class="testimonials__header-right">
        <span class="testimonials__rating-number">{{ section.settings.rating }}</span>
        <div class="testimonials__rating-info">
          <div class="testimonials__stars" aria-label="{{ 'testimonials.star_rating' | t: rating: section.settings.rating }}">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M10 1.667l2.575 5.218 5.758.838-4.166 4.06.983 5.73L10 14.808l-5.15 2.705.983-5.73-4.166-4.06 5.758-.838L10 1.667z" fill="var(--theme-star)"/>
            </svg>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M10 1.667l2.575 5.218 5.758.838-4.166 4.06.983 5.73L10 14.808l-5.15 2.705.983-5.73-4.166-4.06 5.758-.838L10 1.667z" fill="var(--theme-star)"/>
            </svg>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M10 1.667l2.575 5.218 5.758.838-4.166 4.06.983 5.73L10 14.808l-5.15 2.705.983-5.73-4.166-4.06 5.758-.838L10 1.667z" fill="var(--theme-star)"/>
            </svg>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M10 1.667l2.575 5.218 5.758.838-4.166 4.06.983 5.73L10 14.808l-5.15 2.705.983-5.73-4.166-4.06 5.758-.838L10 1.667z" fill="var(--theme-star)"/>
            </svg>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M10 1.667l2.575 5.218 5.758.838-4.166 4.06.983 5.73L10 14.808l-5.15 2.705.983-5.73-4.166-4.06 5.758-.838L10 1.667z" fill="var(--theme-star)"/>
            </svg>
          </div>
          <span class="testimonials__review-count">{{ section.settings.review_count }} FIVE-STAR REVIEWS</span>
        </div>
      </div>
    </div>

    <div class="testimonials__cards" role="list">
      {% for block in section.blocks %}
        <article
          class="testimonials__card"
          role="listitem"
          {{ block.shopify_attributes }}
        >
          <div class="testimonials__card-avatar">
            {% if block.settings.author_image %}
              {{ block.settings.author_image | image_url: width: 200, height: 192, crop: 'center' | image_tag: loading: 'lazy' }}
            {% else %}
              {{ 'product-1' | placeholder_svg_tag: 'testimonials__avatar-placeholder' }}
            {% endif %}
          </div>

          <div class="testimonials__card-content">
            <blockquote class="testimonials__card-quote">
              {{ block.settings.quote }}
            </blockquote>
            <div class="testimonials__card-author">
              <span class="testimonials__card-name">{{ block.settings.author_name }}</span>
              {% if block.settings.author_role != blank %}
                <span class="testimonials__card-role">{{ block.settings.author_role }}</span>
              {% endif %}
            </div>
          </div>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% stylesheet %}
  .testimonials {
    background-color: var(--theme-surface);
    padding: 52px 0;
  }

  .testimonials__container {
    max-width: var(--container-max, 1200px);
    margin: 0 auto;
    padding: 0 52px;
    width: 100%;
    box-sizing: border-box;
  }

  .testimonials__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    flex-wrap: wrap;
    gap: 24px;
  }

  .testimonials__header-left {
    display: flex;
    flex-direction: column;
    gap: 16px;
    max-width: 696px;
  }

  .testimonials__tag {
    display: inline-flex;
    align-self: flex-start;
    background-color: var(--theme-surface-alt);
    color: var(--theme-primary);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-medium);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wider);
    padding: 4px 12px;
    border-radius: var(--theme-radius-badge);
    line-height: normal;
  }

  .testimonials__heading {
    font-size: var(--font-size-5xl);
    line-height: normal;
    color: var(--theme-primary);
    letter-spacing: var(--letter-spacing-tighter);
    margin: 0;
    font-weight: var(--font-weight-regular);
  }

  .testimonials__header-right {
    display: flex;
    gap: 16px;
    align-items: center;
  }

  .testimonials__rating-number {
    font-size: var(--font-size-5xl);
    line-height: normal;
    color: var(--theme-primary);
    letter-spacing: var(--letter-spacing-tighter);
    font-weight: var(--font-weight-regular);
  }

  .testimonials__rating-info {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .testimonials__stars {
    display: flex;
    gap: 8px;
  }

  .testimonials__stars svg {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    fill: var(--theme-star);
  }

  .testimonials__review-count {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    color: var(--theme-text);
    letter-spacing: var(--letter-spacing-wider);
    text-transform: uppercase;
    line-height: normal;
  }

  .testimonials__cards {
    display: flex;
    gap: 24px;
    margin-top: 52px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding: 0 52px 8px;
    margin-left: calc(-1 * (100vw - var(--container-max, 1200px)) / 2 - 52px);
    width: 100vw;
  }

  .testimonials__cards::-webkit-scrollbar {
    display: none;
  }

  .testimonials__card {
    display: flex;
    align-items: flex-start;
    background-color: var(--theme-surface-alt);
    border-radius: var(--radius-3xl);
    padding: 8px 16px 8px 8px;
    min-width: 576px;
    max-width: 576px;
    scroll-snap-align: start;
    flex-shrink: 0;
  }

  .testimonials__card-avatar {
    width: 100px;
    min-height: 96px;
    flex-shrink: 0;
    border-radius: var(--theme-radius-image);
    overflow: hidden;
  }

  .testimonials__card-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .testimonials__avatar-placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .testimonials__card-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    padding: 8px;
    gap: 16px;
    min-width: 0;
  }

  .testimonials__card-quote {
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-medium);
    color: var(--theme-primary);
    line-height: var(--line-height-snug);
    letter-spacing: var(--letter-spacing-tighter);
    margin: 0;
  }

  .testimonials__card-author {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .testimonials__card-name {
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-medium);
    color: var(--theme-primary);
    line-height: var(--line-height-normal);
  }

  .testimonials__card-role {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    color: var(--theme-text-secondary);
    line-height: var(--line-height-snug);
  }

  @media screen and (max-width: 749px) {
    .testimonials {
      padding: 24px 0;
    }

    .testimonials__container {
      padding: 0 20px;
    }

    .testimonials__header {
      flex-direction: column;
      align-items: flex-start;
    }

    .testimonials__header-right {
      align-items: flex-start;
    }

    .testimonials__heading {
      font-size: var(--font-size-3xl);
      line-height: var(--line-height-tight);
      letter-spacing: var(--letter-spacing-tighter);
    }

    .testimonials__rating-number {
      font-size: var(--font-size-3xl);
    }

    .testimonials__cards {
      padding: 0 20px 8px;
      margin-left: -20px;
      width: 100vw;
    }

    .testimonials__card {
      min-width: 300px;
      max-width: 300px;
    }

    .testimonials__card-avatar {
      width: 72px;
      min-height: 72px;
    }

    .testimonials__card-quote {
      font-size: var(--font-size-base);
      line-height: var(--line-height-snug);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.testimonials.name",
  "settings": [
    {
      "type": "text",
      "id": "tag_text",
      "label": "t:sections.testimonials.settings.tag_text",
      "default": "Testimonials"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.testimonials.settings.heading",
      "default": "What our customer say?"
    },
    {
      "type": "text",
      "id": "rating",
      "label": "t:sections.testimonials.settings.rating",
      "default": "4.9"
    },
    {
      "type": "text",
      "id": "review_count",
      "label": "t:sections.testimonials.settings.review_count",
      "default": "10,078+"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "t:sections.testimonials.blocks.testimonial.name",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "t:sections.testimonials.blocks.testimonial.settings.quote",
          "default": "This product changed my daily routine completely. Highly recommended!"
        },
        {
          "type": "text",
          "id": "author_name",
          "label": "t:sections.testimonials.blocks.testimonial.settings.author_name",
          "default": "Jane Doe"
        },
        {
          "type": "text",
          "id": "author_role",
          "label": "t:sections.testimonials.blocks.testimonial.settings.author_role",
          "default": "Verified Buyer"
        },
        {
          "type": "image_picker",
          "id": "author_image",
          "label": "t:sections.testimonials.blocks.testimonial.settings.author_image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.testimonials.name",
      "blocks": [
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}

<section class="faq full-width" aria-label="{{ 'faq.section_label' | t }}">
  <div class="faq__container">
    <div class="faq__left">
      <span class="faq__tag">{{ section.settings.tag_text }}</span>
      <h2 class="faq__heading">{{ section.settings.heading }}</h2>
    </div>

    <div class="faq__right">
      {% for block in section.blocks %}
        <details
          class="faq__item"
          data-faq-item
          {% if forloop.first %}open{% endif %}
          {{ block.shopify_attributes }}
        >
          <div class="faq__divider"></div>
          <summary class="faq__question">
            <span class="faq__question-text">{{ block.settings.question }}</span>
            <span class="faq__icon" aria-hidden="true"></span>
          </summary>
          <div class="faq__answer">
            <div class="faq__answer-inner">
              {{ block.settings.answer }}
            </div>
          </div>
        </details>
      {% endfor %}

      {% if section.blocks.size > 0 %}
        <div class="faq__divider faq__divider--bottom"></div>
      {% endif %}
    </div>
  </div>
</section>

{% stylesheet %}
  .faq {
    background-color: var(--theme-surface);
    padding: 52px 0;
  }

  .faq__container {
    max-width: var(--container-max, 1200px);
    margin: 0 auto;
    padding: 0 var(--container-padding, 16px);
    display: flex;
    gap: 52px;
  }

  .faq__left {
    display: flex;
    flex-direction: column;
    gap: 16px;
    width: 419px;
    flex-shrink: 0;
  }

  .faq__tag {
    display: inline-flex;
    align-self: flex-start;
    background-color: var(--theme-surface-alt);
    color: var(--theme-primary);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-medium);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wider);
    padding: 4px 12px;
    border-radius: var(--theme-radius-badge);
    line-height: normal;
  }

  .faq__heading {
    font-size: var(--font-size-5xl);
    color: var(--theme-primary);
    line-height: normal;
    letter-spacing: var(--letter-spacing-tighter);
    margin: 0;
    font-weight: var(--font-weight-regular);
  }

  .faq__right {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 24px;
    min-width: 0;
  }

  .faq__item {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .faq__divider {
    height: 1px;
    background-color: var(--theme-border);
    width: 100%;
  }

  .faq__question {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    padding: 0;
    background: none;
    border: none;
    cursor: pointer;
    text-align: start;
    gap: 16px;
    font-family: inherit;
    list-style: none;
  }

  .faq__question::-webkit-details-marker {
    display: none;
  }

  .faq__question::marker {
    display: none;
    content: '';
  }

  .faq__question:focus-visible {
    outline: 2px solid var(--color-focus, var(--theme-primary));
    outline-offset: 2px;
    border-radius: var(--radius-sm);
  }

  .faq__question-text {
    font-size: var(--font-size-xl);
    color: var(--theme-primary);
    line-height: normal;
    font-weight: var(--font-weight-regular);
    letter-spacing: var(--letter-spacing-tighter);
  }

  .faq__item[open] .faq__question-text {
    font-weight: var(--font-weight-medium);
  }

  .faq__icon {
    position: relative;
    width: 24px;
    height: 24px;
    flex-shrink: 0;
  }

  .faq__icon::before,
  .faq__icon::after {
    content: "";
    position: absolute;
    background-color: var(--theme-text);
    transition: transform var(--duration-medium, 300ms) var(--ease-standard, ease),
                opacity var(--duration-medium, 300ms) var(--ease-standard, ease);
  }

  .faq__icon::before {
    inset-block-start: 50%;
    inset-inline: 4px;
    height: 2px;
    transform: translateY(-50%);
  }

  .faq__icon::after {
    inset-inline-start: 50%;
    inset-block: 4px;
    width: 2px;
    transform: translateX(-50%);
  }

  .faq__item[open] .faq__icon::after {
    transform: translateX(-50%) rotate(90deg);
    opacity: 0;
  }

  .faq__answer {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows var(--duration-medium, 300ms) var(--ease-standard, ease);
    overflow: hidden;
  }

  .faq__item[open] .faq__answer {
    grid-template-rows: 1fr;
  }

  .faq__answer-inner {
    min-height: 0;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    color: var(--theme-text-secondary);
    line-height: var(--line-height-snug);
  }

  .faq__answer-inner p {
    margin: 0;
  }

  .faq__divider--bottom {
    margin-top: 0;
  }

  @media screen and (max-width: 749px) {
    .faq {
      padding: 32px 0;
    }

    .faq__container {
      flex-direction: column;
      gap: 32px;
    }

    .faq__left {
      width: 100%;
    }

    .faq__heading {
      font-size: var(--font-size-3xl);
      line-height: var(--line-height-tight);
      letter-spacing: var(--letter-spacing-tighter);
    }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    var section = document.querySelector('.faq');
    if (!section) return;

    var items = section.querySelectorAll('[data-faq-item]');

    for (const item of items) {
      item.addEventListener('toggle', function () {
        if (!item.open) return;

        for (const other of items) {
          if (other !== item && other.open) {
            other.removeAttribute('open');
          }
        }
      });
    }
  })();
{% endjavascript %}

{% schema %}
{
  "name": "t:sections.faq.name",
  "settings": [
    {
      "type": "text",
      "id": "tag_text",
      "label": "t:sections.faq.settings.tag_text",
      "default": "FAQs"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.faq.settings.heading",
      "default": "Frequently ask questions"
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "t:sections.faq.blocks.faq_item.name",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "t:sections.faq.blocks.faq_item.settings.question",
          "default": "Is the bottle glass or plastic?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "t:sections.faq.blocks.faq_item.settings.answer",
          "default": "<p>Our bottle is glass and the base is stainless steel.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.faq.name",
      "blocks": [
        {
          "type": "faq_item",
          "settings": {
            "question": "Is the bottle glass or plastic?",
            "answer": "<p>Our bottle is glass and the base is stainless steel.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "How long do I need to use this bottle?",
            "answer": "<p>We recommend using it daily for best results.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "How many bottles do I need to drink in a day?",
            "answer": "<p>We recommend at least 2-3 full bottles per day for optimal hydration.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "Can I use distilled, filtered, or tap water?",
            "answer": "<p>Yes, you can use any type of water with our bottle.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "Does the bottle need a replacement filter?",
            "answer": "<p>No, the bottle does not require any replacement filters.</p>"
          }
        }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}

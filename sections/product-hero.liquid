{%- comment -%}
  Product hero section — two-column layout with image gallery (left) and
  product details with bundle selector, trust badges, social proof,
  guarantee card, and accordions (right).

  Designed for the product template. Uses the global `product` object.
{%- endcomment -%}

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign featured_image = product.featured_image
-%}

<div class="product-hero full-width">
  <div class="product-hero__inner">
    {%- comment -%} ===== Left column: Image gallery ===== {%- endcomment -%}
    <div class="product-hero__gallery">
      {%- if featured_image -%}
        <div class="product-hero__main-image" aria-live="polite">
          {{
            featured_image
            | image_url: width: 1136
            | image_tag:
              id: 'product-hero-main-img',
              class: 'product-hero__img',
              loading: 'eager',
              widths: '568,852,1136',
              sizes: '(min-width: 1024px) 568px, 100vw'
          }}
        </div>
      {%- else -%}
        <div class="product-hero__main-image">
          {{ 'product-1' | placeholder_svg_tag: 'product-hero__img product-hero__img--placeholder' }}
        </div>
      {%- endif -%}

      {%- if product.images.size > 1 -%}
        {%- assign grid_images = product.images | where: 'attached_to_variant?', false -%}
        {%- comment -%} Fall back to all images after the first if no non-variant images {%- endcomment -%}
        {%- if grid_images.size == 0 -%}
          {%- assign grid_images = product.images -%}
        {%- endif -%}

        {%- for image in grid_images -%}
          {%- if forloop.index > 1 -%}
            {%- assign grid_index = forloop.index | minus: 2 -%}
            {%- assign row_index = grid_index | modulo: 2 -%}

            {%- if row_index == 0 -%}
              <div class="product-hero__grid-images">
            {%- endif -%}

            <div class="product-hero__grid-image"
              data-thumbnail-index="{{ forloop.index0 }}"
              data-image-url="{{ image | image_url: width: 1136 }}"
              data-image-srcset="{{ image | image_url: width: 568 }} 568w, {{ image | image_url: width: 852 }} 852w, {{ image | image_url: width: 1136 }} 1136w"
              data-image-alt="{{ image.alt | escape }}"
              role="button"
              tabindex="0"
              aria-label="{{ 'products.hero.thumbnail_label' | t: index: forloop.index }}"
            >
              {{
                image
                | image_url: width: 568
                | image_tag:
                  class: 'product-hero__grid-img',
                  loading: 'lazy',
                  widths: '284,426,568',
                  sizes: '(min-width: 1024px) 276px, 50vw'
              }}
            </div>

            {%- if row_index == 1 or forloop.last -%}
              </div>
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- comment -%} ===== Right column: Product details ===== {%- endcomment -%}
    <div class="product-hero__details">

      {%- comment -%} Group 1: Review badge + Title + Description + Price {%- endcomment -%}
      <div class="product-hero__info-group">
        <div class="product-hero__review-badge" aria-label="{{ 'products.hero.rating_label' | t: rating: section.settings.review_rating }}">
          <svg class="product-hero__review-badge-star" width="20" height="20" viewBox="0 0 20 20" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M10 1.12l2.24 5.36 5.76.56-4.36 3.8 1.28 5.64L10 13.64l-4.92 2.84 1.28-5.64-4.36-3.8 5.76-.56L10 1.12z"/>
          </svg>
          <span class="product-hero__review-badge-text">
            {{- section.settings.review_count }} {{ 'products.hero.five_star_reviews' | t -}}
          </span>
        </div>
        <h1 class="product-hero__title">{{ product.title }}</h1>
        {%- if product.description != blank -%}
          <div class="product-hero__description">
            {{ product.description }}
          </div>
        {%- endif -%}
        <div class="product-hero__price">
          <span class="product-hero__price-current">
            {{ current_variant.price | money }}
          </span>
          {%- if current_variant.compare_at_price > current_variant.price -%}
            <span class="product-hero__price-compare">
              {{ current_variant.compare_at_price | money }}
            </span>
          {%- endif -%}
        </div>
      </div>

      {%- comment -%} Group 2: Guarantee banner {%- endcomment -%}
      {%- if section.settings.guarantee_banner_text != blank -%}
        <div class="product-hero__guarantee-banner">
          <span class="product-hero__guarantee-banner-text">
            {{ section.settings.guarantee_banner_text }}
          </span>
        </div>
      {%- endif -%}

      {%- comment -%} Group 3: Bundle selector {%- endcomment -%}
      {% form 'product', product, id: 'product-hero-form', class: 'product-hero__form' %}
        <fieldset class="product-hero__bundles" aria-label="{{ 'products.hero.select_quantity' | t }}">
          <legend class="visually-hidden">{{ 'products.hero.select_quantity' | t }}</legend>

          {%- for i in (1..3) -%}
            {%- liquid
              if i == 1
                assign bundle_label = 'products.hero.bundle_1'
                assign bundle_subtitle = 'products.hero.bundle_1_subtitle'
                assign bundle_save_badge = ''
                assign bundle_qty = 1
                assign is_popular = true
              elsif i == 2
                assign bundle_label = 'products.hero.bundle_2'
                assign bundle_subtitle = 'products.hero.bundle_2_subtitle'
                assign bundle_save_badge = 'products.hero.badge_save'
                assign bundle_qty = 2
                assign is_popular = false
              else
                assign bundle_label = 'products.hero.bundle_3'
                assign bundle_subtitle = 'products.hero.bundle_3_subtitle'
                assign bundle_save_badge = 'products.hero.badge_save_best'
                assign bundle_qty = 3
                assign is_popular = false
              endif

              assign bundle_price = current_variant.price | times: bundle_qty
              assign bundle_compare = current_variant.compare_at_price | times: bundle_qty
            -%}
            <label class="product-hero__bundle{% if i == 1 %} product-hero__bundle--selected{% endif %}">
              {%- if is_popular -%}
                <span class="product-hero__bundle-ribbon" aria-hidden="true">
                  {{ 'products.hero.badge_popular' | t }}
                </span>
              {%- endif -%}
              <input
                type="radio"
                name="quantity"
                value="{{ bundle_qty }}"
                class="visually-hidden"
                {% if i == 1 %}checked{% endif %}
                data-bundle-index="{{ i }}"
              >
              <span class="product-hero__bundle-inner">
                <span class="product-hero__bundle-radio" aria-hidden="true"></span>
                <span class="product-hero__bundle-info">
                  <span class="product-hero__bundle-title-row">
                    <span class="product-hero__bundle-title">{{ bundle_label | t }}</span>
                    {%- if bundle_save_badge != blank -%}
                      <span class="product-hero__bundle-save-badge">{{ bundle_save_badge | t }}</span>
                    {%- endif -%}
                  </span>
                  <span class="product-hero__bundle-subtitle">{{ bundle_subtitle | t }}</span>
                </span>
                <span class="product-hero__bundle-price-box">
                  <span class="product-hero__bundle-price">{{ bundle_price | money }}</span>
                  {%- if current_variant.compare_at_price > current_variant.price -%}
                    <span class="product-hero__bundle-compare">{{ bundle_compare | money }}</span>
                  {%- endif -%}
                </span>
              </span>
            </label>
          {%- endfor -%}
        </fieldset>

        <input type="hidden" name="id" value="{{ current_variant.id }}">
      {% endform %}

      {%- comment -%} Group 4: Add to cart + Shipping estimate {%- endcomment -%}
      <div class="product-hero__cta-group">
        <button
          type="submit"
          form="product-hero-form"
          class="product-hero__add-to-cart"
          {% unless current_variant.available %}disabled{% endunless %}
        >
          {%- if current_variant.available -%}
            {{ 'products.hero.add_to_cart' | t }}
          {%- else -%}
            {{ 'products.hero.sold_out' | t }}
          {%- endif -%}
        </button>
        {%- if section.settings.shipping_estimate_text != blank -%}
          <p class="product-hero__shipping-estimate">
            {{ section.settings.shipping_estimate_text }}
          </p>
        {%- endif -%}
      </div>

      {%- comment -%} 9. Trust badges {%- endcomment -%}
      {%- if section.settings.show_trust_badges -%}
        {%- assign trust_badge_blocks = section.blocks | where: 'type', 'trust_badge' -%}
        {%- if trust_badge_blocks.size > 0 -%}
          <div class="product-hero__trust-badges">
            {%- for block in trust_badge_blocks -%}
              <div class="product-hero__trust-badge" {{ block.shopify_attributes }}>
                {%- if block.settings.icon != blank -%}
                  <span class="product-hero__trust-badge-icon" aria-hidden="true">
                    {{ block.settings.icon }}
                  </span>
                {%- endif -%}
                <span class="product-hero__trust-badge-text">
                  {{ block.settings.text }}
                </span>
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}
      {%- endif -%}

      {%- comment -%} 10. Money-back guarantee card {%- endcomment -%}
      {%- if section.settings.show_guarantee_card -%}
        <div class="product-hero__guarantee-card">
          <div class="product-hero__guarantee-card-header">
            <div class="product-hero__guarantee-card-badge" aria-hidden="true">
              <svg width="64" height="64" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M32 2.6L37.8 8.2L45.4 6.2L48.2 13.4L55.8 14.2L55 21.8L61.4 26.2L57.4 33L61.4 39.8L55 44.2L55.8 51.8L48.2 52.6L45.4 59.8L37.8 57.8L32 63.4L26.2 57.8L18.6 59.8L15.8 52.6L8.2 51.8L9 44.2L2.6 39.8L6.6 33L2.6 26.2L9 21.8L8.2 14.2L15.8 13.4L18.6 6.2L26.2 8.2L32 2.6Z" fill="#1B79B0"/>
                <text x="32" y="30" text-anchor="middle" font-size="14" font-weight="800" fill="var(--theme-text-on-primary)">90</text>
                <text x="32" y="42" text-anchor="middle" font-size="8" font-weight="800" fill="var(--theme-text-on-primary)">DAY</text>
              </svg>
            </div>
            <span class="product-hero__guarantee-card-heading">
              {{ section.settings.guarantee_card_heading }}
            </span>
          </div>
          {%- if section.settings.guarantee_card_body != blank -%}
            <p class="product-hero__guarantee-card-body">
              {{ section.settings.guarantee_card_body }}
            </p>
          {%- endif -%}
          {%- if section.settings.guarantee_card_claim_text != blank -%}
            <div class="product-hero__guarantee-card-claim">
              <span class="product-hero__guarantee-card-claim-text">
                {{ section.settings.guarantee_card_claim_text }}
              </span>
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- comment -%} 11. Social proof images {%- endcomment -%}
      {%- assign social_proof_blocks = section.blocks | where: 'type', 'social_proof' -%}
      {%- if section.settings.show_social_proof -%}
        {%- if social_proof_blocks.size > 0 -%}
          <div class="product-hero__social-proof">
            {%- for block in social_proof_blocks -%}
              <div class="product-hero__social-proof-item" {{ block.shopify_attributes }}>
                {%- if block.settings.image -%}
                  <div class="product-hero__social-proof-image">
                    {{
                      block.settings.image
                      | image_url: width: 400, height: 382, crop: 'center'
                      | image_tag:
                        class: 'product-hero__social-proof-img',
                        loading: 'lazy',
                        widths: '200,300,400',
                        sizes: '(min-width: 1024px) 130px, 45vw'
                    }}
                  </div>
                {%- endif -%}
                <div class="product-hero__social-proof-text">
                  <div class="product-hero__social-proof-stars" aria-hidden="true">
                    {%- for s in (1..5) -%}
                      <svg width="14" height="14" viewBox="0 0 20 20" fill="var(--theme-star)" xmlns="http://www.w3.org/2000/svg">
                        <path d="M10 1.12l2.24 5.36 5.76.56-4.36 3.8 1.28 5.64L10 13.64l-4.92 2.84 1.28-5.64-4.36-3.8 5.76-.56L10 1.12z"/>
                      </svg>
                    {%- endfor -%}
                  </div>
                  {%- if block.settings.quote != blank -%}
                    <p class="product-hero__social-proof-quote">{{ block.settings.quote }}</p>
                  {%- endif -%}
                </div>
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}
      {%- endif -%}

      {%- comment -%} 12 & 13. Accordions {%- endcomment -%}
      {%- assign accordion_blocks = section.blocks | where: 'type', 'accordion_item' -%}
      {%- if accordion_blocks.size > 0 -%}
        <div class="product-hero__accordions">
          {%- for block in accordion_blocks -%}
            <details class="product-hero__accordion" {{ block.shopify_attributes }}>
              <summary class="product-hero__accordion-header">
                <span class="product-hero__accordion-title">{{ block.settings.title }}</span>
                <span class="product-hero__accordion-icon" aria-hidden="true">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
                    <line class="product-hero__accordion-icon-h" x1="5" y1="12" x2="19" y2="12"/>
                    <line class="product-hero__accordion-icon-v" x1="12" y1="5" x2="12" y2="19"/>
                  </svg>
                </span>
              </summary>
              <div class="product-hero__accordion-content">
                {{ block.settings.content }}
              </div>
            </details>
          {%- endfor -%}
        </div>
      {%- endif -%}

    </div>
  </div>
</div>

{% stylesheet %}
  /* ===== Product hero layout ===== */
  .product-hero {
    background-color: var(--theme-surface);
    padding: 24px 52px;
  }

  .product-hero__inner {
    display: flex;
    gap: 40px;
    max-width: 1280px;
    margin: 0 auto;
  }

  .product-hero__gallery {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .product-hero__details {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .product-hero__info-group {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .product-hero__cta-group {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  /* ===== Gallery ===== */
  .product-hero__main-image {
    border-radius: var(--theme-radius-card);
    overflow: hidden;
    background-color: var(--theme-surface-alt);
  }

  .product-hero__img {
    width: 100%;
    height: 451px;
    display: block;
    object-fit: cover;
    border-radius: var(--theme-radius-card);
  }

  .product-hero__img--placeholder {
    height: 451px;
  }

  .product-hero__grid-images {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .product-hero__grid-image {
    border-radius: var(--theme-radius-card);
    overflow: hidden;
    cursor: pointer;
    transition: opacity var(--duration-fast) var(--ease-standard);
  }

  .product-hero__grid-image:hover {
    opacity: 0.85;
  }

  .product-hero__grid-image:focus-visible {
    outline: 2px solid var(--color-focus, var(--theme-primary));
    outline-offset: 2px;
  }

  .product-hero__grid-img {
    width: 100%;
    height: 235px;
    object-fit: cover;
    display: block;
    border-radius: var(--theme-radius-card);
  }

  /* ===== Review badge ===== */
  .product-hero__review-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 4px 16px 4px 8px;
    background-color: var(--theme-accent);
    color: var(--theme-primary);
    border-radius: 28px;
  }

  .product-hero__review-badge-star {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
  }

  .product-hero__review-badge-text {
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 1.44px;
    line-height: 18px;
  }

  /* ===== Title ===== */
  .product-hero__title {
    font-size: 52px;
    line-height: 64px;
    letter-spacing: -2.08px;
    font-weight: 400;
    color: var(--theme-primary);
    margin: 0;
    font-family: var(--font-heading, var(--font-sans));
  }

  /* ===== Description ===== */
  .product-hero__description {
    font-size: 16px;
    font-weight: 400;
    line-height: 24px;
    color: var(--theme-text-secondary);
  }

  .product-hero__description p {
    margin: 0;
  }

  /* ===== Price ===== */
  .product-hero__price {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .product-hero__price-current {
    font-size: 40px;
    font-weight: 400;
    letter-spacing: -1.6px;
    color: var(--theme-primary);
    font-family: var(--font-heading, var(--font-sans));
  }

  .product-hero__price-compare {
    font-size: 24px;
    letter-spacing: -0.96px;
    color: color-mix(in srgb, var(--theme-primary) 40%, transparent);
    text-decoration: line-through;
  }

  /* ===== Guarantee banner (full-width pill) ===== */
  .product-hero__guarantee-banner {
    background-color: var(--theme-accent);
    border-radius: 36px;
    padding: 8px 24px;
    text-align: center;
  }

  .product-hero__guarantee-banner-text {
    font-size: 14px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 1.4px;
    color: var(--theme-primary);
  }

  /* ===== Bundle selector ===== */
  .product-hero__bundles {
    display: flex;
    flex-direction: column;
    gap: 16px;
    border: none;
    padding: 0;
    margin: 0;
  }

  .product-hero__bundle {
    position: relative;
    cursor: pointer;
    display: block;
  }

  .product-hero__bundle-inner {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 12px 12px 12px 16px;
    background-color: var(--theme-surface-alt);
    border-radius: 16px;
    border: 1px solid transparent;
    transition:
      border-color var(--duration-fast) var(--ease-standard),
      box-shadow var(--duration-fast) var(--ease-standard);
  }

  .product-hero__bundle input:checked + .product-hero__bundle-inner,
  .product-hero__bundle--selected .product-hero__bundle-inner {
    border-color: var(--theme-primary);
  }

  .product-hero__bundle input:focus-visible + .product-hero__bundle-inner {
    outline: 2px solid var(--color-focus, var(--theme-primary));
    outline-offset: 2px;
  }

  /* Bundle ribbon (POPULAR) */
  .product-hero__bundle-ribbon {
    position: absolute;
    top: -12px;
    right: 24px;
    z-index: 1;
    display: flex;
    align-items: center;
    height: 20px;
    padding: 0 16px;
    background-color: var(--theme-primary);
    color: var(--theme-text-on-primary);
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 1.44px;
    line-height: 18px;
    border-bottom-left-radius: 8px;
    border-bottom-right-radius: 8px;
  }

  .product-hero__bundle-ribbon::before,
  .product-hero__bundle-ribbon::after {
    content: '';
    position: absolute;
    top: 0;
    width: 0;
    height: 0;
    border-bottom: 12px solid var(--theme-primary-dark);
  }

  .product-hero__bundle-ribbon::before {
    right: 100%;
    border-left: 12px solid transparent;
  }

  .product-hero__bundle-ribbon::after {
    left: 100%;
    border-right: 12px solid transparent;
  }

  /* Bundle radio circle */
  .product-hero__bundle-radio {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    border: 2px solid var(--theme-border);
    box-sizing: border-box;
    position: relative;
    transition: border-color var(--duration-fast) var(--ease-standard);
  }

  .product-hero__bundle input:checked ~ .product-hero__bundle-inner .product-hero__bundle-radio {
    border-color: var(--theme-primary);
  }

  .product-hero__bundle input:checked ~ .product-hero__bundle-inner .product-hero__bundle-radio::after {
    content: '';
    position: absolute;
    top: 3px;
    left: 3px;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: var(--theme-primary);
  }

  /* Bundle info */
  .product-hero__bundle-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex: 1;
    min-width: 0;
  }

  .product-hero__bundle-title-row {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
  }

  .product-hero__bundle-title {
    font-size: 16px;
    font-weight: 400;
    line-height: 24px;
    color: var(--theme-primary);
  }

  .product-hero__bundle-subtitle {
    font-size: 14px;
    line-height: 20px;
    font-weight: 400;
    color: var(--theme-text-secondary);
  }

  .product-hero__bundle-save-badge {
    display: inline-flex;
    padding: 4px 8px;
    background-color: var(--theme-accent);
    color: var(--theme-primary);
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 1.44px;
    border-radius: 28px;
    line-height: 1;
  }

  /* Bundle price box */
  .product-hero__bundle-price-box {
    flex-shrink: 0;
    width: 148px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 8px 16px;
    background-color: var(--theme-surface-emphasis);
    border-radius: 8px;
    align-self: stretch;
  }

  .product-hero__bundle-price {
    font-size: 16px;
    font-weight: 400;
    line-height: 24px;
    color: var(--theme-primary);
  }

  .product-hero__bundle-compare {
    font-size: 12px;
    line-height: 16px;
    color: color-mix(in srgb, var(--theme-primary) 40%, transparent);
    text-decoration: line-through;
    text-align: right;
  }

  /* ===== Add to cart ===== */
  .product-hero__add-to-cart {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 56px;
    border: none;
    border-radius: 48px;
    background-color: var(--theme-primary);
    color: var(--theme-text-on-primary);
    font-size: 16px;
    font-weight: 500;
    letter-spacing: -0.32px;
    cursor: pointer;
    transition:
      background-color var(--duration-fast) var(--ease-standard),
      opacity var(--duration-fast) var(--ease-standard);
  }

  .product-hero__add-to-cart:hover {
    background-color: var(--theme-primary-hover);
  }

  .product-hero__add-to-cart:focus-visible {
    outline: 2px solid var(--color-focus, var(--theme-primary));
    outline-offset: 2px;
  }

  .product-hero__add-to-cart:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  /* ===== Shipping estimate ===== */
  .product-hero__shipping-estimate {
    text-align: center;
    font-size: 14px;
    line-height: 20px;
    color: var(--theme-text-secondary);
    margin: 0;
  }

  /* ===== Trust badges ===== */
  .product-hero__trust-badges {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
  }

  .product-hero__trust-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    background-color: var(--theme-surface-alt);
    border-radius: 36px;
    white-space: nowrap;
    overflow: hidden;
  }

  .product-hero__trust-badge-icon {
    display: inline-flex;
    align-items: center;
    font-size: 14px;
    line-height: 1;
    flex-shrink: 0;
  }

  .product-hero__trust-badge-text {
    font-size: 14px;
    font-weight: 400;
    color: var(--theme-primary);
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* ===== Guarantee card ===== */
  .product-hero__guarantee-card {
    background-color: var(--theme-surface-alt);
    border-radius: 16px;
    padding: 12px 16px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .product-hero__guarantee-card-header {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .product-hero__guarantee-card-badge {
    flex-shrink: 0;
    width: 64px;
    height: 64px;
  }

  .product-hero__guarantee-card-heading {
    font-size: 20px;
    font-weight: 400;
    line-height: 28px;
    color: var(--theme-primary);
  }

  .product-hero__guarantee-card-body {
    font-size: 14px;
    line-height: 20px;
    color: var(--theme-text-secondary);
    margin: 0;
  }

  .product-hero__guarantee-card-claim {
    background-color: var(--theme-accent);
    border-radius: 36px;
    padding: 6px 16px;
    text-align: center;
  }

  .product-hero__guarantee-card-claim-text {
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 1.44px;
    color: var(--theme-primary);
  }

  /* ===== Social proof images ===== */
  .product-hero__social-proof {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }

  .product-hero__social-proof-item {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .product-hero__social-proof-image {
    border-radius: 16px;
    overflow: hidden;
    height: 191px;
  }

  .product-hero__social-proof-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .product-hero__social-proof-text {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .product-hero__social-proof-stars {
    display: flex;
    gap: 4px;
  }

  .product-hero__social-proof-quote {
    font-size: 14px;
    font-weight: 400;
    line-height: 20px;
    color: var(--theme-primary);
    margin: 0;
  }

  /* ===== Accordions ===== */
  .product-hero__accordion {
    border-top: 1px solid var(--theme-border);
  }

  .product-hero__accordion:last-child {
    border-bottom: 1px solid var(--theme-border);
  }

  .product-hero__accordion-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 0;
    cursor: pointer;
    list-style: none;
    user-select: none;
  }

  .product-hero__accordion-header::-webkit-details-marker {
    display: none;
  }

  .product-hero__accordion-header::marker {
    content: '';
    display: none;
  }

  .product-hero__accordion-header:focus-visible {
    outline: 2px solid var(--color-focus, var(--theme-primary));
    outline-offset: 2px;
  }

  .product-hero__accordion-title {
    font-size: 20px;
    font-weight: 400;
    line-height: 28px;
    color: var(--theme-primary);
  }

  .product-hero__accordion-icon {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    color: var(--theme-primary);
  }

  .product-hero__accordion-icon-v {
    transition: transform var(--duration-fast) var(--ease-standard);
    transform-origin: center;
  }

  .product-hero__accordion[open] .product-hero__accordion-icon-v {
    transform: scaleY(0);
  }

  .product-hero__accordion-content {
    padding: 0 0 16px 0;
    font-size: 14px;
    line-height: 20px;
    color: var(--theme-text-secondary);
  }

  .product-hero__accordion-content ul {
    margin: 0;
    padding-left: 20px;
  }

  .product-hero__accordion-content li {
    margin-bottom: 4px;
  }

  /* ===== Visually hidden utility ===== */
  .visually-hidden {
    position: absolute !important;
    width: 1px !important;
    height: 1px !important;
    padding: 0 !important;
    margin: -1px !important;
    overflow: hidden !important;
    clip: rect(0, 0, 0, 0) !important;
    white-space: nowrap !important;
    border: 0 !important;
  }

  /* ===== Responsive ===== */
  @media (max-width: 1023px) {
    .product-hero {
      padding: 24px;
    }

    .product-hero__inner {
      flex-direction: column;
      gap: 32px;
    }

    .product-hero__details {
      gap: 24px;
    }

    .product-hero__title {
      font-size: 36px;
      line-height: 44px;
      letter-spacing: -1.44px;
    }

    .product-hero__price-current {
      font-size: 28px;
      letter-spacing: -1.12px;
    }

    .product-hero__price-compare {
      font-size: 18px;
    }

    .product-hero__social-proof {
      grid-template-columns: repeat(2, 1fr);
    }

    .product-hero__social-proof-image {
      height: 160px;
    }
  }

  @media (max-width: 639px) {
    .product-hero {
      padding: 16px;
    }

    .product-hero__trust-badges {
      grid-template-columns: 1fr;
    }

    .product-hero__trust-badge {
      white-space: normal;
    }

    .product-hero__grid-images {
      grid-template-columns: 1fr 1fr;
      gap: 8px;
    }

    .product-hero__grid-img {
      height: 160px;
    }

    .product-hero__img {
      height: auto;
      aspect-ratio: 1 / 1;
    }

    .product-hero__bundle-price-box {
      width: auto;
      min-width: 100px;
    }

    .product-hero__social-proof {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }

    .product-hero__social-proof-image {
      height: 140px;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function() {
    var section = document.querySelector('.product-hero');
    if (!section) return;

    /* Gallery: clicking grid images swaps the main image */
    var mainImg = section.querySelector('#product-hero-main-img');
    var gridImages = section.querySelectorAll('.product-hero__grid-image');

    if (mainImg && gridImages.length > 0) {
      gridImages.forEach(function(thumb) {
        function handleClick() {
          var url = thumb.getAttribute('data-image-url');
          var srcset = thumb.getAttribute('data-image-srcset');
          var alt = thumb.getAttribute('data-image-alt');

          if (url) mainImg.src = url;
          if (srcset) mainImg.srcset = srcset;
          if (alt !== null) mainImg.alt = alt;
        }

        thumb.addEventListener('click', handleClick);
        thumb.addEventListener('keydown', function(e) {
          if (e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            handleClick();
          }
        });
      });
    }

    /* Bundle selector: sync selected state class */
    var bundles = section.querySelectorAll('.product-hero__bundle');
    bundles.forEach(function(bundle) {
      var input = bundle.querySelector('input[type="radio"]');
      if (!input) return;

      input.addEventListener('change', function() {
        bundles.forEach(function(b) {
          b.classList.remove('product-hero__bundle--selected');
        });
        if (this.checked) {
          bundle.classList.add('product-hero__bundle--selected');
        }
      });
    });
  })();
{% endjavascript %}


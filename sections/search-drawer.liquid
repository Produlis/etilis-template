{%- comment -%}
  Search Drawer — full-screen overlay with predictive search.
  Rendered from header-group.json so it appears on every page.
  Uses Shopify's Predictive Search API for instant results.
{%- endcomment -%}

<div class="search-drawer" data-search-drawer>
  <div class="search-drawer__overlay" data-search-drawer-overlay tabindex="-1"></div>

  <div class="search-drawer__panel" data-search-drawer-panel role="dialog" aria-label="{{ 'search.title' | t }}" aria-modal="true">

    {%- comment -%} Header with search input {%- endcomment -%}
    <div class="search-drawer__header">
      <form action="{{ routes.search_url }}" method="get" role="search" class="search-drawer__form" data-search-form>
        <div class="search-drawer__input-wrapper">
          <svg class="search-drawer__input-icon" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <circle cx="9" cy="9" r="6" stroke="currentColor" stroke-width="1.5"/>
            <path d="M13.5 13.5L17 17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <input
            type="search"
            name="q"
            class="search-drawer__input"
            placeholder="{{ 'search.placeholder' | t }}"
            autocomplete="off"
            autocorrect="off"
            autocapitalize="off"
            spellcheck="false"
            data-search-input
            aria-label="{{ 'search.placeholder' | t }}"
          >
          <button
            type="button"
            class="search-drawer__clear"
            aria-label="{{ 'search.clear' | t }}"
            data-search-clear
            hidden
          >
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <circle cx="8" cy="8" r="7" fill="currentColor" opacity="0.15"/>
              <path d="M5.5 5.5L10.5 10.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              <path d="M10.5 5.5L5.5 10.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </button>
        </div>
        <input type="hidden" name="type" value="product,article,page">
      </form>

      <button
        class="search-drawer__close"
        data-search-drawer-close
        aria-label="{{ 'header.close_menu' | t }}"
      >
        {{ 'search.cancel' | t }}
      </button>
    </div>

    {%- comment -%} Results container {%- endcomment -%}
    <div class="search-drawer__body" data-search-body>

      {%- comment -%} Empty state — shown before typing {%- endcomment -%}
      <div class="search-drawer__empty" data-search-empty>
        <div class="search-drawer__empty-icon">
          <svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <circle cx="22" cy="22" r="14" stroke="currentColor" stroke-width="2"/>
            <path d="M33 33L42 42" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </div>
        <p class="search-drawer__empty-text">{{ 'search.start_typing' | t }}</p>
      </div>

      {%- comment -%} Loading state {%- endcomment -%}
      <div class="search-drawer__loading" data-search-loading hidden>
        <div class="search-drawer__spinner" aria-label="{{ 'search.loading' | t }}"></div>
      </div>

      {%- comment -%} No results state {%- endcomment -%}
      <div class="search-drawer__no-results" data-search-no-results hidden>
        <p class="search-drawer__no-results-text">{{ 'search.no_results' | t }}</p>
        <p class="search-drawer__no-results-hint">{{ 'search.try_different' | t }}</p>
      </div>

      {%- comment -%} Results — populated by JS {%- endcomment -%}
      <div class="search-drawer__results" data-search-results hidden>

        {%- comment -%} Products {%- endcomment -%}
        <div class="search-drawer__section" data-search-products hidden>
          <h3 class="search-drawer__section-title">{{ 'search.products' | t }}</h3>
          <ul class="search-drawer__product-list" data-search-product-list></ul>
        </div>

        {%- comment -%} Articles {%- endcomment -%}
        <div class="search-drawer__section" data-search-articles hidden>
          <h3 class="search-drawer__section-title">{{ 'search.articles' | t }}</h3>
          <ul class="search-drawer__link-list" data-search-article-list></ul>
        </div>

        {%- comment -%} Pages {%- endcomment -%}
        <div class="search-drawer__section" data-search-pages hidden>
          <h3 class="search-drawer__section-title">{{ 'search.pages' | t }}</h3>
          <ul class="search-drawer__link-list" data-search-page-list></ul>
        </div>

        {%- comment -%} View all link {%- endcomment -%}
        <div class="search-drawer__view-all">
          <a href="#" class="search-drawer__view-all-link" data-search-view-all>
            {{ 'search.view_all_results' | t }}
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M3 8H13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              <path d="M9 4L13 8L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
  /* ===== Search Drawer ===== */
  .search-drawer [hidden] {
    display: none !important;
  }

  .search-drawer {
    display: none;
  }

  .search-drawer.is-open {
    display: block;
  }

  /* --- Overlay --- */
  .search-drawer__overlay {
    position: fixed;
    inset: 0;
    background-color: var(--color-overlay);
    z-index: var(--z-modal, 300);
    animation: searchOverlayIn var(--duration-medium, 300ms) var(--ease-standard, ease);
  }

  @keyframes searchOverlayIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  /* --- Panel --- */
  .search-drawer__panel {
    position: fixed;
    inset-block-start: 0;
    inset-inline: 0;
    max-height: 80vh;
    background-color: var(--color-bg, #fff);
    z-index: var(--z-modal, 300);
    display: flex;
    flex-direction: column;
    animation: searchPanelIn var(--duration-medium, 300ms) var(--ease-emphasized, ease);
    border-bottom-left-radius: var(--theme-radius-card, 0);
    border-bottom-right-radius: var(--theme-radius-card, 0);
    box-shadow: var(--shadow-lg, 0 25px 50px -12px rgba(0, 0, 0, 0.25));
  }

  @keyframes searchPanelIn {
    from { opacity: 0; transform: translateY(-20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* --- Header --- */
  .search-drawer__header {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px 24px;
    border-block-end: 1px solid var(--color-border, #e0e0e0);
  }

  .search-drawer__form {
    flex: 1;
    min-width: 0;
  }

  .search-drawer__input-wrapper {
    display: flex;
    align-items: center;
    gap: 10px;
    background-color: var(--color-bg-subtle, #f5f5f5);
    border: 1px solid var(--color-border, #e0e0e0);
    border-radius: var(--theme-radius-button, 0);
    padding: 0 16px;
    height: 48px;
    transition: border-color var(--duration-fast, 150ms) var(--ease-standard, ease);
  }

  .search-drawer__input-wrapper:focus-within {
    border-color: var(--color-accent, #0a0a0a);
    outline: 2px solid var(--color-focus, #0a0a0a);
    outline-offset: 2px;
  }

  .search-drawer__input-icon {
    flex-shrink: 0;
    color: var(--color-text-muted, #555);
  }

  .search-drawer__input {
    flex: 1;
    min-width: 0;
    border: none;
    background: none;
    font-size: var(--font-size-base, 1rem);
    font-family: inherit;
    color: var(--color-text, #0a0a0a);
    line-height: var(--line-height-normal, 1.5);
    outline: none;
    padding: 0;
  }

  .search-drawer__input::placeholder {
    color: var(--color-text-disabled, #aaa);
  }

  .search-drawer__clear {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    padding: 0;
    border: none;
    background: none;
    color: var(--color-text-muted, #555);
    cursor: pointer;
    border-radius: var(--radius-round, 50%);
    transition: color var(--duration-fast, 150ms) var(--ease-standard, ease);
  }

  .search-drawer__clear:hover {
    color: var(--color-text, #0a0a0a);
  }

  .search-drawer__close {
    flex-shrink: 0;
    padding: 8px 0;
    border: none;
    background: none;
    font-size: var(--font-size-base, 1rem);
    font-family: inherit;
    color: var(--color-text-muted, #555);
    cursor: pointer;
    transition: color var(--duration-fast, 150ms) var(--ease-standard, ease);
    white-space: nowrap;
  }

  .search-drawer__close:hover {
    color: var(--color-text, #0a0a0a);
  }

  .search-drawer__close:focus-visible {
    outline: 2px solid var(--color-focus, #0a0a0a);
    outline-offset: 2px;
    border-radius: var(--radius-sm, 4px);
  }

  /* --- Body --- */
  .search-drawer__body {
    flex: 1;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    padding: 0;
  }

  /* --- Empty state --- */
  .search-drawer__empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: 48px 24px;
  }

  .search-drawer__empty-icon {
    color: var(--color-text-disabled, #aaa);
  }

  .search-drawer__empty-text {
    font-size: var(--font-size-sm, 0.875rem);
    color: var(--color-text-muted, #555);
    margin: 0;
  }

  /* --- Loading state --- */
  .search-drawer__loading {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 48px 24px;
  }

  .search-drawer__spinner {
    width: 24px;
    height: 24px;
    border: 2px solid var(--color-border, #e0e0e0);
    border-top-color: var(--color-accent, #0a0a0a);
    border-radius: var(--radius-round, 50%);
    animation: searchSpin 0.6s linear infinite;
  }

  @keyframes searchSpin {
    to { transform: rotate(360deg); }
  }

  /* --- No results --- */
  .search-drawer__no-results {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    padding: 48px 24px;
    text-align: center;
  }

  .search-drawer__no-results-text {
    font-size: var(--font-size-base, 1rem);
    font-weight: var(--font-weight-medium, 500);
    color: var(--color-text, #0a0a0a);
    margin: 0;
  }

  .search-drawer__no-results-hint {
    font-size: var(--font-size-sm, 0.875rem);
    color: var(--color-text-muted, #555);
    margin: 0;
  }

  /* --- Results --- */
  .search-drawer__results {
    padding: 8px 0;
  }

  .search-drawer__section {
    padding: 8px 24px 16px;
  }

  .search-drawer__section-title {
    font-size: var(--font-size-xs, 0.75rem);
    font-weight: var(--font-weight-medium, 500);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wider, 0.05em);
    color: var(--color-text-muted, #555);
    margin: 0 0 8px 0;
    padding: 0;
  }

  /* --- Product list --- */
  .search-drawer__product-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .search-drawer__product-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 8px;
    border-radius: var(--theme-radius-card, 0);
    text-decoration: none;
    color: inherit;
    transition: background-color var(--duration-fast, 150ms) var(--ease-standard, ease);
  }

  .search-drawer__product-item:hover {
    background-color: var(--color-bg-subtle, #f5f5f5);
  }

  .search-drawer__product-item:focus-visible {
    outline: 2px solid var(--color-focus, #0a0a0a);
    outline-offset: -2px;
  }

  .search-drawer__product-image {
    width: 56px;
    height: 56px;
    flex-shrink: 0;
    border-radius: var(--theme-radius-image, 0);
    overflow: hidden;
    background-color: var(--color-bg-subtle, #f5f5f5);
  }

  .search-drawer__product-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .search-drawer__product-image--placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-disabled, #aaa);
  }

  .search-drawer__product-info {
    flex: 1;
    min-width: 0;
  }

  .search-drawer__product-title {
    font-size: var(--font-size-sm, 0.875rem);
    font-weight: var(--font-weight-medium, 500);
    color: var(--color-text, #0a0a0a);
    line-height: var(--line-height-snug, 1.3);
    margin: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .search-drawer__product-price {
    font-size: var(--font-size-sm, 0.875rem);
    color: var(--color-text-muted, #555);
    margin: 2px 0 0 0;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .search-drawer__product-compare-price {
    text-decoration: line-through;
    color: var(--color-text-disabled, #aaa);
    font-size: var(--font-size-xs, 0.75rem);
  }

  .search-drawer__product-vendor {
    font-size: var(--font-size-xs, 0.75rem);
    color: var(--color-text-disabled, #aaa);
    margin: 2px 0 0 0;
  }

  /* --- Link list (articles, pages) --- */
  .search-drawer__link-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .search-drawer__link-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 8px;
    border-radius: var(--theme-radius-card, 0);
    text-decoration: none;
    color: var(--color-text, #0a0a0a);
    font-size: var(--font-size-sm, 0.875rem);
    transition: background-color var(--duration-fast, 150ms) var(--ease-standard, ease);
  }

  .search-drawer__link-item:hover {
    background-color: var(--color-bg-subtle, #f5f5f5);
  }

  .search-drawer__link-item:focus-visible {
    outline: 2px solid var(--color-focus, #0a0a0a);
    outline-offset: -2px;
  }

  .search-drawer__link-icon {
    flex-shrink: 0;
    color: var(--color-text-disabled, #aaa);
  }

  /* --- View all --- */
  .search-drawer__view-all {
    padding: 12px 24px 16px;
    border-block-start: 1px solid var(--color-border, #e0e0e0);
    margin-top: 8px;
  }

  .search-drawer__view-all-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: var(--font-size-sm, 0.875rem);
    font-weight: var(--font-weight-medium, 500);
    color: var(--color-accent, #0a0a0a);
    text-decoration: none;
    transition: gap var(--duration-fast, 150ms) var(--ease-standard, ease);
  }

  .search-drawer__view-all-link:hover {
    gap: 10px;
  }

  .search-drawer__view-all-link:focus-visible {
    outline: 2px solid var(--color-focus, #0a0a0a);
    outline-offset: 2px;
    border-radius: var(--radius-sm, 4px);
  }

  /* --- Mobile --- */
  @media screen and (max-width: 749px) {
    .search-drawer__panel {
      max-height: 100vh;
      max-height: 100dvh;
      border-radius: 0;
    }

    .search-drawer__header {
      padding: 12px 16px;
    }

    .search-drawer__input-wrapper {
      height: 44px;
      padding: 0 12px;
    }

    .search-drawer__section {
      padding: 8px 16px 16px;
    }

    .search-drawer__empty {
      padding: 32px 16px;
    }

    .search-drawer__view-all {
      padding: 12px 16px 16px;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    var wrapper = document.querySelector('[data-search-drawer]');
    if (!wrapper) return;

    var overlay = wrapper.querySelector('[data-search-drawer-overlay]');
    var panel = wrapper.querySelector('[data-search-drawer-panel]');
    var input = wrapper.querySelector('[data-search-input]');
    var clearBtn = wrapper.querySelector('[data-search-clear]');
    var closeBtn = wrapper.querySelector('[data-search-drawer-close]');
    var form = wrapper.querySelector('[data-search-form]');
    var body = wrapper.querySelector('[data-search-body]');

    /* State containers */
    var emptyEl = wrapper.querySelector('[data-search-empty]');
    var loadingEl = wrapper.querySelector('[data-search-loading]');
    var noResultsEl = wrapper.querySelector('[data-search-no-results]');
    var resultsEl = wrapper.querySelector('[data-search-results]');

    /* Result sections */
    var productsSec = wrapper.querySelector('[data-search-products]');
    var productsList = wrapper.querySelector('[data-search-product-list]');
    var articlesSec = wrapper.querySelector('[data-search-articles]');
    var articlesList = wrapper.querySelector('[data-search-article-list]');
    var pagesSec = wrapper.querySelector('[data-search-pages]');
    var pagesList = wrapper.querySelector('[data-search-page-list]');
    var viewAllLink = wrapper.querySelector('[data-search-view-all]');

    var debounceTimer = null;
    var abortController = null;
    var lastQuery = '';

    /* ===== Open / Close ===== */
    function open() {
      wrapper.classList.add('is-open');
      document.body.style.overflow = 'hidden';
      setTimeout(function () {
        input.focus();
      }, 100);
    }

    function close() {
      wrapper.classList.remove('is-open');
      document.body.style.overflow = '';
      input.value = '';
      lastQuery = '';
      clearBtn.hidden = true;
      showState('empty');

      /* Return focus to trigger */
      var trigger = document.querySelector('[data-search-trigger]');
      if (trigger) trigger.focus();
    }

    /* Global open handler */
    document.addEventListener('click', function (e) {
      var trigger = e.target.closest('[data-search-trigger]');
      if (trigger) {
        e.preventDefault();
        open();
      }
    });

    if (closeBtn) closeBtn.addEventListener('click', close);
    if (overlay) overlay.addEventListener('click', close);

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && wrapper.classList.contains('is-open')) {
        close();
      }
      /* Cmd/Ctrl + K opens search */
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        if (wrapper.classList.contains('is-open')) {
          close();
        } else {
          open();
        }
      }
    });

    /* ===== Input handling ===== */
    input.addEventListener('input', function () {
      var query = input.value.trim();
      clearBtn.hidden = query.length === 0;

      if (query.length < 2) {
        showState('empty');
        lastQuery = '';
        return;
      }

      if (query === lastQuery) return;
      lastQuery = query;

      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(function () {
        fetchResults(query);
      }, 300);
    });

    clearBtn.addEventListener('click', function () {
      input.value = '';
      clearBtn.hidden = true;
      lastQuery = '';
      showState('empty');
      input.focus();
    });

    /* Submit full search */
    form.addEventListener('submit', function (e) {
      var query = input.value.trim();
      if (query.length === 0) {
        e.preventDefault();
        return;
      }
    });

    /* ===== State management ===== */
    function showState(state) {
      emptyEl.hidden = state !== 'empty';
      loadingEl.hidden = state !== 'loading';
      noResultsEl.hidden = state !== 'no-results';
      resultsEl.hidden = state !== 'results';
    }

    /* ===== Predictive Search API ===== */
    async function fetchResults(query) {
      if (abortController) abortController.abort();
      abortController = new AbortController();

      showState('loading');

      var searchUrl = new URL('/search/suggest.json', window.location.origin);
      searchUrl.searchParams.set('q', query);
      searchUrl.searchParams.set('resources[type]', 'product,article,page');
      searchUrl.searchParams.set('resources[limit]', '6');
      searchUrl.searchParams.set('resources[options][unavailable_products]', 'last');

      try {
        var res = await fetch(searchUrl, { signal: abortController.signal });
        var data = await res.json();
        renderResults(data, query);
      } catch (err) {
        if (err.name !== 'AbortError') {
          showState('empty');
        }
      }
    }

    /* ===== Render results ===== */
    function renderResults(data, query) {
      var resources = data.resources || {};
      var results = resources.results || {};
      var products = results.products || [];
      var articles = results.articles || [];
      var pages = results.pages || [];

      var total = products.length + articles.length + pages.length;

      if (total === 0) {
        showState('no-results');
        return;
      }

      /* Products */
      if (products.length > 0) {
        productsSec.hidden = false;
        productsList.innerHTML = products.map(function (p) {
          var imageHtml = '';
          if (p.image) {
            imageHtml = '<div class="search-drawer__product-image">'
              + '<img src="' + getSizedImage(p.image, '112x112') + '" alt="' + escapeHtml(p.title) + '" loading="lazy" width="56" height="56">'
              + '</div>';
          } else {
            imageHtml = '<div class="search-drawer__product-image search-drawer__product-image--placeholder">'
              + '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.5"/><circle cx="8.5" cy="8.5" r="1.5" fill="currentColor"/><path d="M21 15l-5-5L3 21" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>'
              + '</div>';
          }

          var priceHtml = '<p class="search-drawer__product-price">' + p.price + '</p>';
          if (p.compare_at_price_max && p.compare_at_price_max !== '0.00' && p.compare_at_price_max !== p.price) {
            priceHtml = '<p class="search-drawer__product-price">'
              + p.price
              + ' <span class="search-drawer__product-compare-price">' + p.compare_at_price_max + '</span>'
              + '</p>';
          }

          return '<li>'
            + '<a href="' + p.url + '" class="search-drawer__product-item">'
            + imageHtml
            + '<div class="search-drawer__product-info">'
            + '<p class="search-drawer__product-title">' + highlightMatch(p.title, query) + '</p>'
            + priceHtml
            + '</div>'
            + '</a>'
            + '</li>';
        }).join('');
      } else {
        productsSec.hidden = true;
      }

      /* Articles */
      if (articles.length > 0) {
        articlesSec.hidden = false;
        articlesList.innerHTML = articles.map(function (a) {
          return '<li>'
            + '<a href="' + a.url + '" class="search-drawer__link-item">'
            + '<svg class="search-drawer__link-icon" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><path d="M3 3h12v12H3z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M6 7h6M6 10h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>'
            + highlightMatch(a.title, query)
            + '</a>'
            + '</li>';
        }).join('');
      } else {
        articlesSec.hidden = true;
      }

      /* Pages */
      if (pages.length > 0) {
        pagesSec.hidden = false;
        pagesList.innerHTML = pages.map(function (pg) {
          return '<li>'
            + '<a href="' + pg.url + '" class="search-drawer__link-item">'
            + '<svg class="search-drawer__link-icon" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><path d="M4 2h7l4 4v10H4V2z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M11 2v4h4" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>'
            + highlightMatch(pg.title, query)
            + '</a>'
            + '</li>';
        }).join('');
      } else {
        pagesSec.hidden = true;
      }

      /* View all link */
      var viewAllUrl = new URL('/search', window.location.origin);
      viewAllUrl.searchParams.set('q', query);
      viewAllUrl.searchParams.set('type', 'product,article,page');
      viewAllLink.href = viewAllUrl.toString();

      showState('results');
    }

    /* ===== Helpers ===== */
    function escapeHtml(str) {
      var div = document.createElement('div');
      div.textContent = str;
      return div.innerHTML;
    }

    function highlightMatch(text, query) {
      var escaped = escapeHtml(text);
      var words = query.split(/\s+/).filter(function (w) { return w.length > 0; });
      for (const word of words) {
        var regex = new RegExp('(' + word.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + ')', 'gi');
        escaped = escaped.replace(regex, '<mark>$1</mark>');
      }
      return escaped;
    }

    function getSizedImage(url, size) {
      if (!url) return '';
      return url.replace(/(\.[^.]+)$/, '_' + size + '$1');
    }
  })();
{% endjavascript %}


<section class="how-it-works full-width">
  <div class="how-it-works__header" data-animate="fade-up">
    {% if section.settings.tag_text != blank %}
      <span class="how-it-works__tag">{{ section.settings.tag_text }}</span>
    {% endif %}

    {% if section.settings.heading != blank %}
      <h2 class="how-it-works__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    {% if section.settings.description != blank %}
      <p class="how-it-works__description">{{ section.settings.description }}</p>
    {% endif %}
  </div>

  <div class="how-it-works__body">
    <div class="how-it-works__steps" data-animate="fade-up" data-animate-stagger>
      {% for block in section.blocks %}
        {% if block.type == 'step' %}
          <div class="how-it-works__step" {{ block.shopify_attributes }}>
            <div class="how-it-works__timeline">
              <span class="how-it-works__dot"></span>
              {% unless forloop.last %}
                <span class="how-it-works__line"></span>
              {% endunless %}
            </div>

            <div class="how-it-works__step-content">
              <span class="how-it-works__step-badge">
                {{ 'sections.how_it_works.step' | t: number: forloop.index }}
              </span>

              {% if block.settings.title != blank %}
                <h3 class="how-it-works__step-title">{{ block.settings.title }}</h3>
              {% endif %}

              {% if block.settings.description != blank %}
                <p class="how-it-works__step-description">{{ block.settings.description }}</p>
              {% endif %}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <div class="how-it-works__aside" data-animate="fade-up">
      {% if section.settings.side_image %}
        <div class="how-it-works__image">
          {{ section.settings.side_image | image_url: width: 800 | image_tag: loading: 'lazy' }}
        </div>
      {% endif %}

      {% if section.settings.show_upsell %}
        {% assign upsell = section.settings.upsell_product %}
        {% if upsell != blank %}
          <div class="how-it-works__upsell">
            {% if upsell.featured_image %}
              <div class="how-it-works__upsell-image">
                {{ upsell.featured_image | image_url: width: 310, height: 272 | image_tag: loading: 'lazy' }}
              </div>
            {% endif %}

            <div class="how-it-works__upsell-info">
              <div class="how-it-works__upsell-title-row">
                <span class="how-it-works__upsell-title">{{ 'sections.how_it_works.bundle' | t }}</span>
                <span class="how-it-works__upsell-badge">{{ 'sections.how_it_works.save_badge' | t }}</span>
              </div>

              <p class="how-it-works__upsell-subtitle">{{ 'sections.how_it_works.offer_ends' | t }}</p>

              <div class="how-it-works__upsell-price">
                <span class="how-it-works__upsell-price-current">{{ upsell.price | money }}</span>
                {% if upsell.compare_at_price > upsell.price %}
                  <span class="how-it-works__upsell-price-compare">{{ upsell.compare_at_price | money }}</span>
                {% endif %}
              </div>

              <a href="{{ upsell.url }}" class="how-it-works__upsell-button">
                {{ 'sections.how_it_works.add_to_cart' | t }}
              </a>
            </div>
          </div>
        {% endif %}
      {% endif %}
    </div>
  </div>
</section>

{% stylesheet %}
  .how-it-works {
    background-color: var(--theme-surface);
    padding: var(--space-13) 0 3.125rem;
  }

  .how-it-works__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: var(--container-max, 80rem);
    margin: 0 auto;
    padding: 0 var(--container-padding, 16px);
  }

  .how-it-works__tag {
    display: inline-block;
    background-color: var(--theme-surface-alt);
    color: var(--theme-primary);
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wider);
    padding: 6px var(--space-4);
    border-radius: var(--theme-radius-badge);
    margin-bottom: var(--space-4);
  }

  .how-it-works__heading {
    font-size: var(--font-size-5xl);
    line-height: var(--line-height-tight);
    font-weight: var(--font-weight-bold);
    color: var(--theme-primary);
    margin-bottom: var(--space-4);
  }

  .how-it-works__description {
    font-size: var(--font-size-base);
    color: var(--theme-text-secondary);
    max-width: 502px;
    line-height: var(--line-height-normal);
  }

  .how-it-works__body {
    display: flex;
    gap: var(--space-6);
    max-width: var(--container-max, 80rem);
    margin: var(--space-13) auto 0;
    padding: 0 var(--container-padding, 16px);
  }

  .how-it-works__steps {
    flex: 0 0 576px;
    max-width: 576px;
    display: flex;
    flex-direction: column;
  }

  .how-it-works__step {
    display: flex;
    gap: var(--space-4);
    padding-bottom: var(--space-6);
  }

  .how-it-works__step:last-child {
    padding-bottom: 0;
  }

  .how-it-works__timeline {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
    width: 20px;
    padding-top: var(--space-1);
  }

  .how-it-works__dot {
    display: block;
    width: 20px;
    height: 20px;
    border-radius: var(--radius-round);
    background-color: var(--theme-accent);
    flex-shrink: 0;
  }

  .how-it-works__line {
    display: block;
    width: 0;
    flex: 1;
    border-inline-start: 1px dashed color-mix(in srgb, var(--theme-primary) 25%, transparent);
    margin-top: var(--space-1);
  }

  .how-it-works__step-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .how-it-works__step-badge {
    display: inline-block;
    background-color: var(--theme-accent);
    color: var(--theme-text-on-accent);
    font-size: var(--font-size-sm);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wider);
    padding: var(--space-1) 14px;
    border-radius: var(--theme-radius-badge);
    align-self: flex-start;
  }

  .how-it-works__step-title {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wider);
    color: var(--theme-primary);
  }

  .how-it-works__step-description {
    font-size: var(--font-size-base);
    color: var(--theme-text-secondary);
    line-height: var(--line-height-normal);
  }

  .how-it-works__aside {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .how-it-works__image {
    border-radius: var(--theme-radius-image);
    overflow: hidden;
    height: 396px;
  }

  .how-it-works__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .how-it-works__upsell {
    display: flex;
    gap: var(--space-4);
    background-color: var(--theme-surface-alt);
    border-radius: var(--theme-radius-card);
    padding: var(--space-2) var(--space-4) var(--space-2) var(--space-2);
    align-items: center;
  }

  .how-it-works__upsell-image {
    flex-shrink: 0;
    width: 155px;
    height: 136px;
    border-radius: var(--theme-radius-image);
    overflow: hidden;
  }

  .how-it-works__upsell-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .how-it-works__upsell-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    flex: 1;
  }

  .how-it-works__upsell-title-row {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .how-it-works__upsell-title {
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-semibold);
  }

  .how-it-works__upsell-badge {
    display: inline-block;
    background-color: var(--theme-accent);
    color: var(--theme-text-on-accent);
    font-size: var(--font-size-xs);
    padding: var(--space-1) var(--space-2);
    border-radius: var(--theme-radius-badge);
    white-space: nowrap;
  }

  .how-it-works__upsell-subtitle {
    font-size: var(--font-size-sm);
    color: var(--theme-text-secondary);
  }

  .how-it-works__upsell-price {
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
  }

  .how-it-works__upsell-price-current {
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-bold);
  }

  .how-it-works__upsell-price-compare {
    font-size: var(--font-size-xs);
    color: var(--theme-text-secondary);
    text-decoration: line-through;
  }

  .how-it-works__upsell-button {
    display: inline-block;
    background-color: var(--theme-primary);
    color: var(--theme-text-on-primary);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    text-decoration: none;
    text-align: center;
    padding: var(--space-2) var(--space-6);
    border-radius: var(--theme-radius-button);
    margin-top: var(--space-1);
    align-self: flex-start;
  }

  @media screen and (max-width: 749px) {
    .how-it-works__heading {
      font-size: var(--font-size-3xl);
    }

    .how-it-works__body {
      flex-direction: column;
    }

    .how-it-works__steps {
      flex: 1;
      max-width: 100%;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.how_it_works.name",
  "settings": [
    {
      "type": "text",
      "id": "tag_text",
      "label": "t:sections.how_it_works.settings.tag_text",
      "default": "HOW IT WORK"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "This is how Hydrogen Water Can Help You!"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "t:labels.description"
    },
    {
      "type": "image_picker",
      "id": "side_image",
      "label": "t:sections.how_it_works.settings.side_image"
    },
    {
      "type": "checkbox",
      "id": "show_upsell",
      "label": "t:sections.how_it_works.settings.show_upsell",
      "default": true
    },
    {
      "type": "product",
      "id": "upsell_product",
      "label": "t:sections.how_it_works.settings.upsell_product"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "t:sections.how_it_works.blocks.step.name",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "t:labels.title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "t:labels.description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.how_it_works.name",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "title": "Push the bottle",
            "description": "Simply press the button on your hydrogen water bottle to start the electrolysis process."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Wait for the process",
            "description": "The SPE/PEM technology infuses your water with molecular hydrogen in just minutes."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Enjoy hydrogen water",
            "description": "Drink your freshly hydrogenated water and enjoy the antioxidant benefits."
          }
        }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}

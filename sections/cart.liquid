{%- comment -%}
  Cart Page — full-page cart with line items, upsell products, and checkout.
  Mirrors the cart-drawer design but as a standalone page at /cart.
{%- endcomment -%}

<section class="cart-page full-width">
  <div class="cart-page__container">

    {%- comment -%} Top announcement banner {%- endcomment -%}
    {% if section.settings.show_free_shipping_bar %}
      {%- assign fs_threshold_banner = section.settings.free_shipping_threshold | times: 100 -%}
      {%- assign fs_cart_total_banner = cart.total_price -%}
      <div class="cart-page__announcement">
        <p class="cart-page__announcement-text">
          {%- if fs_cart_total_banner >= fs_threshold_banner -%}
            {{ 'cart.free_shipping_success' | t }}
          {%- else -%}
            {%- assign fs_remaining_banner = fs_threshold_banner | minus: fs_cart_total_banner -%}
            {{ 'cart.free_shipping_remaining' | t: amount: fs_remaining_banner | money }}
          {%- endif -%}
        </p>
      </div>
    {% endif %}

    {%- comment -%} Header {%- endcomment -%}
    <div class="cart-page__header">
      <h1 class="cart-page__heading">{{ 'cart.title' | t }}</h1>
    </div>

      {%- comment -%} Free shipping progress bar {%- endcomment -%}
      {% if section.settings.show_free_shipping_bar %}
        {%- assign free_shipping_threshold = section.settings.free_shipping_threshold | times: 100 -%}
        {%- assign cart_total = cart.total_price -%}
        {%- if cart_total >= free_shipping_threshold -%}
          {%- assign shipping_progress = 100 -%}
        {%- else -%}
          {%- assign shipping_progress = cart_total | times: 100 | divided_by: free_shipping_threshold -%}
        {%- endif -%}
        <div class="cart-page__shipping-bar" data-cart-page-shipping-bar>
          <p class="cart-page__shipping-text" data-cart-page-shipping-text>
            {%- if cart_total >= free_shipping_threshold -%}
              {{ 'cart.free_shipping_success' | t }}
            {%- else -%}
              {%- assign remaining = free_shipping_threshold | minus: cart_total -%}
              {{ 'cart.free_shipping_remaining' | t: amount: remaining | money }}
            {%- endif -%}
          </p>
          <div class="cart-page__progress-track">
            <div class="cart-page__progress-fill" style="--progress: {{ shipping_progress }}%" data-cart-page-shipping-fill></div>
            <div class="cart-page__progress-icon" style="--progress: {{ shipping_progress }}%" data-cart-page-shipping-icon>
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <rect width="24" height="24" rx="12" fill="var(--theme-accent)"/>
                <rect x="2" y="2" width="20" height="20" rx="10" stroke="var(--theme-primary)" stroke-width="2"/>
                <path d="M8 9H16V15H8V9Z" stroke="var(--theme-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M10 15V16.5" stroke="var(--theme-primary)" stroke-width="1.5" stroke-linecap="round"/>
                <path d="M14 15V16.5" stroke="var(--theme-primary)" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </div>
          </div>
        </div>
      {% endif %}

      <div class="cart-page__layout">
        {%- comment -%} Cart items {%- endcomment -%}
        <div class="cart-page__items" data-cart-page-items>
          {% if cart.item_count > 0 %}
            {% for item in cart.items %}
              <div class="cart-page__item" data-cart-page-item data-line-key="{{ item.key }}">
                <a href="{{ item.url }}" class="cart-page__item-image">
                  {% if item.image %}
                    {{ item.image | image_url: width: 310 | image_tag: class: 'cart-page__item-img', loading: 'lazy' }}
                  {% else %}
                    {{ 'product-1' | placeholder_svg_tag: 'cart-page__item-placeholder' }}
                  {% endif %}
                </a>
                <div class="cart-page__item-details">
                  <div class="cart-page__item-left">
                    <div class="cart-page__item-info">
                      <a href="{{ item.url }}" class="cart-page__item-title">{{ item.product.title }}</a>
                      {% if item.variant.title != 'Default Title' %}
                        <p class="cart-page__item-variant">{{ item.variant.title }}</p>
                      {% endif %}
                    </div>
                    <div class="cart-page__quantity" data-cart-page-quantity>
                      <button
                        class="cart-page__quantity-btn"
                        data-cart-page-minus
                        aria-label="{{ 'cart.decrease_quantity' | t }}"
                      >
                        {{ 'icon-minus.svg' | inline_asset_content }}
                      </button>
                      <span class="cart-page__quantity-value" data-cart-page-qty-value>{{ item.quantity }}</span>
                      <button
                        class="cart-page__quantity-btn"
                        data-cart-page-plus
                        aria-label="{{ 'cart.increase_quantity' | t }}"
                      >
                        {{ 'icon-plus.svg' | inline_asset_content }}
                      </button>
                    </div>
                  </div>
                  <div class="cart-page__item-right">
                    <button
                      class="cart-page__remove-btn"
                      data-cart-page-remove
                      aria-label="{{ 'cart.remove' | t }}: {{ item.product.title }}"
                    >
                      {{ 'icon-trash.svg' | inline_asset_content }}
                    </button>
                    <div class="cart-page__item-prices">
                      {%- assign compare_line = item.variant.compare_at_price | default: 0 | times: item.quantity -%}
                      {%- assign has_compare = false -%}
                      {%- if compare_line > item.final_line_price -%}
                        {%- assign has_compare = true -%}
                        {%- assign display_compare = compare_line -%}
                      {%- elsif item.original_line_price > item.final_line_price -%}
                        {%- assign has_compare = true -%}
                        {%- assign display_compare = item.original_line_price -%}
                      {%- endif -%}
                      <div class="cart-page__item-price-row">
                        {% if has_compare %}
                          <span class="cart-page__item-compare-price">{{ display_compare | money }}</span>
                        {% endif %}
                        <span class="cart-page__item-price">{{ item.final_line_price | money }}</span>
                      </div>
                      {% if has_compare %}
                        {%- assign item_savings = display_compare | minus: item.final_line_price | money -%}
                        <span class="cart-page__item-savings">({{ 'cart.save_label' | t: amount: item_savings }})</span>
                      {% endif %}
                      {% for discount in item.discount_allocations %}
                        <span class="cart-page__item-discount-badge">
                          {{ 'icon-discount-tag.svg' | inline_asset_content }}
                          <span>{{ discount.discount_application.title }}</span>
                        </span>
                      {% endfor %}
                    </div>
                  </div>
                </div>
              </div>
            {% endfor %}
          {% else %}
            {%- comment -%} Fallback placeholder items for visualization {%- endcomment -%}
            {% for i in (1..2) %}
              <div class="cart-page__item">
                <div class="cart-page__item-image">
                  {{ 'product-' | append: i | placeholder_svg_tag: 'cart-page__item-placeholder' }}
                </div>
                <div class="cart-page__item-details">
                  <div class="cart-page__item-left">
                    <div class="cart-page__item-info">
                      <span class="cart-page__item-title">{{ 'cart.fallback_product_title' | t }}</span>
                      <p class="cart-page__item-variant">{{ 'cart.fallback_variant' | t }}</p>
                    </div>
                    <div class="cart-page__quantity">
                      <button class="cart-page__quantity-btn" disabled>
                        {{ 'icon-minus.svg' | inline_asset_content }}
                      </button>
                      <span class="cart-page__quantity-value">1</span>
                      <button class="cart-page__quantity-btn" disabled>
                        {{ 'icon-plus.svg' | inline_asset_content }}
                      </button>
                    </div>
                  </div>
                  <div class="cart-page__item-right">
                    <button class="cart-page__remove-btn" disabled>
                      {{ 'icon-trash.svg' | inline_asset_content }}
                    </button>
                    <div class="cart-page__item-prices">
                      <div class="cart-page__item-price-row">
                        <span class="cart-page__item-compare-price">$59.99</span>
                        <span class="cart-page__item-price">$39.99</span>
                      </div>
                      <span class="cart-page__item-savings">({{ 'cart.save_label' | t: amount: '$20.00' }})</span>
                      <span class="cart-page__item-discount-badge">
                        {{ 'icon-discount-tag.svg' | inline_asset_content }}
                        <span>SAVE20</span>
                      </span>
                    </div>
                  </div>
                </div>
              </div>
            {% endfor %}
          {% endif %}
        </div>

        {%- comment -%} Sidebar: summary + upsell {%- endcomment -%}
        <div class="cart-page__sidebar">
          {%- comment -%} Order summary {%- endcomment -%}
          <div class="cart-page__summary">
            {%- comment -%} Promo code input {%- endcomment -%}
            <div class="cart-page__promo" data-cart-page-promo>
              <input
                type="text"
                class="cart-page__promo-input"
                placeholder="{{ 'cart.promo_code' | t }}"
                data-cart-page-promo-input
                aria-label="{{ 'cart.promo_code' | t }}"
              >
              <button class="cart-page__promo-apply" data-cart-page-promo-apply>
                {{ 'cart.apply' | t }}
              </button>
            </div>

            {%- comment -%} Checkout+ protection {%- endcomment -%}
            {% if section.settings.show_checkout_protection %}
              <div class="cart-page__protection" data-cart-page-protection>
                <div class="cart-page__protection-icon">
                  {{ 'icon-box.svg' | inline_asset_content }}
                </div>
                <div class="cart-page__protection-info">
                  <div class="cart-page__protection-title-row">
                    <span class="cart-page__protection-title">{{ section.settings.checkout_protection_title }}</span>
                    {{ 'icon-warning.svg' | inline_asset_content }}
                  </div>
                  <p class="cart-page__protection-desc">{{ section.settings.checkout_protection_description }}</p>
                </div>
                <label class="cart-page__protection-toggle">
                  <input
                    type="checkbox"
                    data-cart-page-protection-checkbox
                    {% unless cart.attributes.checkout_protection == '' %}checked{% endunless %}
                    aria-label="{{ section.settings.checkout_protection_title }}"
                  >
                  <span class="cart-page__protection-checkbox">
                    {{ 'icon-checkbox.svg' | inline_asset_content }}
                  </span>
                </label>
              </div>
            {% endif %}

            <div class="cart-page__subtotal">
              <span class="cart-page__subtotal-label">{{ 'cart.subtotal' | t }}</span>
              <div class="cart-page__subtotal-right">
                {% if cart.item_count > 0 %}
                  {% if cart.original_total_price > cart.total_price %}
                    {%- assign total_savings = cart.original_total_price | minus: cart.total_price -%}
                    {%- assign savings_pct = total_savings | times: 100 | divided_by: cart.original_total_price -%}
                    <span class="cart-page__savings-badge">
                      {{ 'cart.save_percent' | t: percent: savings_pct }}
                    </span>
                  {% endif %}
                  <span class="cart-page__subtotal-price" data-cart-page-subtotal>{{ cart.total_price | money }}</span>
                {% else %}
                  <span class="cart-page__savings-badge">
                    {{ 'cart.save_percent' | t: percent: 33 }}
                  </span>
                  <span class="cart-page__subtotal-price" data-cart-page-subtotal>$79.98</span>
                {% endif %}
              </div>
            </div>

            <a href="{{ routes.cart_url }}/checkout" class="cart-page__checkout-btn">
              {{ 'cart.checkout' | t }}
            </a>

            <a href="{{ routes.all_products_collection_url }}" class="cart-page__continue-btn">
              {{ 'cart.continue_shopping' | t }}
            </a>

            {%- comment -%} Trust badges {%- endcomment -%}
            <div class="cart-page__trust-row">
              <div class="cart-page__trust-badge">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <rect x="1" y="1" width="14" height="14" rx="3" stroke="var(--theme-primary)" stroke-width="1.2"/>
                  <text x="8" y="11" text-anchor="middle" font-size="7" font-weight="600" fill="var(--theme-primary)">30</text>
                </svg>
                <span>{{ 'cart.money_back_guarantee' | t }}</span>
              </div>
              <div class="cart-page__trust-badge">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M8 1L10 5.5L15 6.2L11.5 9.5L12.3 14.5L8 12.2L3.7 14.5L4.5 9.5L1 6.2L6 5.5L8 1Z" fill="var(--theme-star)"/>
                </svg>
                <span>{{ 'cart.happy_customers' | t }}</span>
              </div>
            </div>
          </div>

          {%- comment -%} Upsell products (Swiper slider) {%- endcomment -%}
          {% render 'swiper-loader' %}
          {% if section.settings.upsell_collection != blank %}
            {%- assign upsell_products_page = section.settings.upsell_collection.products -%}
          {% endif %}

          {% if upsell_products_page != blank and upsell_products_page.size > 0 %}
            <div class="cart-page__upsell" data-cart-page-upsell>
              <div class="cart-page__upsell-top">
                <h3 class="cart-page__upsell-heading">{{ section.settings.upsell_heading }}</h3>
                <div class="cart-page__upsell-nav">
                  <button class="cart-page__upsell-nav-btn" data-page-upsell-prev aria-label="{{ 'cart.decrease_quantity' | t }}">
                    <svg width="7" height="12" viewBox="0 0 7 12" fill="none" aria-hidden="true"><path d="M6 1L1 6L6 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </button>
                  <button class="cart-page__upsell-nav-btn" data-page-upsell-next aria-label="{{ 'cart.increase_quantity' | t }}">
                    <svg width="7" height="12" viewBox="0 0 7 12" fill="none" aria-hidden="true"><path d="M1 1L6 6L1 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </button>
                </div>
              </div>
              <div class="swiper cart-page__upsell-swiper" data-cart-page-upsell-swiper>
                <div class="swiper-wrapper">
                  {% for product in upsell_products_page limit: 8 %}
                    <div class="swiper-slide">
                      <article class="cart-page__upsell-card" data-cart-page-upsell-card>
                        <div class="cart-page__upsell-image">
                          {% if product.featured_image %}
                            {{ product.featured_image | image_url: width: 200, height: 200 | image_tag: class: 'cart-page__upsell-img', loading: 'lazy' }}
                          {% else %}
                            <div class="cart-page__upsell-placeholder">
                              {{ 'product-1' | placeholder_svg_tag }}
                            </div>
                          {% endif %}
                        </div>
                        <div class="cart-page__upsell-info">
                          <h4 class="cart-page__upsell-title">
                            <a href="{{ product.url }}">{{ product.title }}</a>
                          </h4>
                          <div class="cart-page__upsell-prices">
                            <span class="cart-page__upsell-price">{{ product.price | money }}</span>
                            {% if product.compare_at_price > product.price %}
                              <span class="cart-page__upsell-compare">{{ product.compare_at_price | money }}</span>
                            {% endif %}
                          </div>
                        </div>
                        <button
                          class="cart-page__upsell-atc"
                          data-cart-page-upsell-atc
                          data-variant-id="{{ product.selected_or_first_available_variant.id }}"
                          {% unless product.available %}disabled{% endunless %}
                          aria-label="{{ 'products.add_to_cart' | t }}"
                        >
                          {% if product.available %}
                            {{ 'products.add_to_cart' | t }}
                          {% else %}
                            {{ 'products.sold_out' | t }}
                          {% endif %}
                        </button>
                      </article>
                    </div>
                  {% endfor %}
                </div>
              </div>
            </div>
          {% else %}
            {%- comment -%} Fallback placeholder upsell cards for visualization {%- endcomment -%}
            <div class="cart-page__upsell" data-cart-page-upsell>
              <div class="cart-page__upsell-top">
                <h3 class="cart-page__upsell-heading">{{ section.settings.upsell_heading | default: 'You may also like' }}</h3>
                <div class="cart-page__upsell-nav">
                  <button class="cart-page__upsell-nav-btn" data-page-upsell-prev aria-label="{{ 'cart.decrease_quantity' | t }}">
                    <svg width="7" height="12" viewBox="0 0 7 12" fill="none" aria-hidden="true"><path d="M6 1L1 6L6 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </button>
                  <button class="cart-page__upsell-nav-btn" data-page-upsell-next aria-label="{{ 'cart.increase_quantity' | t }}">
                    <svg width="7" height="12" viewBox="0 0 7 12" fill="none" aria-hidden="true"><path d="M1 1L6 6L1 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </button>
                </div>
              </div>
              <div class="swiper cart-page__upsell-swiper" data-cart-page-upsell-swiper>
                <div class="swiper-wrapper">
                  {% for i in (1..3) %}
                    <div class="swiper-slide">
                      <article class="cart-page__upsell-card">
                        <div class="cart-page__upsell-image">
                          <div class="cart-page__upsell-placeholder">
                            {{ 'product-' | append: i | placeholder_svg_tag }}
                          </div>
                        </div>
                        <div class="cart-page__upsell-info">
                          <h4 class="cart-page__upsell-title">{{ 'cart.fallback_product_title' | t }}</h4>
                          <div class="cart-page__upsell-prices">
                            <span class="cart-page__upsell-price">$29.99</span>
                            <span class="cart-page__upsell-compare">$39.99</span>
                          </div>
                        </div>
                        <button class="cart-page__upsell-atc" disabled>
                          {{ 'products.add_to_cart' | t }}
                        </button>
                      </article>
                    </div>
                  {% endfor %}
                </div>
              </div>
            </div>
          {% endif %}
        </div>
      </div>

  </div>
</section>

{% stylesheet %}
  .cart-page {
    background-color: var(--color-bg, #fff);
    padding: 48px 0 80px;
  }

  .cart-page__container {
    max-width: var(--container-max, 1200px);
    margin: 0 auto;
    padding: 0 var(--container-padding, 24px);
  }

  /* --- Top announcement banner --- */
  .cart-page__announcement {
    background-color: var(--theme-primary);
    margin: 0 calc(-1 * var(--container-padding, 24px)) 32px;
    padding: 14px 24px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .cart-page__announcement-text {
    font-size: var(--font-size-xl);
    line-height: var(--line-height-snug);
    color: var(--theme-text-on-primary);
    margin: 0;
    text-align: center;
  }

  /* --- Header --- */
  .cart-page__header {
    margin-bottom: 32px;
  }

  .cart-page__heading {
    font-size: var(--font-size-4xl, 2.25rem);
    line-height: var(--line-height-tight, 1.2);
    letter-spacing: var(--letter-spacing-tighter, -0.02em);
    color: var(--color-text, #0a0a0a);
    margin: 0;
  }

  /* --- Free shipping bar --- */
  .cart-page__shipping-bar {
    background-color: var(--theme-surface-alt);
    border-radius: var(--radius-xl);
    padding: 16px 16px 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
    margin-bottom: 32px;
  }

  .cart-page__shipping-text {
    font-size: var(--font-size-xl);
    line-height: var(--line-height-snug);
    color: var(--theme-text);
    margin: 0;
    text-align: center;
  }

  .cart-page__progress-track {
    position: relative;
    width: 100%;
    height: 12px;
    background-color: var(--theme-primary);
    border-radius: var(--theme-radius-badge);
    overflow: visible;
  }

  .cart-page__progress-fill {
    position: absolute;
    inset-block-start: 0;
    inset-inline-start: 0;
    height: 100%;
    width: var(--progress, 0%);
    max-width: 100%;
    background-color: var(--theme-primary);
    border-radius: var(--theme-radius-badge);
    transition: width var(--duration-medium, 300ms) var(--ease-standard, ease);
  }

  .cart-page__progress-icon {
    position: absolute;
    inset-block-start: 50%;
    inset-inline-start: var(--progress, 0%);
    transform: translate(-50%, -50%);
    transition: inset-inline-start var(--duration-medium, 300ms) var(--ease-standard, ease);
  }

  /* --- Layout: items + sidebar --- */
  .cart-page__layout {
    display: grid;
    grid-template-columns: 1fr 400px;
    gap: 40px;
    align-items: start;
  }

  /* --- Cart items --- */
  .cart-page__items {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .cart-page__item {
    display: flex;
    gap: 16px;
    padding: 16px 24px 16px 16px;
    border-radius: var(--radius-3xl);
    background-color: var(--theme-surface-alt);
  }

  .cart-page__item-image {
    width: 155px;
    height: 136px;
    flex-shrink: 0;
    border-radius: var(--radius-xl);
    overflow: hidden;
    background-color: var(--theme-surface-alt);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .cart-page__item-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .cart-page__item-placeholder {
    width: 60%;
    height: auto;
    opacity: 0.4;
  }

  .cart-page__item-details {
    flex: 1;
    min-width: 0;
    display: flex;
    gap: 12px;
  }

  .cart-page__item-left {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: flex-start;
  }

  .cart-page__item-right {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    justify-content: space-between;
  }

  .cart-page__item-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .cart-page__item-title {
    font-size: var(--font-size-2xl);
    line-height: var(--line-height-snug);
    letter-spacing: var(--letter-spacing-tighter);
    color: var(--theme-text);
    text-decoration: none;
    font-weight: var(--font-weight-regular);
  }

  .cart-page__item-title:hover {
    text-decoration: underline;
  }

  .cart-page__item-title:focus-visible {
    outline: 2px solid var(--color-focus, var(--theme-primary));
    outline-offset: 2px;
    border-radius: var(--radius-sm);
  }

  .cart-page__item-variant {
    font-size: var(--font-size-sm);
    line-height: var(--line-height-snug);
    color: var(--theme-text-secondary);
    margin: 0;
  }

  .cart-page__item-prices {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 4px;
  }

  .cart-page__item-price-row {
    display: flex;
    align-items: center;
    gap: 2px;
  }

  .cart-page__item-compare-price {
    font-size: var(--font-size-xs);
    line-height: var(--line-height-tight);
    color: var(--theme-text-dim);
    text-decoration: line-through;
    text-align: end;
  }

  .cart-page__item-price {
    font-size: var(--font-size-xl);
    line-height: var(--line-height-snug);
    color: var(--theme-text);
  }

  /* Quantity selector */
  .cart-page__quantity {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px;
    background-color: var(--theme-surface-alt);

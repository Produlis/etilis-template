{%- comment -%}
  Cart Page — full-page cart with line items, upsell products, and checkout.
  Mirrors the cart-drawer design but as a standalone page at /cart.
{%- endcomment -%}

<section class="cart-page full-width">
  <div class="cart-page__container">

    {%- comment -%} Top announcement banner {%- endcomment -%}
    {% if section.settings.show_free_shipping_bar %}
      {%- assign fs_threshold_banner = section.settings.free_shipping_threshold | times: 100 -%}
      {%- assign fs_cart_total_banner = cart.total_price -%}
      <div class="cart-page__announcement">
        <p class="cart-page__announcement-text">
          {%- if fs_cart_total_banner >= fs_threshold_banner -%}
            {{ 'cart.free_shipping_success' | t }}
          {%- else -%}
            {%- assign fs_remaining_banner = fs_threshold_banner | minus: fs_cart_total_banner -%}
            {{ 'cart.free_shipping_remaining' | t: amount: fs_remaining_banner | money }}
          {%- endif -%}
        </p>
      </div>
    {% endif %}

    {%- comment -%} Header {%- endcomment -%}
    <div class="cart-page__header">
      <h1 class="cart-page__heading">
        {{ 'cart.title' | t }}
        {% if cart.item_count > 0 %}
          <span class="cart-page__count" data-cart-page-count>{{ cart.item_count }}</span>
        {% endif %}
      </h1>
    </div>


      <div class="cart-page__layout">
        {%- comment -%} Cart items {%- endcomment -%}
        <div class="cart-page__items" data-cart-page-items>
          {% if cart.item_count > 0 %}
            {% for item in cart.items %}
              <div class="cart-page__item" data-cart-page-item data-line-key="{{ item.key }}">
                <a href="{{ item.url }}" class="cart-page__item-image">
                  {% if item.image %}
                    {{ item.image | image_url: width: 310 | image_tag: class: 'cart-page__item-img', loading: 'lazy' }}
                  {% else %}
                    {% render 'placeholder-image' %}
                  {% endif %}
                </a>
                <div class="cart-page__item-details">
                  <div class="cart-page__item-left">
                    <div class="cart-page__item-info">
                      <a href="{{ item.url }}" class="cart-page__item-title">{{ item.product.title }}</a>
                      {% if item.variant.title != 'Default Title' %}
                        <p class="cart-page__item-variant">{{ item.variant.title }}</p>
                      {% endif %}
                    </div>
                    <div class="cart-page__qty-row">
                      <div class="cart-page__quantity" data-cart-page-quantity>
                        <button
                          class="cart-page__quantity-btn"
                          data-cart-page-minus
                          aria-label="{{ 'cart.decrease_quantity' | t }}"
                        >
                          {{ 'icon-minus.svg' | inline_asset_content }}
                        </button>
                        <span class="cart-page__quantity-value" data-cart-page-qty-value>{{ item.quantity }}</span>
                        <button
                          class="cart-page__quantity-btn"
                          data-cart-page-plus
                          aria-label="{{ 'cart.increase_quantity' | t }}"
                        >
                          {{ 'icon-plus.svg' | inline_asset_content }}
                        </button>
                      </div>
                      <button
                        class="cart-page__remove-btn"
                        data-cart-page-remove
                        aria-label="{{ 'cart.remove' | t }}: {{ item.product.title }}"
                      >
                        {{ 'icon-trash.svg' | inline_asset_content }}
                      </button>
                    </div>
                  </div>
                  <div class="cart-page__item-right">
                    <div class="cart-page__item-prices">
                      {%- assign compare_line = item.variant.compare_at_price | default: 0 | times: item.quantity -%}
                      {%- assign has_compare = false -%}
                      {%- if compare_line > item.final_line_price -%}
                        {%- assign has_compare = true -%}
                        {%- assign display_compare = compare_line -%}
                      {%- elsif item.original_line_price > item.final_line_price -%}
                        {%- assign has_compare = true -%}
                        {%- assign display_compare = item.original_line_price -%}
                      {%- endif -%}
                      <div class="cart-page__item-price-row">
                        {% if has_compare %}
                          <span class="cart-page__item-compare-price">{{ display_compare | money }}</span>
                        {% endif %}
                        <span class="cart-page__item-price">{{ item.final_line_price | money }}</span>
                      </div>
                      {% if has_compare %}
                        {%- assign item_savings = display_compare | minus: item.final_line_price | money -%}
                        <span class="cart-page__item-savings">({{ 'cart.save_label' | t: amount: item_savings }})</span>
                      {% endif %}
                      {% for discount in item.discount_allocations %}
                        <span class="cart-page__item-discount-badge">
                          {{ 'icon-discount-tag.svg' | inline_asset_content }}
                          <span>{{ discount.discount_application.title }}</span>
                        </span>
                      {% endfor %}
                    </div>
                  </div>
                </div>
              </div>
            {% endfor %}
          {% else %}
            <div class="cart-page__empty">
              <svg class="cart-page__empty-icon" width="48" height="48" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M3 6h18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M16 10a4 4 0 01-8 0" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <h2 class="cart-page__empty-title">{{ 'cart.empty' | t }}</h2>
              <a href="{{ routes.all_products_collection_url }}" class="cart-page__empty-btn">
                {{ 'cart.continue_shopping' | t }}
              </a>
            </div>
          {% endif %}
        </div>

        {%- comment -%} Sidebar: summary + upsell {%- endcomment -%}
        <div class="cart-page__sidebar"{% if cart.item_count == 0 %} hidden{% endif %}>
          {%- comment -%} Order summary {%- endcomment -%}
          <div class="cart-page__summary">
            {%- comment -%} Promo code input {%- endcomment -%}
            <div class="cart-page__promo" data-cart-page-promo>
              <input
                type="text"
                class="cart-page__promo-input"
                placeholder="{{ 'cart.promo_code' | t }}"
                data-cart-page-promo-input
                aria-label="{{ 'cart.promo_code' | t }}"
              >
              <button class="cart-page__promo-apply" data-cart-page-promo-apply>
                {{ 'cart.apply' | t }}
              </button>
            </div>


            <div class="cart-page__subtotal">
              <span class="cart-page__subtotal-label">{{ 'cart.subtotal' | t }}</span>
              <div class="cart-page__subtotal-right">
                {% if cart.item_count > 0 %}
                  {% if cart.original_total_price > cart.total_price %}
                    {%- assign total_savings = cart.original_total_price | minus: cart.total_price -%}
                    {%- assign savings_pct = total_savings | times: 100 | divided_by: cart.original_total_price -%}
                    <span class="cart-page__savings-badge">
                      {{ 'cart.save_percent' | t: percent: savings_pct }}
                    </span>
                  {% endif %}
                  <span class="cart-page__subtotal-price" data-cart-page-subtotal>{{ cart.total_price | money }}</span>
                {% else %}
                  <span class="cart-page__savings-badge">
                    {{ 'cart.save_percent' | t: percent: 33 }}
                  </span>
                  <span class="cart-page__subtotal-price" data-cart-page-subtotal>$79.98</span>
                {% endif %}
              </div>
            </div>

            <a href="{{ routes.cart_url }}/checkout" class="cart-page__checkout-btn">
              {{ 'cart.checkout' | t }}
            </a>

            <a href="{{ routes.all_products_collection_url }}" class="cart-page__continue-btn">
              {{ 'cart.continue_shopping' | t }}
            </a>

          </div>
        </div>
      </div>

  </div>
</section>

{% stylesheet %}
  .cart-page {
    background-color: var(--color-bg, #fff);
    padding: var(--space-12) 0 var(--space-20);
  }

  .cart-page__container {
    max-width: var(--container-max, 1200px);
    margin: 0 auto;
    padding: 0 var(--container-padding, 24px);
  }

  /* --- Top announcement banner --- */
  .cart-page__announcement {
    background-color: var(--theme-primary);
    margin: 0 calc(-1 * var(--container-padding, 24px)) var(--space-8);
    padding: 14px var(--space-6);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .cart-page__announcement-text {
    font-size: var(--font-size-xl);
    line-height: var(--line-height-snug);
    color: var(--theme-text-on-primary);
    margin: 0;
    text-align: center;
  }

  /* --- Header --- */
  .cart-page__header {
    margin-bottom: var(--space-8);
  }

  .cart-page__heading {
    font-size: var(--font-size-4xl, 2.25rem);
    line-height: var(--line-height-tight, 1.2);
    letter-spacing: var(--letter-spacing-tighter, -0.02em);
    color: var(--color-text, #0a0a0a);
    margin: 0;
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .cart-page__count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 28px;
    height: 28px;
    padding: 0 var(--space-2);
    border-radius: var(--radius-round, 50%);
    background-color: var(--theme-surface-alt);
    color: var(--theme-text-secondary);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    line-height: 1;
  }

  /* --- Layout: items + sidebar --- */
  .cart-page__layout {
    display: grid;
    grid-template-columns: 1fr 400px;
    gap: var(--space-10);
    align-items: start;
  }

  /* --- Cart items --- */
  .cart-page__items {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .cart-page__item {
    display: flex;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-6) var(--space-4) var(--space-4);
    border-radius: var(--radius-3xl);
    background-color: var(--theme-surface-alt);
  }

  .cart-page__item-image {
    width: 155px;
    height: 136px;
    flex-shrink: 0;
    border-radius: var(--radius-xl);
    overflow: hidden;
    background-color: var(--theme-surface-alt);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .cart-page__item-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .cart-page__item-placeholder {
    width: 60%;
    height: auto;
    opacity: 0.4;
  }

  .cart-page__item-details {
    flex: 1;
    min-width: 0;
    display: flex;
    gap: var(--space-3);
  }

  .cart-page__item-left {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: flex-start;
  }

  .cart-page__qty-row {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .cart-page__item-right {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
  }

  .cart-page__item-prices {
    margin-top: auto;
  }

  .cart-page__item-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .cart-page__item-title {
    font-size: var(--font-size-2xl);
    line-height: var(--line-height-snug);
    letter-spacing: var(--letter-spacing-tighter);
    color: var(--theme-text);
    text-decoration: none;
    font-weight: var(--font-weight-regular);
  }

  .cart-page__item-title:hover {
    text-decoration: underline;
  }

  .cart-page__item-title:focus-visible {
    outline: 2px solid var(--color-focus, var(--theme-primary));
    outline-offset: 2px;
    border-radius: var(--radius-sm);
  }

  .cart-page__item-variant {
    font-size: var(--font-size-sm);
    line-height: var(--line-height-snug);
    color: var(--theme-text-secondary);
    margin: 0;
  }

  .cart-page__item-prices {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: var(--space-1);
  }

  .cart-page__item-price-row {
    display: flex;
    align-items: center;
    gap: 2px;
  }

  .cart-page__item-compare-price {
    font-size: var(--font-size-xs);
    line-height: var(--line-height-tight);
    color: var(--theme-text-dim);
    text-decoration: line-through;
    text-align: end;
  }

  .cart-page__item-price {
    font-size: var(--font-size-xl);
    line-height: var(--line-height-snug);
    color: var(--theme-text);
  }

  /* Quantity selector */
  .cart-page__quantity {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2);
    background-color: var(--theme-surface-alt);
    border: 1px solid var(--theme-border);
    border-radius: var(--radius-pill);
  }

  .cart-page__quantity-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    padding: 0;
    background: none;
    border: none;
    color: var(--theme-text);
    cursor: pointer;
    border-radius: var(--radius-round);
  }

  .cart-page__quantity-btn svg {
    width: 20px;
    height: 20px;
  }

  .cart-page__quantity-btn:hover {
    opacity: 0.7;
  }

  .cart-page__quantity-btn:focus-visible {
    outline: 2px solid var(--color-focus, var(--theme-primary));
    outline-offset: 2px;
  }

  .cart-page__quantity-value {
    width: 32px;
    text-align: center;
    font-size: var(--font-size-sm);
    line-height: var(--line-height-snug);
    color: var(--theme-text);
  }

  .cart-page__remove-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    padding: 0;
    background: none;
    border: none;
    color: var(--theme-text-dim);
    cursor: pointer;
    transition: color var(--duration-fast, 150ms) var(--ease-standard, ease);
  }

  .cart-page__remove-btn svg {
    width: 24px;
    height: 24px;
  }

  .cart-page__remove-btn:hover {
    color: var(--color-danger, #dc2626);
  }

  .cart-page__remove-btn:focus-visible {
    outline: 2px solid var(--color-focus, var(--theme-primary));
    outline-offset: 2px;
    border-radius: var(--radius-sm);
  }

  /* --- Sidebar --- */
  .cart-page__sidebar {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
    position: sticky;
    inset-block-start: var(--space-6);
    min-width: 0;
  }

  /* Order summary */
  .cart-page__summary {
    background-color: var(--theme-surface-alt);
    border-radius: var(--radius-xl);
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .cart-page__subtotal {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 var(--space-1);
  }

  .cart-page__subtotal-label {
    font-size: var(--font-size-base);
    line-height: var(--line-height-normal);
    color: var(--theme-text-secondary);
  }

  .cart-page__subtotal-right {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .cart-page__savings-badge {
    display: inline-flex;
    align-items: center;
    padding: var(--space-1) var(--space-2);
    background-color: var(--theme-accent);
    border-radius: var(--theme-radius-badge);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-medium);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wider);
    color: var(--theme-text-on-accent);
    line-height: var(--line-height-normal);
  }

  .cart-page__subtotal-price {
    font-size: var(--font-size-xl);
    line-height: var(--line-height-snug);
    color: var(--theme-text);
  }

  /* Checkout button */
  .cart-page__checkout-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 48px;
    width: 100%;
    background-color: var(--theme-primary);
    color: var(--theme-text-on-primary);
    border-radius: var(--theme-radius-button);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    letter-spacing: var(--letter-spacing-tight);
    text-decoration: none;
    transition: background-color var(--duration-fast, 150ms) var(--ease-standard, ease);
  }

  .cart-page__checkout-btn:hover {
    background-color: var(--theme-primary-hover);
  }

  .cart-page__checkout-btn:focus-visible {
    outline: 2px solid var(--color-focus, var(--theme-primary));
    outline-offset: 2px;
  }

  /* Continue shopping button */
  .cart-page__continue-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 48px;
    width: 100%;
    background-color: var(--theme-surface-muted);
    color: var(--theme-text);
    border-radius: var(--theme-radius-button);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    letter-spacing: var(--letter-spacing-tight);
    text-decoration: none;
    transition: opacity var(--duration-fast, 150ms) var(--ease-standard, ease);
  }

  .cart-page__continue-btn:hover {
    opacity: 0.85;
  }

  .cart-page__continue-btn:focus-visible {
    outline: 2px solid var(--color-focus, var(--theme-primary));
    outline-offset: 2px;
  }

  /* --- Empty state --- */
  .cart-page__empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-20) var(--space-6);
    text-align: center;
  }

  .cart-page__empty-icon {
    color: var(--color-text-disabled, #aaa);
    margin-bottom: var(--space-2);
  }

  .cart-page__empty-title {
    font-size: var(--font-size-xl, 1.25rem);
    font-weight: var(--font-weight-medium, 500);
    color: var(--color-text, #0a0a0a);
    margin: 0;
  }

  .cart-page__empty-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 48px;
    padding: 0 var(--space-8);
    background-color: var(--theme-primary);
    color: var(--theme-text-on-primary);
    border-radius: var(--theme-radius-button);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    text-decoration: none;
    transition: background-color var(--duration-fast, 150ms) var(--ease-standard, ease);
  }

  .cart-page__empty-btn:hover {
    background-color: var(--theme-primary-hover);
  }

  .cart-page__empty-btn:focus-visible {
    outline: 2px solid var(--color-focus, var(--theme-primary));
    outline-offset: 2px;
  }

  /* --- Item savings and discount badges --- */
  .cart-page__item-savings {
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-medium);
    line-height: var(--line-height-normal);
    color: var(--theme-text);
    text-align: end;
  }

  .cart-page__item-discount-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    padding: 2px var(--space-2);
    background-color: var(--theme-surface-alt);
    border-radius: var(--radius-sm);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-medium);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wider);
    color: var(--theme-text);
    line-height: var(--line-height-normal);
  }

  .cart-page__item-discount-badge svg {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
  }

  /* --- Promo code input --- */
  .cart-page__promo {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background-color: var(--theme-surface);
    border: 1px solid var(--theme-border);
    border-radius: var(--radius-lg);
    padding: var(--space-3) var(--space-4);
    gap: var(--space-2);
  }

  .cart-page__promo-input {
    flex: 1;
    min-width: 0;
    background: none;
    border: none;
    outline: none;
    font-size: var(--font-size-sm);
    line-height: var(--line-height-snug);
    color: var(--theme-text);
    font-family: inherit;
  }

  .cart-page__promo-input::placeholder {
    color: var(--theme-text-secondary);
  }

  .cart-page__promo-apply {
    flex-shrink: 0;
    background: none;
    border: none;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    color: var(--theme-text);
    cursor: pointer;
    letter-spacing: var(--letter-spacing-tight);
    padding: 0;
    transition: opacity var(--duration-fast, 150ms) var(--ease-standard, ease);
  }

  .cart-page__promo-apply:hover {
    opacity: 0.7;
  }

  .cart-page__promo-apply:focus-visible {
    outline: 2px solid var(--color-focus, var(--theme-primary));
    outline-offset: 2px;
    border-radius: var(--radius-sm);
  }

  /* --- Loading state --- */
  .cart-page__item.is-loading {
    opacity: 0.5;
    pointer-events: none;
  }

  /* --- Responsive --- */
  @media screen and (max-width: 999px) {
    .cart-page__layout {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .cart-page__sidebar {
      position: static;
    }
  }

  @media screen and (max-width: 749px) {
    .cart-page {
      padding: var(--space-6) 0 var(--space-12);
    }

    .cart-page__announcement {
      padding: var(--space-2) var(--space-4);
    }

    .cart-page__announcement-text {
      font-size: var(--font-size-base);
    }

    .cart-page__heading {
      font-size: var(--font-size-2xl, 1.5rem);
    }

    .cart-page__shipping-text {
      font-size: var(--font-size-base);
      line-height: var(--line-height-normal);
    }

    .cart-page__item {
      padding: var(--space-2);
    }

    .cart-page__item-image {
      width: 100px;
      height: 100px;
    }

    .cart-page__item-title {
      font-size: var(--font-size-lg);
      line-height: var(--line-height-snug);
    }

    .cart-page__item-price {
      font-size: var(--font-size-base);
      line-height: var(--line-height-normal);
    }

  }
{% endstylesheet %}

{% javascript %}
  (function () {
    var section = document.querySelector('.cart-page');
    if (!section) return;

    /* --- Cart API helpers --- */
    async function fetchCart() {
      var r = await fetch('/cart.js', {
        method: 'GET',
        headers: { 'Content-Type': 'application/json' }
      });
      return r.json();
    }

    async function updateCartItem(key, quantity) {
      var r = await fetch('/cart/change.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: key, quantity: quantity })
      });
      return r.json();
    }

    async function addToCart(variantId, quantity) {
      var r = await fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ items: [{ id: variantId, quantity: quantity || 1 }] })
      });
      return r.json();
    }

    /* --- Refresh via section rendering API --- */
    async function refreshCartPage() {
      var sectionEl = section.closest('.shopify-section');
      if (!sectionEl) return;
      var sectionId = sectionEl.id.replace('shopify-section-', '');
      var r = await fetch('/?sections=' + sectionId);
      var data = await r.json();
      var html = data[sectionId];
      if (!html) return;
      var temp = document.createElement('div');
      temp.innerHTML = html;
      var newSection = temp.querySelector('.cart-page');
      if (newSection) {
        section.innerHTML = newSection.innerHTML;
        bindEvents();
      }
      updateHeaderCartCount();
    }

    async function updateHeaderCartCount() {
      var cart = await fetchCart();
      var countEl = document.querySelector('.site-header__cart-count');
      if (countEl) {
        if (cart.item_count > 0) {
          countEl.textContent = cart.item_count;
          countEl.hidden = false;
        } else {
          countEl.textContent = '';
          countEl.hidden = true;
        }
      }
    }

    /* --- Event bindings --- */
    function bindEvents() {
      /* Quantity buttons */
      for (const selector of section.querySelectorAll('[data-cart-page-quantity]')) {
        const item = selector.closest('[data-cart-page-item]');
        const key = item.getAttribute('data-line-key');
        const valueEl = selector.querySelector('[data-cart-page-qty-value]');
        const minusBtn = selector.querySelector('[data-cart-page-minus]');
        const plusBtn = selector.querySelector('[data-cart-page-plus]');

        minusBtn.addEventListener('click', async function () {
          var qty = parseInt(valueEl.textContent, 10);
          if (qty <= 1) return;
          item.classList.add('is-loading');
          await updateCartItem(key, qty - 1);
          await refreshCartPage();
        });

        plusBtn.addEventListener('click', async function () {
          var qty = parseInt(valueEl.textContent, 10);
          item.classList.add('is-loading');
          await updateCartItem(key, qty + 1);
          await refreshCartPage();
        });
      }

      /* Remove buttons */
      for (const btn of section.querySelectorAll('[data-cart-page-remove]')) {
        btn.addEventListener('click', async function () {
          var item = btn.closest('[data-cart-page-item]');
          var key = item.getAttribute('data-line-key');
          item.classList.add('is-loading');
          await updateCartItem(key, 0);
          await refreshCartPage();
        });
      }

      /* Promo code apply */
      var promoApply = section.querySelector('[data-cart-page-promo-apply]');
      var promoInput = section.querySelector('[data-cart-page-promo-input]');
      if (promoApply && promoInput) {
        promoApply.addEventListener('click', async function () {
          var code = promoInput.value.trim();
          if (!code) return;
          promoApply.disabled = true;
          promoApply.textContent = '...';
          try {
            await fetch('/discount/' + encodeURIComponent(code), { method: 'GET', redirect: 'follow' });
            await refreshCartPage();
          } catch (err) {
            promoApply.disabled = false;
            promoApply.textContent = promoInput.getAttribute('aria-label') || 'Apply';
          }
        });
        promoInput.addEventListener('keydown', function (e) {
          if (e.key === 'Enter') {
            e.preventDefault();
            promoApply.click();
          }
        });
      }

    }

    /* Initial binding */
    bindEvents();

    /* Theme editor support */
    document.addEventListener('shopify:section:load', function (e) {
      if (e.target.querySelector('.cart-page')) {
        bindEvents();
      }
    });
  })();
{% endjavascript %}


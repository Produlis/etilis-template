{
  "name": "t:general.cart",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_free_shipping_bar",
      "label": "t:sections.cart_page.settings.show_free_shipping_bar",
      "default": true
    },
    {
      "type": "range",
      "id": "free_shipping_threshold",
      "label": "t:sections.cart_page.settings.free_shipping_threshold",
      "min": 0,
      "max": 500,
      "step": 10,
      "unit": "$",
      "default": 100
    }
  ]
}

<section class="product-timeline full-width">
  <div class="product-timeline__header">
    {% if section.settings.tag_text != blank %}
      <span class="product-timeline__tag">{{ section.settings.tag_text }}</span>
    {% endif %}

    {% if section.settings.heading != blank %}
      <h2 class="product-timeline__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    {% if section.settings.description != blank %}
      <p class="product-timeline__description">{{ section.settings.description }}</p>
    {% endif %}
  </div>

  <div class="product-timeline__body">
    <div class="product-timeline__steps">
      {% for block in section.blocks %}
        {% if block.type == 'milestone' %}
          <div class="product-timeline__step" {{ block.shopify_attributes }}>
            <div class="product-timeline__timeline">
              <span class="product-timeline__dot"></span>
              {% unless forloop.last %}
                <span class="product-timeline__line"></span>
              {% endunless %}
            </div>

            <div class="product-timeline__step-content">
              <div class="product-timeline__step-bar">
                {% if block.settings.time_label != blank %}
                  <span class="product-timeline__time-badge">
                    {{ block.settings.time_label }}
                  </span>
                {% endif %}

                {% if block.settings.title != blank %}
                  <span class="product-timeline__step-title">{{ block.settings.title }}</span>
                {% endif %}
              </div>

              {% if block.settings.benefits != blank %}
                <div class="product-timeline__benefits">
                  {{ block.settings.benefits }}
                </div>
              {% endif %}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <div class="product-timeline__aside">
      <div class="product-timeline__image">
        {% if section.settings.side_image %}
          {{ section.settings.side_image | image_url: width: 1200 | image_tag: loading: 'lazy' }}
        {% else %}
          {{ 'product-1' | placeholder_svg_tag: 'product-timeline__placeholder' }}
        {% endif %}
      </div>

      {% assign upsell_product = section.settings.upsell_product %}
      <div class="product-timeline__upsell">
        <div class="product-timeline__upsell-thumb">
          {% if section.settings.upsell_image %}
            {{ section.settings.upsell_image | image_url: width: 400 | image_tag: loading: 'lazy' }}
          {% elsif upsell_product and upsell_product.featured_image %}
            {{ upsell_product.featured_image | image_url: width: 400 | image_tag: loading: 'lazy' }}
          {% else %}
            {{ 'product-1' | placeholder_svg_tag: 'product-timeline__placeholder' }}
          {% endif %}
        </div>

        <div class="product-timeline__upsell-body">
          <div class="product-timeline__upsell-info">
            <div class="product-timeline__upsell-title-row">
              {% if section.settings.upsell_title != blank %}
                <span class="product-timeline__upsell-name">{{ section.settings.upsell_title }}</span>
              {% endif %}
              {% if section.settings.upsell_badge != blank %}
                <span class="product-timeline__upsell-badge">{{ section.settings.upsell_badge }}</span>
              {% endif %}
            </div>

            {% if section.settings.upsell_description != blank %}
              <p class="product-timeline__upsell-desc">{{ section.settings.upsell_description }}</p>
            {% endif %}
          </div>

          <div class="product-timeline__upsell-action">
            <div class="product-timeline__upsell-pricing">
              {% if upsell_product %}
                {% assign upsell_variant = upsell_product.selected_or_first_available_variant %}
                <span class="product-timeline__upsell-price">{{ upsell_variant.price | money }}</span>
                {% if upsell_variant.compare_at_price > upsell_variant.price %}
                  <span class="product-timeline__upsell-compare">{{ upsell_variant.compare_at_price | money }}</span>
                {% endif %}
              {% else %}
                <span class="product-timeline__upsell-price">$109.00</span>
                <span class="product-timeline__upsell-compare">$199.99</span>
              {% endif %}
            </div>

            {% if upsell_product %}
              {% assign upsell_variant = upsell_product.selected_or_first_available_variant %}
              {% form 'product', upsell_product %}
                <input type="hidden" name="id" value="{{ upsell_variant.id }}">
                <button type="submit" class="product-timeline__upsell-btn">
                  {{ 'sections.product_timeline.add_to_cart' | t }}
                </button>
              {% endform %}
            {% else %}
              <button type="button" class="product-timeline__upsell-btn" disabled>
                {{ 'sections.product_timeline.add_to_cart' | t }}
              </button>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .product-timeline {
    background-color: var(--theme-surface);
    padding: 52px 0;
  }

  .product-timeline__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: var(--container-max, 1200px);
    margin: 0 auto;
    padding: 0 var(--container-padding, 16px);
    gap: 16px;
  }

  .product-timeline__tag {
    display: inline-block;
    background-color: var(--theme-surface-alt);
    color: var(--theme-primary);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-medium);
    text-transform: uppercase;
    letter-spacing: 1.44px;
    padding: 4px 12px;
    border-radius: var(--theme-radius-badge);
    line-height: 18px;
  }

  .product-timeline__heading {
    font-size: var(--font-size-5xl);
    line-height: 64px;
    font-weight: var(--font-weight-regular);
    color: var(--theme-primary);
    letter-spacing: -2.08px;
    margin: 0;
    max-width: 696px;
  }

  .product-timeline__description {
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-regular);
    color: var(--theme-text-secondary);
    line-height: var(--line-height-normal);
    margin: 0;
  }

  /* ── Body ── */
  .product-timeline__body {
    display: flex;
    gap: 24px;
    max-width: var(--container-max, 1200px);
    margin: 52px auto 0;
    padding: 0 var(--container-padding, 16px);
  }

  .product-timeline__steps {
    flex: 0 0 576px;
    max-width: 576px;
    display: flex;
    flex-direction: column;
  }

  /* ── Step ── */
  .product-timeline__step {
    display: flex;
    gap: 16px;
  }

  .product-timeline__timeline {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
    width: 20px;
    padding-top: 8px;
  }

  .product-timeline__dot {
    display: block;
    width: 20px;
    height: 20px;
    border-radius: var(--radius-round);
    background-color: var(--theme-primary);
    flex-shrink: 0;
  }

  .product-timeline__line {
    display: block;
    width: 0;
    flex: 1;
    border-inline-start: 1px dashed color-mix(in srgb, var(--theme-primary) 25%, transparent);
    margin-block-start: 2px;
  }

  /* ── Step content ── */
  .product-timeline__step-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding-bottom: 24px;
  }

  .product-timeline__step:last-child .product-timeline__step-content {
    padding-bottom: 0;
  }

  .product-timeline__step-bar {
    display: flex;
    align-items: center;
    gap: 8px;
    height: 36px;
  }

  .product-timeline__time-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: var(--theme-accent);
    color: var(--theme-text-on-accent);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    text-transform: uppercase;
    letter-spacing: 1.4px;
    line-height: 20px;
    padding: 0 12px;
    height: 28px;
    border-radius: var(--theme-radius-badge);
    flex-shrink: 0;
    white-space: nowrap;
  }

  .product-timeline__step-title {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    text-transform: uppercase;
    letter-spacing: 1.68px;
    line-height: 20px;
    color: var(--theme-primary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .product-timeline__benefits {
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-regular);
    color: var(--theme-text-secondary);
    line-height: var(--line-height-normal);
  }

  .product-timeline__benefits ul {
    margin: 0;
    padding-inline-start: 24px;
    list-style-type: disc;
  }

  .product-timeline__benefits li {
    margin-bottom: 0;
  }

  .product-timeline__benefits p {
    margin: 0;
  }

  /* ── Aside ── */
  .product-timeline__aside {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 16px;
    min-width: 0;
  }

  .product-timeline__image {
    height: 396px;
    flex-shrink: 0;
    position: relative;
    border-radius: var(--radius-3xl);
    overflow: hidden;
    background-color: var(--theme-surface-alt);
  }

  .product-timeline__image img,
  .product-timeline__image svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ── Upsell card ── */
  .product-timeline__upsell {
    display: flex;
    gap: 16px;
    align-items: center;
    background-color: var(--theme-surface-alt);
    border-radius: var(--radius-3xl);
    padding: 8px 16px 8px 8px;
    flex-shrink: 0;
  }

  .product-timeline__upsell-thumb {
    width: 155px;
    height: 136px;
    flex-shrink: 0;
    border-radius: var(--radius-xl);
    overflow: hidden;
    background-color: var(--theme-border);
  }

  .product-timeline__upsell-thumb img,
  .product-timeline__upsell-thumb svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .product-timeline__upsell-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 12px;
    min-width: 0;
  }

  .product-timeline__upsell-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .product-timeline__upsell-title-row {
    display: flex;
    align-items: flex-start;
    gap: 4px;
  }

  .product-timeline__upsell-name {
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-regular);
    color: var(--theme-primary);
    line-height: 24px;
  }

  .product-timeline__upsell-badge {
    display: inline-flex;
    align-items: center;
    background-color: var(--theme-accent);
    color: var(--theme-text-on-accent);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-medium);
    text-transform: uppercase;
    letter-spacing: 1.44px;
    line-height: 18px;
    padding: 4px 8px;
    border-radius: var(--theme-radius-badge);
    white-space: nowrap;
  }

  .product-timeline__upsell-desc {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-regular);
    color: var(--theme-text-secondary);
    line-height: 20px;
    margin: 0;
  }

  .product-timeline__upsell-action {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .product-timeline__upsell-pricing {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .product-timeline__upsell-price {
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-regular);
    color: var(--theme-primary);
    line-height: 24px;
  }

  .product-timeline__upsell-compare {
    font-size: var(--font-size-xs);
    color: color-mix(in srgb, var(--theme-primary) 40%, transparent);
    text-decoration: line-through;
    line-height: 16px;
  }

  .product-timeline__upsell form {
    display: contents;
  }

  .product-timeline__upsell-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: var(--theme-border);
    color: var(--theme-primary);
    font-family: inherit;
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-medium);
    line-height: 24px;
    letter-spacing: -0.32px;
    height: 40px;
    padding: 0 20px;
    border-radius: 32px;
    border: none;
    cursor: pointer;
    white-space: nowrap;
    transition: background-color var(--duration-fast) var(--ease-standard);
  }

  .product-timeline__upsell-btn:hover:not(:disabled) {
    background-color: var(--theme-surface-muted);
  }

  .product-timeline__upsell-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  /* ── Mobile ── */
  @media screen and (max-width: 749px) {
    .product-timeline {
      padding: 24px 0;
    }

    .product-timeline__heading {
      font-size: var(--font-size-3xl);
      line-height: var(--line-height-tight);
      letter-spacing: var(--letter-spacing-tighter);
    }

    .product-timeline__body {
      flex-direction: column;
      margin-top: 32px;
    }

    .product-timeline__steps {
      flex: 1;
      max-width: 100%;
    }

    .product-timeline__step-bar {
      flex-wrap: wrap;
      height: auto;
      gap: 4px;
    }

    .product-timeline__step-title {
      white-space: normal;
      font-size: var(--font-size-xs);
    }

    .product-timeline__image {
      height: 280px;
    }

    .product-timeline__upsell {
      flex-direction: column;
      padding: 8px;
    }

    .product-timeline__upsell-thumb {
      width: 100%;
      height: 180px;
    }

    .product-timeline__upsell-action {
      flex-wrap: wrap;
      gap: 12px;
    }
  }
{% endstylesheet %}


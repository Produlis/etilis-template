<section class="faq full-width" aria-label="{{ 'faq.section_label' | t }}">
  <div class="faq__container">
    <div class="faq__left">
      <span class="faq__tag">{{ section.settings.tag_text }}</span>
      <h2 class="faq__heading">{{ section.settings.heading }}</h2>
    </div>

    {%- assign meta_faqs = product.metafields.custom.faqs.value -%}
    <div class="faq__right">
      {%- if meta_faqs and meta_faqs.size > 0 -%}
        {%- for faq in meta_faqs -%}
          <details
            class="faq__item{% if forloop.last %} faq__item--last{% endif %}"
            data-faq-item
            {% if forloop.first %}open{% endif %}
          >
            <summary class="faq__question">
              <span class="faq__question-text">{{ faq.question }}</span>
              <span class="faq__icon" aria-hidden="true">
                {{ 'icon-plus.svg' | inline_asset_content }}
              </span>
            </summary>
            <div class="faq__answer">
              <div class="faq__answer-inner">
                {{ faq.answer }}
              </div>
            </div>
          </details>
        {%- endfor -%}
      {%- else -%}
        {% for block in section.blocks %}
          <details
            class="faq__item{% if forloop.last %} faq__item--last{% endif %}"
            data-faq-item
            {% if forloop.first %}
              open
            {% endif %}
            {{ block.shopify_attributes }}
          >
            <summary class="faq__question">
              <span class="faq__question-text">{{ block.settings.question }}</span>
              <span class="faq__icon" aria-hidden="true">
                {{ 'icon-plus.svg' | inline_asset_content }}
              </span>
            </summary>
            <div class="faq__answer">
              <div class="faq__answer-inner">
                {{ block.settings.answer }}
              </div>
            </div>
          </details>
        {% endfor %}
      {%- endif -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .faq {
    background-color: var(--theme-surface);
    padding: var(--space-13) 0;
  }

  .faq__container {
    max-width: var(--container-max, 1200px);
    margin: 0 auto;
    padding: 0 var(--container-padding, 16px);
    display: flex;
    gap: var(--space-13);
    align-items: flex-start;
  }

  .faq__left {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    width: 419px;
    flex-shrink: 0;
  }

  .faq__tag {
    display: inline-flex;
    align-self: flex-start;
    background-color: var(--theme-surface-alt);
    color: var(--theme-primary);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-medium);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wider);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--theme-radius-badge);
    line-height: 18px;
  }

  .faq__heading {
    font-size: var(--font-size-5xl);
    color: var(--theme-primary);
    line-height: 64px;
    letter-spacing: -2.08px;
    margin: 0;
    font-weight: var(--font-weight-regular);
  }

  .faq__right {
    flex: 1;
    min-width: 0;
  }

  .faq__item {
    border-top: 1px solid var(--theme-border);
  }

  .faq__item--last {
    border-bottom: 1px solid var(--theme-border);
  }

  .faq__question {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    width: 100%;
    padding: var(--space-4) 0 var(--space-6);
    background: none;
    border: none;
    cursor: pointer;
    text-align: start;
    gap: var(--space-4);
    font-family: inherit;
    list-style: none;
  }

  .faq__question::-webkit-details-marker {
    display: none;
  }

  .faq__question::marker {
    display: none;
    content: '';
  }

  .faq__question:focus-visible {
    outline: 2px solid var(--color-focus, var(--theme-primary));
    outline-offset: 2px;
    border-radius: var(--radius-sm);
  }

  .faq__question-text {
    font-size: var(--font-size-xl);
    color: var(--theme-primary);
    line-height: 28px;
    font-weight: var(--font-weight-regular);
    letter-spacing: -0.8px;
  }

  .faq__icon {
    width: 24px;
    height: 24px;
    flex-shrink: 0;
    color: var(--theme-text);
    transition: transform var(--duration-medium, 300ms) var(--ease-standard, ease);
  }

  .faq__icon svg {
    width: 24px;
    height: 24px;
    display: block;
  }

  .faq__item[open] .faq__icon {
    transform: rotate(45deg);
  }

  .faq__item[open] .faq__question {
    padding-bottom: var(--space-4);
  }

  .faq__answer {
    overflow: hidden;
  }

  .faq__answer-inner {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-regular);
    color: var(--theme-text-secondary);
    line-height: 20px;
    padding-bottom: var(--space-6);
  }

  .faq__answer-inner p {
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .faq {
      padding: var(--space-8) 0;
    }

    .faq__container {
      flex-direction: column;
      gap: var(--space-8);
    }

    .faq__left {
      width: 100%;
    }

    .faq__heading {
      font-size: var(--font-size-3xl);
      line-height: var(--line-height-tight);
      letter-spacing: var(--letter-spacing-tighter);
    }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    var section = document.querySelector('.faq');
    if (!section) return;

    var items = section.querySelectorAll('[data-faq-item]');

    for (const item of items) {
      item.addEventListener('toggle', function () {
        if (!item.open) return;

        for (const other of items) {
          if (other !== item && other.open) {
            other.removeAttribute('open');
          }
        }
      });
    }
  })();
{% endjavascript %}

{% schema %}
{
  "name": "t:sections.faq.name",
  "settings": [
    {
      "type": "text",
      "id": "tag_text",
      "label": "t:sections.faq.settings.tag_text",
      "default": "FAQs"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.faq.settings.heading",
      "default": "Frequently ask questions"
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "t:sections.faq.blocks.faq_item.name",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "t:sections.faq.blocks.faq_item.settings.question",
          "default": "Is the bottle glass or plastic?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "t:sections.faq.blocks.faq_item.settings.answer",
          "default": "<p>Our bottle is glass and the base is stainless steel.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.faq.name",
      "blocks": [
        {
          "type": "faq_item",
          "settings": {
            "question": "Is the bottle glass or plastic?",
            "answer": "<p>Our bottle is glass and the base is stainless steel.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "How long do I need to use this bottle?",
            "answer": "<p>We recommend using it daily for best results.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "How many bottles do I need to drink in a day?",
            "answer": "<p>We recommend at least 2-3 full bottles per day for optimal hydration.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "Can I use distilled, filtered, or tap water?",
            "answer": "<p>Yes, you can use any type of water with our bottle.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "Does the bottle need a replacement filter?",
            "answer": "<p>No, the bottle does not require any replacement filters.</p>"
          }
        }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}

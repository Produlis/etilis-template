<section class="guarantee-banner full-width">
  <div class="guarantee-banner__wrapper">
    <div class="guarantee-banner__bg">
      {% if section.settings.image %}
        {{ section.settings.image | image_url: width: 2400 | image_tag: loading: 'lazy', class: 'guarantee-banner__bg-image' }}
      {% else %}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'guarantee-banner__placeholder' }}
      {% endif %}
    </div>

    <div class="guarantee-banner__card">
      {% if section.settings.tag_text != blank %}
        <span class="guarantee-banner__tag">{{ section.settings.tag_text }}</span>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="guarantee-banner__heading">{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.body_text != blank %}
        <div class="guarantee-banner__body rte">
          {{ section.settings.body_text }}
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% stylesheet %}
  .guarantee-banner {
    background-color: var(--theme-surface);
    padding: 52px;
  }

  .guarantee-banner__wrapper {
    position: relative;
    max-width: var(--container-max, 1200px);
    margin: 0 auto;
    border-radius: 24px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding: 16px;
    min-height: 524px;
  }

  /* ── Background image ── */
  .guarantee-banner__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .guarantee-banner__bg-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .guarantee-banner__placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ── Content card ── */
  .guarantee-banner__card {
    position: relative;
    z-index: 1;
    background-color: var(--theme-primary);
    border-radius: 24px;
    padding: 32px;
    width: 564px;
    max-width: 100%;
    min-height: 524px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 16px;
  }

  .guarantee-banner__tag {
    display: inline-block;
    align-self: flex-start;
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 1.2px;
    color: var(--theme-text-on-primary);
    background-color: rgba(255, 255, 255, 0.2);
    border-radius: 28px;
    padding: 4px 12px;
    line-height: normal;
  }

  .guarantee-banner__heading {
    font-size: 52px;
    line-height: normal;
    font-weight: 400;
    letter-spacing: -2.08px;
    color: var(--theme-text-on-primary);
    margin: 0;
  }

  .guarantee-banner__body {
    font-size: 16px;
    font-weight: 500;
    line-height: 24px;
    color: var(--theme-text-muted);
  }

  .guarantee-banner__body p {
    margin: 0 0 16px;
  }

  .guarantee-banner__body p:last-child {
    margin-bottom: 0;
    color: var(--theme-text-on-primary);
  }

  /* ── Mobile ── */
  @media screen and (max-width: 749px) {
    .guarantee-banner {
      padding: 24px 20px;
    }

    .guarantee-banner__wrapper {
      flex-direction: column;
      min-height: auto;
      padding: 0;
    }

    .guarantee-banner__bg {
      position: relative;
      height: 280px;
      border-radius: 24px 24px 0 0;
      overflow: hidden;
    }

    .guarantee-banner__card {
      width: 100%;
      min-height: auto;
      border-radius: 0 0 24px 24px;
      padding: 24px;
    }

    .guarantee-banner__heading {
      font-size: 32px;
      line-height: 1.2;
      letter-spacing: -1.28px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.guarantee_banner.name",
  "tag": "section",
  "class": "guarantee-banner-section",
  "settings": [
    {
      "type": "text",
      "id": "tag_text",
      "label": "t:labels.tag_text",
      "default": "BENEFITS"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Improve Gut Balance & Reduce Digestive Discomfort"
    },
    {
      "type": "richtext",
      "id": "body_text",
      "label": "t:labels.body_text",
      "default": "<p>Backed by clinical research, our daily probiotic + prebiotic formula supports a healthier gut microbiome by relieving bloating, gas, and irregular digestion—while helping beneficial bacteria thrive.</p><p>Clinical studies show that consistent daily use of probiotics and prebiotics can significantly improve digestive regularity, reduce inflammation in the gut, and support overall immune function over time.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:labels.image"
    }
  ],
  "presets": [
    {
      "name": "t:sections.guarantee_banner.name"
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}

<div class="home-steps full-width">
  <div class="home-steps__header">
    {% if section.settings.tag_text != blank %}
      <span class="home-steps__tag">{{ section.settings.tag_text }}</span>
    {% endif %}

    {% if section.settings.heading != blank %}
      <h2 class="home-steps__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    {% if section.settings.description != blank %}
      <p class="home-steps__subtitle">{{ section.settings.description }}</p>
    {% endif %}
  </div>

  <div class="home-steps__track">
    {% for block in section.blocks %}
      <div class="home-steps__step" {{ block.shopify_attributes }}>
        <div class="home-steps__indicator">
          <span class="home-steps__dashed-line"></span>
          <span class="home-steps__badge">
            <span class="home-steps__badge-inner">
              {{ 'sections.home_steps.step' | t: number: forloop.index }}
            </span>
          </span>
          <span class="home-steps__dashed-line"></span>
        </div>

        <div class="home-steps__content">
          {% if block.settings.image != blank %}
            <div class="home-steps__image-wrapper">
              {{
                block.settings.image
                | image_url: width: 800
                | image_tag:
                  class: 'home-steps__image',
                  loading: 'lazy',
                  widths: '280,400,600,800'
              }}
            </div>
          {% else %}
            <div class="home-steps__image-wrapper home-steps__image-wrapper--placeholder">
              {% render 'placeholder-image' %}
            </div>
          {% endif %}

          {% if block.settings.title != blank %}
            <h3 class="home-steps__step-title">{{ block.settings.title }}</h3>
          {% endif %}

          {% if block.settings.description != blank %}
            <p class="home-steps__step-description">{{ block.settings.description }}</p>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>
</div>

{% stylesheet %}
  .home-steps {
    background-color: var(--theme-surface);
    padding: var(--space-13) var(--container-padding, 24px) 3.125rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-13);
  }

  .home-steps__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
    text-align: center;
    max-width: 720px;
  }

  .home-steps__tag {
    display: inline-flex;
    align-items: center;
    background-color: var(--color-surface-card);
    border: none;
    border-radius: var(--theme-radius-badge);
    padding: var(--space-1) var(--space-3);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-medium);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wider);
    color: var(--color-text);
    line-height: var(--line-height-snug);
  }

  .home-steps__heading {
    font-size: var(--font-size-6xl, 52px);
    line-height: 64px;
    letter-spacing: var(--letter-spacing-tighter);
    color: var(--color-text);
    margin: 0;
    text-align: center;
  }

  .home-steps__subtitle {
    font-size: var(--font-size-base);
    line-height: var(--line-height-normal);
    color: var(--theme-text-secondary);
    margin: 0;
    text-align: center;
  }

  .home-steps__track {
    display: flex;
    gap: 0;
    width: 100%;
    max-width: var(--container-max, 80rem);
  }

  .home-steps__step {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .home-steps__indicator {
    display: flex;
    align-items: center;
    width: 100%;
    gap: 0;
  }

  .home-steps__dashed-line {
    flex: 1;
    height: 0;
    border-block-start: 1px dashed var(--color-border);
  }

  .home-steps__badge {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 2px;
    border: none;
    border-radius: 20px;
    background: var(--color-accent-subtle);
  }

  .home-steps__badge-inner {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: var(--theme-accent);
    border-radius: var(--theme-radius-badge);
    height: 28px;
    padding: 0 var(--space-3);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wider);
    color: var(--theme-text-on-accent);
    white-space: nowrap;
  }

  .home-steps__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: 0 var(--space-6);
  }

  .home-steps__image-wrapper {
    width: 100%;
    height: 253px;
    border-radius: var(--theme-radius-image);
    overflow: hidden;
  }

  .home-steps__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .home-steps__image-wrapper--placeholder {
    background-color: var(--color-surface-placeholder);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .home-steps__image-placeholder {
    width: 100%;
    height: 100%;
  }

  .home-steps__step-title {
    font-size: var(--font-size-lg);
    line-height: var(--line-height-snug);
    color: var(--color-text);
    margin: 0;
  }

  .home-steps__step-description {
    font-size: var(--font-size-base);
    line-height: var(--line-height-normal);
    color: var(--theme-text-secondary);
    margin: 0;
  }

  @media screen and (max-width: 989px) {
    .home-steps {
      padding: var(--space-8) var(--container-padding, 24px) 3.125rem;
      gap: var(--space-8);
    }

    .home-steps__heading {
      font-size: var(--font-size-4xl);
    }

    .home-steps__content {
      padding: 0 var(--space-3);
    }
  }

  @media screen and (max-width: 749px) {
    .home-steps {
      padding: var(--space-6) 0 3.125rem;
      gap: var(--space-6);
    }

    .home-steps__header {
      padding: 0 var(--space-4);
    }

    .home-steps__heading {
      font-size: var(--font-size-3xl);
      line-height: var(--line-height-tight);
      letter-spacing: var(--letter-spacing-tighter);
    }

    .home-steps__track {
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scroll-padding-inline-start: var(--space-4);
      scrollbar-width: none;
      -ms-overflow-style: none;
      padding: 0 var(--space-4);
      -webkit-mask-image: linear-gradient(to right, transparent, black 16px, black calc(100% - 40px), transparent);
      mask-image: linear-gradient(to right, transparent, black 16px, black calc(100% - 40px), transparent);
    }

    .home-steps__track::-webkit-scrollbar {
      display: none;
    }

    .home-steps__step {
      flex: 0 0 75vw;
      max-width: 300px;
      scroll-snap-align: start;
    }

    .home-steps__content {
      padding: 0 var(--space-2);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.home_steps.name",
  "settings": [
    {
      "type": "text",
      "id": "tag_text",
      "label": "t:labels.tag_text",
      "default": "HOW IT WORKS"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Simple steps to get started"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "t:labels.description",
      "default": "Our streamlined process makes it easy to find what works best for you."
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "t:sections.home_steps.blocks.step.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:labels.image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "t:labels.title",
          "default": "Step title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "t:labels.description",
          "default": "Step description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.home_steps.name",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "title": "Browse & Choose",
            "description": "Explore our curated collection and find the products that fit your lifestyle."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Customize Your Order",
            "description": "Select your preferences, bundle your favorites, and enjoy exclusive savings."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Enjoy the Results",
            "description": "Experience the quality difference with products designed to exceed your expectations."
          }
        }
      ]
    }
  ]
}
{% endschema %}

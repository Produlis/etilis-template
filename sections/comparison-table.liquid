<section class="comparison-table full-width">
  <div class="comparison-table__container">
    <div class="comparison-table__left">
      {% if section.settings.tag_text != blank %}
        <span class="comparison-table__tag">{{ section.settings.tag_text }}</span>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="comparison-table__heading">{{ section.settings.heading }}</h2>
      {% endif %}
    </div>

    {% assign comparison_rows = section.blocks | where: 'type', 'comparison_row' %}

    <div class="comparison-table__right">
      <table class="comparison-table__glass" role="table">
        <thead>
          <tr class="comparison-table__header-row">
            <th class="comparison-table__label-header" scope="col">
              <span class="visually-hidden">{{ 'sections.comparison_table.features_header' | t }}</span>
            </th>
            <th class="comparison-table__brand-header" scope="col">
              {{ section.settings.brand_name }}
            </th>
            <th class="comparison-table__other-header" scope="col">
              {{ section.settings.competitor_name }}
            </th>
          </tr>
        </thead>
        <tbody>
          {% for block in comparison_rows %}
            <tr class="comparison-table__row" {{ block.shopify_attributes }}>
              <td class="comparison-table__label-cell">
                {{ block.settings.label }}
              </td>
              <td class="comparison-table__brand-cell">
                <span class="comparison-table__dot" aria-label="{{ block.settings.label | escape }}"></span>
              </td>
              <td class="comparison-table__other-cell">
                <span class="comparison-table__other-text">
                  {{ block.settings.competitor_text | default: '—' }}
                </span>
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
</section>

{% stylesheet %}
  .comparison-table {
    background-color: var(--theme-primary);
    padding: 52px 0;
  }

  .comparison-table__container {
    display: flex;
    gap: 24px;
    max-width: var(--container-max, 1200px);
    margin: 0 auto;
    padding: 0 var(--container-padding, 16px);
    align-items: flex-start;
  }

  /* ── Left sidebar ── */
  .comparison-table__left {
    flex: 0 0 300px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .comparison-table__tag {
    display: inline-block;
    align-self: flex-start;
    background-color: var(--color-on-primary-subtle);
    color: var(--theme-text-on-primary);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-medium);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wider);
    padding: 4px 12px;
    border-radius: var(--theme-radius-badge);
    line-height: normal;
  }

  .comparison-table__heading {
    font-size: var(--font-size-5xl);
    line-height: normal;
    font-weight: var(--font-weight-regular);
    letter-spacing: var(--letter-spacing-tighter);
    color: var(--theme-text-on-primary);
    margin: 0;
  }

  /* ── Right table ── */
  .comparison-table__right {
    flex: 1;
    min-width: 0;
  }

  .comparison-table__glass {
    width: 100%;
    border-collapse: separate;
    border-spacing: 10px 0;
    background: var(--color-glass-bg);
    border: 1px solid var(--color-glass-border);
    border-radius: var(--radius-3xl);
    -webkit-backdrop-filter: blur(20px);
    backdrop-filter: blur(20px);
    padding: 8px;
  }

  /* ── Header row ── */
  .comparison-table__label-header {
    padding: 0;
  }

  .comparison-table__brand-header,
  .comparison-table__other-header {
    width: 168px;
    padding: 16px 0 8px;
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-regular);
    letter-spacing: var(--letter-spacing-tighter);
    line-height: var(--line-height-normal);
    color: var(--theme-text-on-primary);
    text-align: center;
  }

  .comparison-table__brand-header {
    background-color: var(--theme-accent);
    border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  }

  /* ── Body rows ── */
  .comparison-table__label-cell {
    padding: 12px 16px 12px 16px;
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-regular);
    color: var(--theme-text-on-primary);
    line-height: var(--line-height-normal);
    text-align: start;
  }

  .comparison-table__brand-cell {
    background-color: var(--theme-accent);
    text-align: center;
    padding: 12px 0;
  }

  .comparison-table__other-cell {
    text-align: center;
    padding: 12px 2px;
  }

  /* Last row rounds bottom of brand column */
  .comparison-table__row:last-child .comparison-table__brand-cell {
    border-radius: 0 0 var(--radius-xl) var(--radius-xl);
    padding-bottom: 16px;
  }

  .comparison-table__dot {
    display: inline-block;
    width: 16px;
    height: 16px;
    border-radius: var(--radius-round);
    background-color: var(--theme-primary);
    vertical-align: middle;
  }

  .comparison-table__other-text {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-regular);
    line-height: var(--line-height-snug);
    color: var(--theme-text-dim);
  }

  /* ── Visually hidden utility ── */
  .comparison-table .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ── Mobile ── */
  @media screen and (max-width: 749px) {
    .comparison-table {
      padding: 24px 0;
    }

    .comparison-table__container {
      flex-direction: column;
      gap: 24px;
    }

    .comparison-table__left {
      flex: none;
      padding: 0 var(--container-padding, 16px);
    }

    .comparison-table__heading {
      font-size: var(--font-size-3xl);
      line-height: var(--line-height-tight);
      letter-spacing: var(--letter-spacing-tighter);
    }

    .comparison-table__glass {
      padding: 8px;
      border-spacing: 4px 0;
      border-radius: var(--radius-xl);
    }

    .comparison-table__label-cell {
      font-size: 13px;
      padding: 8px 4px 8px 8px;
    }

    .comparison-table__brand-header,
    .comparison-table__other-header {
      width: 80px;
      font-size: 13px;
    }

    .comparison-table__other-text {
      font-size: 11px;
      line-height: 16px;
    }
  }
{% endstylesheet %}


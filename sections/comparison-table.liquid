<section class="comparison-table full-width">
  <div class="comparison-table__container">
    <div class="comparison-table__left">
      {% if section.settings.tag_text != blank %}
        <span class="comparison-table__tag">{{ section.settings.tag_text }}</span>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="comparison-table__heading">{{ section.settings.heading }}</h2>
      {% endif %}
    </div>

    {% assign comparison_rows = section.blocks | where: 'type', 'comparison_row' %}

    <div class="comparison-table__right">
      <div class="comparison-table__glass">
        <div class="comparison-table__labels">
          {% for block in comparison_rows %}
            <div class="comparison-table__label-cell" {{ block.shopify_attributes }}>
              {{ block.settings.label }}
            </div>
          {% endfor %}
        </div>

        <div class="comparison-table__brand-col">
          <div class="comparison-table__col-header">
            {{ section.settings.brand_name }}
          </div>
          {% for block in comparison_rows %}
            <div class="comparison-table__cell">
              <span class="comparison-table__dot" aria-label="{{ block.settings.label | escape }}"></span>
            </div>
          {% endfor %}
        </div>

        <div class="comparison-table__other-col">
          <div class="comparison-table__col-header">
            {{ section.settings.competitor_name }}
          </div>
          {% for block in comparison_rows %}
            <div class="comparison-table__cell">
              <span class="comparison-table__other-text">
                {{ block.settings.competitor_text | default: '—' }}
              </span>
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .comparison-table {
    background-color: var(--theme-primary);
    padding: 52px 0;
  }

  .comparison-table__container {
    display: flex;
    gap: 24px;
    max-width: var(--container-max, 1200px);
    margin: 0 auto;
    padding: 0 var(--container-padding, 16px);
    align-items: flex-start;
  }

  /* ── Left sidebar ── */
  .comparison-table__left {
    flex: 0 0 300px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .comparison-table__tag {
    display: inline-block;
    align-self: flex-start;
    background-color: rgba(255, 255, 255, 0.2);
    color: var(--theme-text-on-primary);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-medium);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wider);
    padding: 4px 12px;
    border-radius: var(--theme-radius-badge);
    line-height: normal;
  }

  .comparison-table__heading {
    font-size: var(--font-size-5xl);
    line-height: normal;
    font-weight: var(--font-weight-regular);
    letter-spacing: var(--letter-spacing-tighter);
    color: var(--theme-text-on-primary);
    margin: 0;
  }

  /* ── Right table ── */
  .comparison-table__right {
    flex: 1;
    min-width: 0;
  }

  .comparison-table__glass {
    display: flex;
    gap: 10px;
    align-items: flex-end;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: var(--radius-3xl);
    -webkit-backdrop-filter: blur(20px);
    backdrop-filter: blur(20px);
    padding: 8px 8px 8px 24px;
  }

  /* ── Labels column ── */
  .comparison-table__labels {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding: 16px 0;
    min-width: 0;
  }

  .comparison-table__label-cell {
    min-height: 48px;
    display: flex;
    align-items: center;
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-regular);
    color: var(--theme-text-on-primary);
    line-height: var(--line-height-normal);
  }

  /* ── Brand column ── */
  .comparison-table__brand-col {
    flex: 0 0 168px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    align-items: center;
    background-color: var(--theme-accent);
    border-radius: var(--radius-xl);
    padding: 16px 0;
  }

  .comparison-table__brand-col .comparison-table__col-header {
    color: var(--theme-primary);
  }

  /* ── Other column ── */
  .comparison-table__other-col {
    flex: 0 0 168px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    align-items: center;
    border-radius: var(--radius-xl);
    padding: 16px 0;
  }

  .comparison-table__other-col .comparison-table__col-header {
    color: var(--theme-text-on-primary);
  }

  /* ── Shared ── */
  .comparison-table__col-header {
    min-height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-regular);
    letter-spacing: var(--letter-spacing-tighter);
    line-height: var(--line-height-normal);
  }

  .comparison-table__cell {
    min-height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 2px;
  }

  .comparison-table__dot {
    display: block;
    width: 16px;
    height: 16px;
    border-radius: var(--radius-round);
    background-color: var(--theme-primary);
  }

  .comparison-table__other-text {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-regular);
    line-height: var(--line-height-snug);
    color: var(--theme-text-dim);
    text-align: center;
  }

  /* ── Mobile ── */
  @media screen and (max-width: 749px) {
    .comparison-table {
      padding: 24px 0;
    }

    .comparison-table__container {
      flex-direction: column;
      gap: 24px;
    }

    .comparison-table__left {
      flex: none;
      padding: 0 var(--container-padding, 16px);
    }

    .comparison-table__heading {
      font-size: var(--font-size-3xl);
      line-height: var(--line-height-tight);
      letter-spacing: var(--letter-spacing-tighter);
    }

    .comparison-table__glass {
      padding: 8px;
      gap: 4px;
      border-radius: var(--radius-xl);
    }

    .comparison-table__labels {
      padding: 8px 0;
    }

    .comparison-table__label-cell {
      font-size: 13px;
      min-height: 40px;
    }

    .comparison-table__brand-col,
    .comparison-table__other-col {
      flex: 0 0 80px;
    }

    .comparison-table__col-header {
      font-size: 13px;
    }

    .comparison-table__other-text {
      font-size: 11px;
      line-height: 16px;
    }
  }
{% endstylesheet %}

{% schema %}

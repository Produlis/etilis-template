<div class="home-testimonials full-width">
  <div class="home-testimonials__container">
    <div class="home-testimonials__header">
      <div class="home-testimonials__header-left">
        <span class="home-testimonials__tag">{{ section.settings.tag_text }}</span>
        <h2 class="home-testimonials__heading">{{ section.settings.heading }}</h2>
      </div>
      <div class="home-testimonials__header-right">
        <span class="home-testimonials__rating">{{ section.settings.rating }}</span>
        <div class="home-testimonials__stars-wrap">
          <div class="home-testimonials__stars">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="var(--theme-star)" aria-hidden="true"><path d="M10 1l2.39 4.84 5.34.78-3.87 3.77.91 5.33L10 13.27l-4.77 2.51.91-5.33L2.27 6.68l5.34-.78L10 1z"/></svg>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="var(--theme-star)" aria-hidden="true"><path d="M10 1l2.39 4.84 5.34.78-3.87 3.77.91 5.33L10 13.27l-4.77 2.51.91-5.33L2.27 6.68l5.34-.78L10 1z"/></svg>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="var(--theme-star)" aria-hidden="true"><path d="M10 1l2.39 4.84 5.34.78-3.87 3.77.91 5.33L10 13.27l-4.77 2.51.91-5.33L2.27 6.68l5.34-.78L10 1z"/></svg>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="var(--theme-star)" aria-hidden="true"><path d="M10 1l2.39 4.84 5.34.78-3.87 3.77.91 5.33L10 13.27l-4.77 2.51.91-5.33L2.27 6.68l5.34-.78L10 1z"/></svg>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="var(--theme-star)" aria-hidden="true"><path d="M10 1l2.39 4.84 5.34.78-3.87 3.77.91 5.33L10 13.27l-4.77 2.51.91-5.33L2.27 6.68l5.34-.78L10 1z"/></svg>
          </div>
          <span class="home-testimonials__review-count">{{ section.settings.review_count }} {{ 'sections.home_testimonials.five_star_reviews' | t }}</span>
        </div>
      </div>
    </div>
  </div>

  <div class="home-testimonials__row">
    {% for block in section.blocks %}
      {% case block.type %}
        {% when 'video_card' %}
          <div class="home-testimonials__card home-testimonials__card--video" {{ block.shopify_attributes }}>
            {% if block.settings.image %}
              {{ block.settings.image | image_url: width: 600, height: 860 | image_tag: class: 'home-testimonials__card-image', loading: 'lazy' }}
            {% else %}
              {{ 'lifestyle-1' | placeholder_svg_tag: 'home-testimonials__card-image home-testimonials__card-placeholder' }}
            {% endif %}
            <button class="home-testimonials__play-btn" aria-label="{{ 'sections.home_testimonials.play_video' | t }}">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="var(--theme-text-on-primary)" aria-hidden="true"><path d="M8 5v14l11-7L8 5z"/></svg>
            </button>
          </div>

        {% when 'quote_card' %}
          <div class="home-testimonials__card home-testimonials__card--split home-testimonials__card--split-{{ block.settings.image_position }}" {{ block.shopify_attributes }}>
            <div class="home-testimonials__card-image-half">
              {% if block.settings.image %}
                {{ block.settings.image | image_url: width: 600, height: 400 | image_tag: class: 'home-testimonials__card-split-image', loading: 'lazy' }}
              {% else %}
                {{ 'lifestyle-2' | placeholder_svg_tag: 'home-testimonials__card-split-image home-testimonials__card-placeholder' }}
              {% endif %}
            </div>
            <div class="home-testimonials__card-quote home-testimonials__card-quote--{{ block.settings.style }}">
              <div class="home-testimonials__card-quote-inner">
                <p class="home-testimonials__quote-text">{{ block.settings.quote }}</p>
                <div class="home-testimonials__quote-author">
                  <span class="home-testimonials__author-name">{{ block.settings.author_name }}</span>
                  <span class="home-testimonials__author-role">{{ block.settings.author_role }}</span>
                </div>
              </div>
            </div>
          </div>
      {% endcase %}
    {% endfor %}
  </div>
</div>

{% stylesheet %}
  .home-testimonials {
    background-color: var(--theme-surface);
    padding: 52px 0;
    display: flex;
    flex-direction: column;
    gap: 52px;
  }

  .home-testimonials__container {
    max-width: var(--container-max, 1200px);
    margin: 0 auto;
    padding: 0 52px;
    width: 100%;
    box-sizing: border-box;
  }

  /* Header */
  .home-testimonials__header {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: flex-end;
  }

  .home-testimonials__header-left {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .home-testimonials__tag {
    display: inline-flex;
    align-self: flex-start;
    background-color: var(--theme-surface-alt);
    border-radius: var(--theme-radius-badge);
    padding: 4px 12px;
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    color: var(--theme-primary);
    letter-spacing: 1.44px;
    line-height: 1.4;
  }

  .home-testimonials__heading {
    font-size: 52px;
    line-height: 64px;
    color: var(--theme-primary);
    letter-spacing: -2.08px;
    max-width: 696px;
    margin: 0;
    font-weight: 700;
  }

  .home-testimonials__header-right {
    display: flex;
    flex-direction: row;
    gap: 16px;
    align-items: center;
    flex-shrink: 0;
  }

  .home-testimonials__rating {
    font-size: 52px;
    line-height: 64px;
    color: var(--theme-primary);
    letter-spacing: -2.08px;
    font-weight: 700;
  }

  .home-testimonials__stars-wrap {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .home-testimonials__stars {
    display: flex;
    flex-direction: row;
    gap: 8px;
  }

  .home-testimonials__review-count {
    font-size: 14px;
    font-weight: 500;
    color: var(--theme-text);
    letter-spacing: 1.4px;
    text-transform: uppercase;
  }

  /* Testimonials row */
  .home-testimonials__row {
    display: flex;
    gap: 24px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -ms-overflow-style: none;
    scrollbar-width: none;
    padding: 0 52px;
  }

  .home-testimonials__row::-webkit-scrollbar {
    display: none;
  }

  /* Base card */
  .home-testimonials__card {
    flex: 0 0 276px;
    width: 276px;
    height: 394px;
    scroll-snap-align: start;
  }

  /* Video card */
  .home-testimonials__card--video {
    border-radius: var(--theme-radius-image);
    overflow: hidden;
    position: relative;
  }

  .home-testimonials__card--video .home-testimonials__card-image,
  .home-testimonials__card--video .home-testimonials__card-placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .home-testimonials__card--video .home-testimonials__card-placeholder {
    background-color: var(--theme-surface-alt);
  }

  .home-testimonials__play-btn {
    position: absolute;
    top: 12px;
    left: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 12px;
    border-radius: var(--theme-radius-card);
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: rgba(255, 255, 255, 0.12);
    backdrop-filter: blur(50px);
    -webkit-backdrop-filter: blur(50px);
    cursor: pointer;
    line-height: 0;
  }

  .home-testimonials__play-btn:focus-visible {
    outline: 2px solid var(--color-focus, var(--theme-primary));
    outline-offset: 2px;
  }

  /* Split card */
  .home-testimonials__card--split {
    display: flex;
    flex-direction: column;
    gap: 0;
    border-radius: var(--theme-radius-image);
    overflow: hidden;
  }

  .home-testimonials__card--split-bottom {
    flex-direction: column-reverse;
  }

  .home-testimonials__card-image-half {
    flex: 1;
    overflow: hidden;
    min-height: 0;
  }

  .home-testimonials__card-split-image,
  .home-testimonials__card-image-half .home-testimonials__card-placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .home-testimonials__card-image-half .home-testimonials__card-placeholder {
    background-color: var(--theme-surface-alt);
  }

  .home-testimonials__card-quote {
    padding: 8px;
    border-radius: 0;
  }

  .home-testimonials__card--split-top .home-testimonials__card-image-half {
    border-radius: var(--theme-radius-image);
    overflow: hidden;
  }

  .home-testimonials__card--split-top .home-testimonials__card-quote {
    border-radius: var(--theme-radius-image);
  }

  .home-testimonials__card--split-bottom .home-testimonials__card-image-half {
    border-radius: var(--theme-radius-image);
    overflow: hidden;
  }

  .home-testimonials__card--split-bottom .home-testimonials__card-quote {
    border-radius: var(--theme-radius-image);
  }

  .home-testimonials__card-quote--light {
    background-color: var(--theme-surface-alt);
  }

  .home-testimonials__card-quote--dark {
    background-color: var(--theme-primary);
  }

  .home-testimonials__card-quote-inner {
    padding: 8px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    text-align: center;
    justify-content: center;
    height: 100%;
  }

  .home-testimonials__quote-text {
    font-size: 20px;
    line-height: 28px;
    margin: 0;
  }

  .home-testimonials__card-quote--light .home-testimonials__quote-text {
    color: var(--theme-primary);
  }

  .home-testimonials__card-quote--dark .home-testimonials__quote-text {
    color: var(--theme-text-on-primary);
  }

  .home-testimonials__quote-author {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .home-testimonials__author-name {
    font-size: 16px;
    font-weight: 500;
  }

  .home-testimonials__card-quote--light .home-testimonials__author-name {
    color: var(--theme-primary);
  }

  .home-testimonials__card-quote--dark .home-testimonials__author-name {
    color: var(--theme-text-on-primary);
  }

  .home-testimonials__author-role {
    font-size: 14px;
  }

  .home-testimonials__card-quote--light .home-testimonials__author-role {
    color: var(--theme-text-secondary);
  }

  .home-testimonials__card-quote--dark .home-testimonials__author-role {
    color: var(--theme-text-muted);
  }

  /* Mobile */
  @media screen and (max-width: 749px) {
    .home-testimonials {
      padding: 24px 0;
    }

    .home-testimonials__container {
      padding: 0 20px;
    }

    .home-testimonials__row {
      padding: 0 20px;
    }

    .home-testimonials__header {
      flex-direction: column;
      align-items: flex-start;
      gap: 24px;
    }

    .home-testimonials__heading {
      font-size: 32px;
      line-height: 40px;
      letter-spacing: -1.28px;
    }

    .home-testimonials__rating {
      font-size: 32px;
      line-height: 40px;
      letter-spacing: -1.28px;
    }

    .home-testimonials__card {
      flex: 0 0 240px;
      width: 240px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.home_testimonials.name",
  "settings": [
    {
      "type": "text",
      "id": "tag_text",
      "label": "t:labels.tag_text",
      "default": "Testimonials"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "What our customer say?"
    },
    {
      "type": "text",
      "id": "rating",
      "label": "t:labels.rating",
      "default": "4.9"
    },
    {
      "type": "text",
      "id": "review_count",
      "label": "t:labels.review_count",
      "default": "10,078+"
    }
  ],
  "blocks": [
    {
      "type": "video_card",
      "name": "t:sections.home_testimonials.blocks.video_card.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:labels.image"
        }
      ]
    },
    {
      "type": "quote_card",
      "name": "t:sections.home_testimonials.blocks.quote_card.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:labels.image"
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "t:labels.quote",
          "default": "I've tried many probiotics, but this is the first one that actually made a difference."
        },
        {
          "type": "text",
          "id": "author_name",
          "label": "t:labels.author_name",
          "default": "Bobby"
        },
        {
          "type": "text",
          "id": "author_role",
          "label": "t:labels.author_role",
          "default": "Influencer"
        },
        {
          "type": "select",
          "id": "style",
          "label": "t:labels.style",
          "options": [
            { "value": "light", "label": "t:options.style.light" },
            { "value": "dark", "label": "t:options.style.dark" }
          ],
          "default": "light"
        },
        {
          "type": "select",
          "id": "image_position",
          "label": "t:labels.image_position",
          "options": [
            { "value": "top", "label": "t:options.image_position.top" },
            { "value": "bottom", "label": "t:options.image_position.bottom" }
          ],
          "default": "top"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.home_testimonials.name",
      "blocks": [
        { "type": "video_card" },
        { "type": "video_card" },
        {
          "type": "quote_card",
          "settings": {
            "style": "light",
            "image_position": "top"
          }
        },
        { "type": "video_card" },
        {
          "type": "quote_card",
          "settings": {
            "style": "dark",
            "image_position": "bottom"
          }
        },
        { "type": "video_card" }
      ]
    }
  ]
}
{% endschema %}

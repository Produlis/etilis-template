          "default": true
        },
        {
          "type": "checkbox",
          "id": "competitor_has",
          "label": "t:labels.competitor_has",
          "default": false
        }
      ]
    },
    {
      "type": "trust_badge",
      "name": "t:sections.home_comparison.blocks.trust_badge.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "t:labels.icon"
        },
        {
          "type": "text",
          "id": "text",
          "label": "t:labels.text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.home_comparison.name",
      "blocks": [
        {
          "type": "comparison_row",
          "settings": {
            "label": "Premium quality materials",
            "brand_has": true,
            "competitor_has": false
          }
        },
        {
          "type": "comparison_row",
          "settings": {
            "label": "Designed for long-lasting durability",
            "brand_has": true,
            "competitor_has": false
          }
        },
        {
          "type": "comparison_row",
          "settings": {
            "label": "Backed by independent testing",
            "brand_has": true,
            "competitor_has": false
          }
        },
        {
          "type": "comparison_row",
          "settings": {
            "label": "Ethically sourced and sustainably made",
            "brand_has": true,
            "competitor_has": false
          }
        },
        {
          "type": "comparison_row",
          "settings": {
            "label": "Satisfaction guarantee included",
            "brand_has": true,
            "competitor_has": false
          }
        },
        {
          "type": "trust_badge",
          "settings": {
            "text": "Limited stock available"
          }
        },
        {
          "type": "trust_badge",
          "settings": {
            "text": "FREE Shipping & Returns"
          }
        },
        {
          "type": "trust_badge",
          "settings": {
            "text": "Money-back guarantee"
          }
        }
      ]
    }
  ]
}
{% endschema %}

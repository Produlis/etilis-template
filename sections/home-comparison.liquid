<div class="home-comparison full-width" style="--bg-color: var(--theme-primary);">
  {% if section.settings.background_image %}
    <div class="home-comparison__background">
      {{ section.settings.background_image | image_url: width: 2000 | image_tag: loading: 'lazy' }}
    </div>
  {% endif %}

  <div class="home-comparison__inner">
    <div class="home-comparison__header">
      {% if section.settings.tag_text != blank %}
        <span class="home-comparison__tag">{{ section.settings.tag_text }}</span>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="home-comparison__heading">{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.description != blank %}
        <p class="home-comparison__subtitle">{{ section.settings.description }}</p>
      {% endif %}
    </div>

    <div class="home-comparison__table-area">
      {%- assign comparison_rows = section.blocks | where: 'type', 'comparison_row' -%}
      {%- assign trust_badges = section.blocks | where: 'type', 'trust_badge' -%}

      <div class="home-comparison__table-card">
        <div class="home-comparison__labels-col">
          <div class="home-comparison__label-spacer" aria-hidden="true"></div>
          {%- for block in comparison_rows -%}
            <div class="home-comparison__label-row" {{ block.shopify_attributes }}>
              {{ block.settings.label }}
            </div>
          {%- endfor -%}
        </div>

        <div class="home-comparison__brand-col">
          <div class="home-comparison__col-header">
            {{ section.settings.brand_name }}
          </div>
          {%- for block in comparison_rows -%}
            <div class="home-comparison__check-row">
              {%- if block.settings.brand_has -%}
                <svg
                  class="home-comparison__icon-check"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  aria-label="{{ 'accessibility.checkmark' | t }}"
                >
                  <circle cx="12" cy="12" r="10"/><path d="M8 12l3 3 5-5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              {%- else -%}
                <svg
                  class="home-comparison__icon-x"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  aria-label="{{ 'accessibility.x_mark' | t }}"
                >
                  <circle cx="12" cy="12" r="10"/><path d="M9 9l6 6M15 9l-6 6" stroke-width="2" stroke-linecap="round"/>
                </svg>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>

        <div class="home-comparison__competitor-col">
          <div class="home-comparison__col-header">
            {{ section.settings.competitor_name }}
          </div>
          {%- for block in comparison_rows -%}
            <div class="home-comparison__check-row">
              {%- if block.settings.competitor_has -%}
                <svg
                  class="home-comparison__icon-check"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  aria-label="{{ 'accessibility.checkmark' | t }}"
                >
                  <circle cx="12" cy="12" r="10"/><path d="M8 12l3 3 5-5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              {%- else -%}
                <svg
                  class="home-comparison__icon-x"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  aria-label="{{ 'accessibility.x_mark' | t }}"
                >
                  <circle cx="12" cy="12" r="10"/><path d="M9 9l6 6M15 9l-6 6" stroke-width="2" stroke-linecap="round"/>
                </svg>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>
      </div>

      {% if trust_badges.size > 0 %}
        <div class="home-comparison__badges">
          {%- for block in trust_badges -%}
            <div class="home-comparison__badge" {{ block.shopify_attributes }}>
              {%- if block.settings.icon -%}
                <div class="home-comparison__badge-icon">
                  {{ block.settings.icon | image_url: width: 32 | image_tag: loading: 'lazy' }}
                </div>
              {%- endif -%}
              {%- if block.settings.text != blank -%}
                <span class="home-comparison__badge-text">{{ block.settings.text }}</span>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% stylesheet %}
  .home-comparison {
    position: relative;
    border-radius: var(--theme-radius-card);
    overflow: hidden;
    padding: var(--space-13);
    background-color: var(--bg-color, var(--theme-primary));
  }

  .home-comparison__background {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }

  .home-comparison__background img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .home-comparison__inner {
    position: relative;
    z-index: 1;
    -webkit-backdrop-filter: blur(50px);
    backdrop-filter: blur(50px);
    background: var(--color-dark-glass-bg);
    border: 1px solid var(--color-glass-border);
    border-radius: var(--theme-radius-card);
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
    max-width: 1200px;
    margin: 0 auto;
  }

  .home-comparison__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  .home-comparison__tag {
    display: inline-block;
    background: var(--color-on-primary-subtle);
    border-radius: var(--theme-radius-badge);
    padding: var(--space-1) var(--space-3);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-medium);
    text-transform: uppercase;
    color: var(--theme-text-on-primary);
    letter-spacing: var(--letter-spacing-wider);
    line-height: var(--line-height-normal);
  }

  .home-comparison__heading {
    font-size: var(--font-size-5xl);
    line-height: var(--line-height-tight);
    color: var(--theme-text-on-primary);
    text-align: center;
    letter-spacing: var(--letter-spacing-tighter);
    margin: 0;
  }

  .home-comparison__subtitle {
    font-size: var(--font-size-base);
    line-height: var(--line-height-normal);
    color: var(--theme-text-muted);
    text-align: center;
    margin: 0;
  }

  .home-comparison__table-area {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--space-9);
  }

  .home-comparison__table-card {
    -webkit-backdrop-filter: blur(20px);
    backdrop-filter: blur(20px);
    background: var(--color-glass-bg);
    border: 1px solid var(--color-glass-border);
    border-radius: var(--theme-radius-card);
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    min-height: 392px;
    padding: var(--space-2) var(--space-2) var(--space-2) var(--space-6);
  }

  .home-comparison__labels-col {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: var(--space-4) 0;
    justify-content: flex-end;
  }

  .home-comparison__label-spacer {
    height: 48px;
  }

  .home-comparison__label-row {
    height: 48px;
    display: flex;
    align-items: center;
    font-size: var(--font-size-base);
    color: var(--theme-text-on-primary);
  }

  .home-comparison__brand-col {
    min-width: 0;
    -webkit-backdrop-filter: blur(20px);
    backdrop-filter: blur(20px);
    background: var(--color-glass-bg);
    border: 1px solid var(--color-glass-border);
    border-radius: var(--theme-radius-card);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    align-items: center;
    padding: var(--space-4) var(--space-2);
  }

  .home-comparison__competitor-col {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    align-items: center;
    padding: var(--space-4) 0;
    border-radius: var(--theme-radius-image);
  }

  .home-comparison__col-header {
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--font-size-base);
    color: var(--theme-text-on-primary);
    letter-spacing: var(--letter-spacing-tighter);
    font-weight: var(--font-weight-medium);
  }

  .home-comparison__check-row {
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .home-comparison__icon-check circle {
    fill: var(--theme-text-on-primary);
  }

  .home-comparison__icon-check path {
    stroke: var(--theme-primary);
  }

  .home-comparison__icon-x circle {
    fill: var(--color-x-mark-bg);
  }

  .home-comparison__icon-x path {
    stroke: var(--color-x-mark-stroke);
  }

  .home-comparison__badges {
    display: flex;
    gap: var(--space-2);
    width: 100%;
  }

  .home-comparison__badge {
    flex: 1;
    height: 44px;
    -webkit-backdrop-filter: blur(20px);
    backdrop-filter: blur(20px);
    background: var(--color-glass-bg);
    border: 1px solid var(--color-glass-border);
    border-radius: var(--theme-radius-card);
    display: flex;
    align-items: center;
    padding: 0 var(--space-3);
    gap: var(--space-2);
  }

  .home-comparison__badge-icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  .home-comparison__badge-icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .home-comparison__badge-text {
    font-size: var(--font-size-sm);
    color: var(--theme-text-on-primary);
    white-space: nowrap;
  }

  @media (max-width: 989px) {
    .home-comparison {
      padding: var(--space-8);
    }

    .home-comparison__heading {
      font-size: var(--font-size-4xl);
    }

    .home-comparison__table-card {
      min-height: auto;
    }

    .home-comparison__badge-text {
      white-space: normal;
    }
  }

  @media (max-width: 749px) {
    .home-comparison {
      padding: var(--space-6) var(--space-4);
      border-radius: var(--theme-radius-card);
    }

    .home-comparison__inner {
      padding: var(--space-2);
      gap: var(--space-8);
    }

    .home-comparison__heading {
      font-size: var(--font-size-3xl);
      line-height: var(--line-height-tight);
      letter-spacing: var(--letter-spacing-tighter);
    }

    .home-comparison__table-card {
      display: flex;
      gap: var(--space-2);
      padding: var(--space-2) var(--space-2) var(--space-2) var(--space-4);
      border-radius: 16px;
      min-height: auto;
    }

    .home-comparison__labels-col {
      flex: 1;
      min-width: 0;
      gap: var(--space-4);
    }

    .home-comparison__label-spacer {
      height: auto;
      min-height: 24px;
    }

    .home-comparison__label-row {
      font-size: var(--font-size-sm);
      height: 48px;
      line-height: var(--line-height-snug);
    }

    .home-comparison__brand-col {
      flex: 0 0 72px;
      border-radius: 8px;
      gap: var(--space-4);
    }

    .home-comparison__competitor-col {
      flex: 0 0 72px;
      gap: var(--space-4);
    }

    .home-comparison__col-header {
      height: auto;
      min-height: 24px;
      font-size: var(--font-size-base);
    }

    .home-comparison__check-row {
      height: 48px;
    }

    .home-comparison__icon-check,
    .home-comparison__icon-x {
      width: 20px;
      height: 20px;
    }

    .home-comparison__icon-check svg,
    .home-comparison__icon-x svg {
      width: 20px;
      height: 20px;
    }

    .home-comparison__badges {
      flex-direction: column;
      gap: var(--space-2);
    }

    .home-comparison__badge {
      flex: none;
      width: 100%;
      height: 44px;
      border-radius: 24px;
      padding: var(--space-2) var(--space-2) var(--space-2) var(--space-3);
      -webkit-backdrop-filter: blur(20px);
      backdrop-filter: blur(20px);
      background: var(--color-glass-bg);
      border: 1px solid var(--color-glass-border);
    }

    .home-comparison__badge-text {
      font-size: var(--font-size-sm);
      white-space: nowrap;
    }
  }
{% endstylesheet %}

{% schema %}

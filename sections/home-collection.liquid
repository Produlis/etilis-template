{% render 'swiper-loader' %}

<div class="home-collection full-width">
  <div class="home-collection__container">
    <div class="home-collection__header">
      {% if section.settings.tag_text != blank %}
        <span class="home-collection__tag">{{ section.settings.tag_text }}</span>
      {% endif %}

      {%- liquid
        if section.settings.collection != blank
          assign heading_text = section.settings.collection.title
          assign description_text = section.settings.collection.description | strip_html
        else
          assign heading_text = section.settings.heading
          assign description_text = section.settings.description
        endif
      -%}
      {% if heading_text != blank %}
        <h2 class="home-collection__heading">{{ heading_text }}</h2>
      {% endif %}

      {% if description_text != blank %}
        <p class="home-collection__subtitle">{{ description_text }}</p>
      {% endif %}
    </div>

    <div class="home-collection__slider">
      <div
        class="swiper home-collection__swiper"
        data-section-id="{{ section.id }}"
        data-autoplay="{{ section.settings.autoplay }}"
        data-autoplay-speed="{{ section.settings.autoplay_speed }}"
        data-loop="{{ section.settings.loop }}"
        data-slides-desktop="{{ section.settings.slides_desktop }}"
        data-slides-mobile="{{ section.settings.slides_mobile }}"
        role="list"
        aria-label="{{ 'sections.home_collection.aria_products' | t }}"
      >
        <div class="swiper-wrapper">
          {% if section.settings.collection != blank %}
            {% for product in section.settings.collection.products limit: 8 %}
              <div class="swiper-slide home-collection__slide" role="listitem">
                <article class="home-collection__card">
                  <div class="home-collection__card-image">
                    {% if product.featured_image %}
                      {{ product.featured_image | image_url: width: 400 | image_tag: class: 'home-collection__img', loading: 'lazy' }}
                    {% else %}
                      <div class="home-collection__img-placeholder">
                        {{ 'product-1' | placeholder_svg_tag: 'home-collection__placeholder-svg' }}
                      </div>
                    {% endif %}

                    {% if product.compare_at_price > product.price %}
                      <span class="home-collection__badge" aria-label="{{ 'products.sale' | t }}">
                        <svg class="home-collection__badge-icon" width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                          <path d="M10.5 5.25L6.75 1.5L1.5 1.5L1.5 6.75L5.25 10.5L10.5 5.25Z" stroke="var(--theme-primary)" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                          <circle cx="3.75" cy="3.75" r="0.75" fill="var(--theme-primary)"/>
                        </svg>
                        <span>{{ 'products.sale' | t }}</span>
                      </span>
                    {% endif %}
                  </div>

                  <div class="home-collection__card-info">
                    <h3 class="home-collection__card-title">
                      <a href="{{ product.url }}">{{ product.title }}</a>
                    </h3>

                    {%- assign rating = product.metafields.reviews.rating -%}
                    {%- assign rating_count = product.metafields.reviews.rating_count -%}
                    {%- if rating != blank -%}
                      {%- assign rating_value = rating.value.rating | round: 1 -%}
                      {%- assign rating_whole = rating_value | floor -%}
                      {%- assign rating_decimal = rating_value | minus: rating_whole -%}
                      {%- assign rating_next = rating_whole | plus: 1 -%}
                      <div class="home-collection__card-rating" aria-label="{{ 'sections.home_collection.rating_label' | t: rating: rating_value }}">
                        {%- for i in (1..5) -%}
                          {%- if i <= rating_whole -%}
                            <svg width="16" height="16" viewBox="0 0 16 16" fill="var(--theme-star)" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                              <path d="M8 1.33L10.06 5.5L14.67 6.18L11.33 9.43L12.12 14.02L8 11.85L3.88 14.02L4.67 9.43L1.33 6.18L5.94 5.5L8 1.33Z"/>
                            </svg>
                          {%- elsif i == rating_next -%}
                            {%- if rating_decimal >= 0.5 -%}
                              <svg width="16" height="16" viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                                <defs>
                                  <clipPath id="half-star-{{ product.id }}-{{ i }}">
                                    <rect x="0" y="0" width="8" height="16"/>
                                  </clipPath>
                                </defs>
                                <path d="M8 1.33L10.06 5.5L14.67 6.18L11.33 9.43L12.12 14.02L8 11.85L3.88 14.02L4.67 9.43L1.33 6.18L5.94 5.5L8 1.33Z" fill="var(--theme-star-empty, #d9d9d9)"/>
                                <path d="M8 1.33L10.06 5.5L14.67 6.18L11.33 9.43L12.12 14.02L8 11.85L3.88 14.02L4.67 9.43L1.33 6.18L5.94 5.5L8 1.33Z" fill="var(--theme-star)" clip-path="url(#half-star-{{ product.id }}-{{ i }})"/>
                              </svg>
                            {%- else -%}
                              <svg width="16" height="16" viewBox="0 0 16 16" fill="var(--theme-star-empty, #d9d9d9)" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                                <path d="M8 1.33L10.06 5.5L14.67 6.18L11.33 9.43L12.12 14.02L8 11.85L3.88 14.02L4.67 9.43L1.33 6.18L5.94 5.5L8 1.33Z"/>
                              </svg>
                            {%- endif -%}
                          {%- else -%}
                            <svg width="16" height="16" viewBox="0 0 16 16" fill="var(--theme-star-empty, #d9d9d9)" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                              <path d="M8 1.33L10.06 5.5L14.67 6.18L11.33 9.43L12.12 14.02L8 11.85L3.88 14.02L4.67 9.43L1.33 6.18L5.94 5.5L8 1.33Z"/>
                            </svg>
                          {%- endif -%}
                        {%- endfor -%}
                        {%- if rating_count != blank and rating_count.value > 0 -%}
                          <span class="home-collection__review-count">({{ rating_count.value }})</span>
                        {%- endif -%}
                      </div>
                    {%- endif -%}

                    <div class="home-collection__card-price">
                      <span class="home-collection__price">{{ product.price | money }}</span>
                      {% if product.compare_at_price > product.price %}
                        <span class="home-collection__compare-price">{{ product.compare_at_price | money }}</span>
                      {% endif %}
                    </div>
                  </div>

                  {%- assign first_available_variant = product.selected_or_first_available_variant -%}
                  <button
                    type="button"
                    class="home-collection__card-button"
                    data-add-to-cart="{{ first_available_variant.id }}"
                    aria-label="{{ 'products.add_to_cart' | t }}: {{ product.title }}"
                    {% unless first_available_variant.available %}disabled{% endunless %}
                  >
                    {%- if first_available_variant.available -%}
                      {{ 'products.add_to_cart' | t }}
                    {%- else -%}
                      {{ 'products.sold_out' | t }}
                    {%- endif -%}
                  </button>
                </article>
              </div>
            {% endfor %}
          {% else %}
            {%- assign placeholder_names = 'Daily Multivitamin,Sleep + Restore,Daily Synbiotic,Pediatric Synbiotic,Gut Health Plus,Immune Support,Probiotic Boost,Fiber Balance' | split: ',' -%}
            {%- assign placeholder_images = 'product-1,product-2,product-3,product-4,product-5,product-6,product-1,product-2' | split: ',' -%}
            {% for name in placeholder_names %}
              <div class="swiper-slide home-collection__slide" role="listitem">
                <article class="home-collection__card">
                  <div class="home-collection__card-image">
                    <div class="home-collection__img-placeholder">
                      {{ placeholder_images[forloop.index0] | placeholder_svg_tag: 'home-collection__placeholder-svg' }}
                    </div>
                    <span class="home-collection__badge" aria-label="{{ 'products.sale' | t }}">
                      <svg class="home-collection__badge-icon" width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path d="M10.5 5.25L6.75 1.5L1.5 1.5L1.5 6.75L5.25 10.5L10.5 5.25Z" stroke="var(--theme-primary)" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                        <circle cx="3.75" cy="3.75" r="0.75" fill="var(--theme-primary)"/>
                      </svg>
                      <span>{{ 'products.sale' | t }}</span>
                    </span>
                  </div>

                  <div class="home-collection__card-info">
                    <h3 class="home-collection__card-title">{{ name }}</h3>

                    <div class="home-collection__card-rating" aria-label="{{ 'sections.home_collection.star_rating' | t }}">
                      {% for i in (1..5) %}
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="var(--theme-star)" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                          <path d="M8 1.33L10.06 5.5L14.67 6.18L11.33 9.43L12.12 14.02L8 11.85L3.88 14.02L4.67 9.43L1.33 6.18L5.94 5.5L8 1.33Z"/>
                        </svg>
                      {% endfor %}
                      <span class="home-collection__review-count">(1,983)</span>
                    </div>

                    <div class="home-collection__card-price">
                      <span class="home-collection__price">$109.00</span>
                      <span class="home-collection__compare-price">$199.99</span>
                    </div>
                  </div>

                  <span class="home-collection__card-button">
                    {{ 'products.add_to_cart' | t }}
                  </span>
                </article>
              </div>
            {% endfor %}
          {% endif %}
        </div>
      </div>

      <button class="home-collection__nav-btn home-collection__nav-btn--prev" aria-label="{{ 'sections.home_collection.prev_slide' | t }}">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M12.5 15L7.5 10L12.5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
      <button class="home-collection__nav-btn home-collection__nav-btn--next" aria-label="{{ 'sections.home_collection.next_slide' | t }}">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M7.5 15L12.5 10L7.5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </div>
  </div>
</div>

{% stylesheet %}
  .home-collection {
    width: 100%;
    padding: 0 24px;
    box-sizing: border-box;
  }

  .home-collection__container {
    background-color: var(--theme-primary);
    border-radius: var(--theme-radius-card);
    padding: 24px 52px 52px;
    overflow: hidden;
    max-width: var(--container-max, 1200px);
    margin: 0 auto;
  }

  .home-collection__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    text-align: center;
    margin-bottom: 40px;
  }

  .home-collection__tag {
    display: inline-block;
    background: rgba(255, 255, 255, 0.2);
    border-radius: var(--theme-radius-badge);
    padding: 4px 12px;
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-medium);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wider);
    color: var(--theme-text-on-primary);
    line-height: var(--line-height-normal);
  }

  .home-collection__heading {
    font-size: var(--font-size-5xl);
    line-height: var(--line-height-tight);
    letter-spacing: var(--letter-spacing-tighter);
    color: var(--theme-text-on-primary);
    margin: 0;
    font-weight: var(--font-weight-bold);
  }

  .home-collection__subtitle {
    font-size: var(--font-size-base);
    line-height: var(--line-height-normal);
    color: var(--theme-text-muted);
    margin: 0;
    max-width: 560px;
  }

  .home-collection__slider {
    position: relative;
  }

  .home-collection__swiper {
    overflow: hidden;
  }

  .home-collection__card {
    width: 100%;
    background: var(--theme-primary-light);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: var(--theme-radius-card);
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    height: 100%;
    box-sizing: border-box;
  }

  /* Navigation */
  .home-collection__nav-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: var(--radius-round);
    border: 1px solid rgba(255, 255, 255, 0.2);
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    color: var(--theme-text-on-primary);
    cursor: pointer;
    transition: background-color 150ms ease, border-color 150ms ease;
  }

  .home-collection__nav-btn--prev {
    left: 8px;
  }

  .home-collection__nav-btn--next {
    right: 8px;
  }

  .home-collection__nav-btn:hover {
    background-color: rgba(255, 255, 255, 0.2);
    border-color: rgba(255, 255, 255, 0.4);
  }

  .home-collection__nav-btn:focus-visible {
    outline: 2px solid var(--color-focus, var(--theme-text-on-primary));
    outline-offset: 2px;
  }

  .home-collection__nav-btn.swiper-button-disabled {
    opacity: 0;
    pointer-events: none;
  }

  .home-collection__card-image {
    position: relative;
    height: 200px;
    border-radius: var(--theme-radius-image);
    overflow: hidden;
    background: rgba(255, 255, 255, 0.05);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .home-collection__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .home-collection__img-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.08);
  }

  .home-collection__placeholder-svg {
    width: 60%;
    height: auto;
    opacity: 0.5;
  }

  .home-collection__badge {
    position: absolute;
    top: 8px;
    left: 8px;
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 4px;
    background: var(--theme-accent);
    border-radius: var(--theme-radius-badge);
    padding: 4px 8px;
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    text-transform: uppercase;
    color: var(--theme-text-on-primary);
    line-height: var(--line-height-none);
  }

  .home-collection__badge-icon {
    flex-shrink: 0;
  }

  .home-collection__card-info {
    display: flex;
    flex-direction: column;
    gap: 12px;
    align-items: center;
    text-align: center;
  }

  .home-collection__card-title {
    font-size: var(--font-size-2xl);
    line-height: var(--line-height-snug);
    letter-spacing: var(--letter-spacing-tighter);
    color: var(--theme-text-on-primary);
    margin: 0;
    font-weight: var(--font-weight-semibold);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .home-collection__card-title a {
    color: inherit;
    text-decoration: none;
  }

  .home-collection__card-title a:hover {
    text-decoration: underline;
  }

  .home-collection__card-title a:focus-visible {
    outline: 2px solid var(--color-focus, var(--theme-text-on-primary));
    outline-offset: 2px;
    border-radius: var(--radius-sm);
  }

  .home-collection__card-rating {
    display: flex;
    align-items: center;
    gap: 2px;
  }

  .home-collection__review-count {
    font-size: var(--font-size-xs);
    color: var(--theme-text-muted);
    margin-left: 4px;
  }

  .home-collection__card-price {
    display: flex;
    align-items: baseline;
    gap: 8px;
  }

  .home-collection__price {
    font-size: var(--font-size-base);
    color: var(--theme-text-on-primary);
    font-weight: var(--font-weight-semibold);
  }

  .home-collection__compare-price {
    font-size: var(--font-size-xs);
    color: var(--theme-text-muted);
    text-decoration: line-through;
  }

  .home-collection__card-button {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 48px;
    background: var(--theme-text-on-primary);
    border-radius: var(--theme-radius-button);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    color: var(--theme-primary);
    text-decoration: none;
    cursor: pointer;
    border: none;
    transition: opacity var(--duration-fast, 150ms) var(--ease-standard, ease);
    margin-top: auto;
  }

  .home-collection__card-button:hover {
    opacity: 0.9;
  }

  .home-collection__card-button:focus-visible {
    outline: 2px solid var(--color-focus, var(--theme-text-on-primary));
    outline-offset: 2px;
  }

  .home-collection__card-button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  @media (max-width: 749px) {
    .home-collection {
      padding: 0 12px;
    }

    .home-collection__container {
      padding: 24px 20px;
      border-radius: var(--theme-radius-card);
    }

    .home-collection__heading {
      font-size: var(--font-size-3xl);
      line-height: var(--line-height-tight);
      letter-spacing: var(--letter-spacing-tighter);
    }

  }
{% endstylesheet %}

{% javascript %}
  function initHomeCollectionSwiper(container) {
    var el = container.querySelector('.home-collection__swiper');
    if (!el) return;

    if (el.swiper) el.swiper.destroy(true, true);

    var autoplay = el.dataset.autoplay === 'true';
    var autoplaySpeed = parseInt(el.dataset.autoplaySpeed, 10) || 5000;
    var loop = el.dataset.loop === 'true';
    var slidesDesktop = parseInt(el.dataset.slidesDesktop, 10) || 4;
    var slidesMobile = parseInt(el.dataset.slidesMobile, 10) || 2;

    var parent = el.closest('.home-collection__slider');
    var prevBtn = parent.querySelector('.home-collection__nav-btn--prev');
    var nextBtn = parent.querySelector('.home-collection__nav-btn--next');

    new Swiper(el, {
      slidesPerView: slidesMobile,
      spaceBetween: 12,
      loop: loop,
      autoplay: autoplay ? { delay: autoplaySpeed, disableOnInteraction: false } : false,
      navigation: {
        prevEl: prevBtn,
        nextEl: nextBtn
      },
      breakpoints: {
        750: {
          slidesPerView: slidesDesktop,
          spaceBetween: 16
        }
      }
    });
  }

  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('.home-collection').forEach(initHomeCollectionSwiper);
  });

  document.addEventListener('shopify:section:load', function (event) {
    var section = event.target;
    if (section.querySelector('.home-collection__swiper')) {
      initHomeCollectionSwiper(section);
    }
  });

  document.addEventListener('click', function (e) {
    var btn = e.target.closest('[data-add-to-cart]');
    if (!btn) return;

    var variantId = btn.dataset.addToCart;
    var originalText = btn.textContent;
    btn.disabled = true;
    btn.textContent = '...';

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: variantId, quantity: 1 })
    })
      .then(function (res) {
        if (!res.ok) throw new Error('Add to cart failed');
        return res.json();
      })
      .then(function () {
        btn.textContent = originalText;
        btn.disabled = false;

        var cartTrigger = document.querySelector('[data-cart-drawer-trigger]');
        if (cartTrigger) cartTrigger.click();
      })
      .catch(function () {
        btn.textContent = originalText;
        btn.disabled = false;
      });
  });
{% endjavascript %}

{% schema %}
{
  "name": "t:sections.home_collection.name",
  "settings": [
    {
      "type": "text",
      "id": "tag_text",
      "label": "t:labels.tag",
      "default": "Collections"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Greenish Collection"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "t:labels.description",
      "default": "Whole body health, made possible by your microbiome"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "t:general.collection"
    },
    {
      "type": "range",
      "id": "slides_desktop",
      "label": "t:labels.slides_desktop",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "slides_mobile",
      "label": "t:labels.slides_mobile",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "t:labels.autoplay",
      "default": false
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "t:labels.autoplay_speed",
      "min": 2000,
      "max": 9000,
      "step": 500,
      "unit": "ms",
      "default": 5000
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "t:labels.loop",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "t:sections.home_collection.name"
    }
  ]
}
{% endschema %}

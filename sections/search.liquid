<section class="search-page full-width">
  <div class="search-page__container">

    {%- comment -%} Header {%- endcomment -%}
    <div class="search-page__header">
      <h1 class="search-page__heading">{{ 'search.title' | t }}</h1>

      <form action="{{ routes.search_url }}" method="get" role="search" class="search-page__form">
        <div class="search-page__input-wrapper">
          <svg class="search-page__input-icon" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <circle cx="9" cy="9" r="6" stroke="currentColor" stroke-width="1.5"/>
            <path d="M13.5 13.5L17 17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <input
            type="search"
            name="q"
            class="search-page__input"
            value="{{ search.terms | escape }}"
            placeholder="{{ 'search.placeholder' | t }}"
            autocomplete="off"
            aria-label="{{ 'search.placeholder' | t }}"
          >
          <button type="submit" class="search-page__submit btn btn--primary">
            {{ 'search.submit' | t }}
          </button>
        </div>
        <input type="hidden" name="type" value="product,article,page">
      </form>
    </div>

    {%- comment -%} Results {%- endcomment -%}
    {% if search.performed %}
      {% if search.results_count == 0 %}
        <div class="search-page__empty">
          <div class="search-page__empty-icon">
            <svg width="64" height="64" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <circle cx="28" cy="28" r="18" stroke="currentColor" stroke-width="2"/>
              <path d="M42 42L56 56" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              <path d="M22 28h12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </div>
          <p class="search-page__empty-title">{{ 'search.no_results' | t }}</p>
          <p class="search-page__empty-text">{{ 'search.no_results_html' | t: terms: search.terms }}</p>
          <p class="search-page__empty-hint">{{ 'search.try_different' | t }}</p>
        </div>

      {% else %}
        <p class="search-page__count">
          {{ 'search.results_for_html' | t: terms: search.terms, count: search.results_count }}
        </p>

        {% paginate search.results by 20 %}
          <div
            class="search-page__grid"
            style="--columns-desktop: 4; --columns-mobile: 2;"
            role="list"
          >
            {% for result in search.results %}
              {% if result.object_type == 'product' %}
                {% render 'product-card', product: result %}
              {% else %}
                <article class="search-page__result" role="listitem">
                  <a href="{{ result.url }}" class="search-page__result-link" aria-label="{{ result.title }}">
                    <div class="search-page__result-image">
                      {%- assign featured_image = result.featured_image | default: result.image -%}
                      {% if featured_image %}
                        {{ featured_image | image_url: width: 400, height: 400, crop: 'center' | image_tag: class: 'search-page__result-img', loading: 'lazy' }}
                      {% else %}
                        <div class="search-page__result-img-placeholder">
                          {% render 'placeholder-image' %}
                        </div>
                      {% endif %}
                    </div>
                    <div class="search-page__result-info">
                      <span class="search-page__card-type">
                        {% if result.object_type == 'article' %}
                          {{ 'search.articles' | t }}
                        {% else %}
                          {{ 'search.pages' | t }}
                        {% endif %}
                      </span>
                      <h2 class="search-page__result-title">{{ result.title }}</h2>
                    </div>
                  </a>
                </article>
              {% endif %}
            {% endfor %}
          </div>

          {% if paginate.pages > 1 %}
            <div class="search-page__pagination">
              {{ paginate | default_pagination }}
            </div>
          {% endif %}
        {% endpaginate %}
      {% endif %}
    {% else %}
      <div class="search-page__empty">
        <div class="search-page__empty-icon">
          <svg width="64" height="64" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <circle cx="28" cy="28" r="18" stroke="currentColor" stroke-width="2"/>
            <path d="M42 42L56 56" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </div>
        <p class="search-page__empty-title">{{ 'search.start_typing' | t }}</p>
        <p class="search-page__empty-text">{{ 'search.placeholder' | t }}</p>
      </div>
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .search-page {
    background-color: var(--color-bg, #fff);
    padding: var(--space-12) 0 var(--space-20);
  }

  .search-page__container {
    max-width: var(--container-max, 1200px);
    margin: 0 auto;
    padding: 0 var(--container-padding, 24px);
  }

  /* --- Header --- */
  .search-page__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    margin-bottom: var(--space-10);
  }

  .search-page__heading {
    font-size: var(--font-size-4xl, 2.25rem);
    line-height: var(--line-height-tight, 1.2);
    letter-spacing: var(--letter-spacing-tighter, -0.02em);
    color: var(--color-text, #0a0a0a);
    margin: 0;
  }

  .search-page__form {
    max-width: 600px;
  }

  .search-page__input-wrapper {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    background-color: var(--color-bg-subtle, #f5f5f5);
    border: 1px solid var(--color-border, #e0e0e0);
    border-radius: var(--theme-radius-button, 0);
    padding: var(--space-1) var(--space-1) var(--space-1) var(--space-4);
    transition: border-color var(--duration-fast, 150ms) var(--ease-standard, ease);
  }

  .search-page__input-wrapper:focus-within {
    border-color: var(--color-accent, #0a0a0a);
    outline: 2px solid var(--color-focus, #0a0a0a);
    outline-offset: 2px;
  }

  .search-page__input-icon {
    flex-shrink: 0;
    color: var(--color-text-muted, #555);
  }

  .search-page__input {
    flex: 1;
    min-width: 0;
    border: none;
    background: none;
    font-size: var(--font-size-base, 1rem);
    font-family: inherit;
    color: var(--color-text, #0a0a0a);
    outline: none;
    padding: var(--space-2) 0;
    -webkit-appearance: none;
  }

  .search-page__input::-webkit-search-cancel-button,
  .search-page__input::-webkit-search-decoration {
    -webkit-appearance: none;
    appearance: none;
  }

  .search-page__input::placeholder {
    color: var(--color-text-disabled, #aaa);
  }

  .search-page__submit {
    flex-shrink: 0;
    height: 40px;
  }

  /* --- Count --- */
  .search-page__count {
    font-size: var(--font-size-sm, 0.875rem);
    color: var(--color-text-muted, #555);
    margin: 0 0 var(--space-6) 0;
  }

  /* --- Grid --- */
  .search-page__grid {
    display: grid;
    grid-template-columns: repeat(var(--columns-desktop, 4), 1fr);
    gap: var(--space-4);
    width: 100%;
  }

  /* --- Pagination --- */
  .search-page__pagination {
    display: flex;
    justify-content: center;
    padding-top: var(--space-4);
    width: 100%;
  }

  /* --- Non-product result cards (articles, pages) --- */
  .search-page__result {
    background: var(--theme-surface-alt);
    border-radius: var(--theme-radius-card);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .search-page__result-link {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: var(--space-4);
    text-decoration: none;
    color: inherit;
    flex: 1;
    box-sizing: border-box;
  }

  .search-page__result-link:focus-visible {
    outline: 2px solid var(--color-focus, var(--theme-text));
    outline-offset: -2px;
    border-radius: var(--theme-radius-card);
  }

  .search-page__result-image {
    position: relative;
    height: 200px;
    border-radius: var(--theme-radius-image);
    overflow: hidden;
    background: var(--color-hover-subtle-3);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .search-page__result-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .search-page__result-img-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-hover-subtle-2);
  }

  .search-page__result-placeholder-svg {
    width: 60%;
    height: auto;
    opacity: 0.4;
  }

  .search-page__result-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    align-items: center;
    text-align: center;
  }

  .search-page__result-title {
    font-size: var(--font-size-2xl);
    line-height: var(--line-height-snug);
    letter-spacing: var(--letter-spacing-tighter);
    color: var(--theme-text);
    margin: 0;
    font-weight: var(--font-weight-regular);
  }

  .search-page__card-type {
    font-size: var(--font-size-xs, 0.75rem);
    font-weight: var(--font-weight-medium, 500);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wider, 0.05em);
    color: var(--color-text-muted, #555);
  }

  /* --- Empty --- */
  .search-page__empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-16) var(--space-6);
    text-align: center;
  }

  .search-page__empty-icon {
    color: var(--color-text-disabled, #aaa);
    margin-bottom: var(--space-2);
  }

  .search-page__empty-title {
    font-size: var(--font-size-xl, 1.25rem);
    font-weight: var(--font-weight-medium, 500);
    color: var(--color-text, #0a0a0a);
    margin: 0;
  }

  .search-page__empty-text {
    font-size: var(--font-size-base, 1rem);
    color: var(--color-text-muted, #555);
    margin: 0;
  }

  .search-page__empty-hint {
    font-size: var(--font-size-sm, 0.875rem);
    color: var(--color-text-disabled, #aaa);
    margin: 0;
  }

  /* --- Responsive --- */
  @media screen and (max-width: 749px) {
    .search-page {
      padding: var(--space-6) 0 var(--space-12);
    }

    .search-page__heading {
      font-size: var(--font-size-2xl, 1.5rem);
    }

    .search-page__grid {
      grid-template-columns: repeat(var(--columns-mobile, 2), 1fr);
      gap: var(--space-3);
    }

    .search-page__result-image {
      height: 160px;
    }

    .search-page__result-title {
      font-size: var(--font-size-lg);
      line-height: var(--line-height-snug);
      letter-spacing: var(--letter-spacing-tighter);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.search",
  "settings": []
}
{% endschema %}
